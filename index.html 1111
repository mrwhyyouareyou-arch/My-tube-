            <div class="my-vid-stats">❤️${p.likes||0} 👁️${p.views||0} 💬${p.comments||0} • ${getTimeAgo(p.time)}</div>
            <div style="font-size:10px;color:${isGood?'#00c864':'#ff7777'};">${isGood?'↑ Above avg':'↓ Below avg'}</div>
          </div>
          <button class="my-vid-del" onclick="deletePost('${p.id}',event)"><i class="fas fa-trash-alt"></i></button>
