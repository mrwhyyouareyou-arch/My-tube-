// SHORT EDITOR — Camera, Sound, Trim, Speed, Timer
// ══════════════════════════════════════════════════════
let _editorSong=null,_editorTrimStart=0,_editorTrimDur=60,_editorSpeed=1;
let _editorCameraStream=null,_editorTimerInterval=null;
const SPEED_OPTIONS=[0.5,0.75,1,1.25,1.5,2];
let _editorSpeedIdx=2;

function openShortEditor(file){
  const modal=document.getElementById('shortEditorModal');
  if(!modal)return;
  modal.style.display='flex';
  _editorTrimStart=0;_editorTrimDur=60;_editorSpeed=1;_editorSpeedIdx=0;_editorSong=null;
  clearInterval(_editorTimerInterval);
  const disp=document.getElementById('editorTimerDisplay');
  if(disp){disp.style.display='none';disp.textContent='0';}
  const lbl=document.getElementById('edSpeedLbl');if(lbl)lbl.textContent='1x';
  const edSpeedBtn=document.getElementById('edSpeedBtn');if(edSpeedBtn)edSpeedBtn.style.borderColor='#333';
  closeAllEditorPanels();
  if(file){
    const vid=document.getElementById('editorVid');
    const empty=document.getElementById('editorEmptyState');
    if(vid&&vid._objURL){URL.revokeObjectURL(vid._objURL);}
    const url=URL.createObjectURL(file);
    if(vid){
      vid._objURL=url;
      vid.src=url;
      vid.style.display='block';
      vid.playbackRate=1;
      vid.load();
      vid.oncanplay=()=>{
        vid.play().catch(()=>{});
        const btn=document.getElementById('editorPlayBtn');
        if(btn)btn.innerHTML='<i class="fas fa-pause"></i>';
        const dur=Math.floor(vid.duration||60);
        const startEl=document.getElementById('edTrimStart');
        const durEl=document.getElementById('edTrimDur');
        if(startEl){startEl.max=Math.max(dur-1,1);startEl.value=0;}
        if(durEl){durEl.max=dur;durEl.value=Math.min(60,dur);_editorTrimDur=Math.min(60,dur);}
        const el=document.getElementById('edTrimEndLbl');if(el)el.textContent=Math.min(60,dur)+'s';
        const dl=document.getElementById('edTrimDurLbl');if(dl)dl.textContent=Math.min(60,dur)+'s';
      };
    }
    if(empty)empty.style.display='none';
  }
}

function closeShortEditor(){
  const modal=document.getElementById('shortEditorModal');
  if(modal)modal.style.display='none';
  stopEditorCamera();
  const vid=document.getElementById('editorVid');
  if(vid){
    vid.pause();vid.src='';
    if(vid._objURL){URL.revokeObjectURL(vid._objURL);vid._objURL=null;}
  }
  clearInterval(_editorTimerInterval);
  closeAllEditorPanels();
}

function editorTogglePlay(){
  const vid=document.getElementById('editorVid');
  const btn=document.getElementById('editorPlayBtn');
  if(!vid||!vid.src)return;
  if(vid.paused){
    vid.play().catch(()=>{});
    if(btn)btn.innerHTML='<i class="fas fa-pause"></i>';
  }else{
    vid.pause();
    if(btn)btn.innerHTML='<i class="fas fa-play"></i>';
  }
}

function editorVidSeek(secs){
  const vid=document.getElementById('editorVid');
  if(vid&&vid.duration)vid.currentTime=Math.max(0,Math.min(vid.duration,(vid.currentTime||0)+secs));
}

function closeAllEditorPanels(){
  ['editorTrimPanel','editorSoundPanel','editorTimerPanel'].forEach(id=>{
    const el=document.getElementById(id);if(el)el.style.display='none';
  });
}

async function toggleEditorCamera(){
  const btn=document.getElementById('edCamBtn');
  const camVid=document.getElementById('editorCamera');
  if(_editorCameraStream){
    stopEditorCamera();
    if(btn){btn.style.borderColor='#333';btn.style.background='#1a1a1a';}
    showToast('Camera off');
    return;
  }
  try{
    _editorCameraStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'user'},audio:false});
    if(camVid){camVid.srcObject=_editorCameraStream;camVid.style.display='block';camVid.play().catch(()=>{});}
    if(btn){btn.style.borderColor='var(--red)';btn.style.background='rgba(255,0,0,.15)';}
    showToast('Camera on 📷');
  }catch(e){showToast('Camera access denied ❌');}
}

function stopEditorCamera(){
  if(_editorCameraStream){_editorCameraStream.getTracks().forEach(t=>t.stop());_editorCameraStream=null;}
  const camVid=document.getElementById('editorCamera');
  if(camVid){camVid.srcObject=null;camVid.style.display='none';}
}

function openEditorSounds(){
  closeAllEditorPanels();
  const panel=document.getElementById('editorSoundPanel');
  if(!panel)return;
  panel.style.display='block';
  const list=document.getElementById('editorSongsList');
  if(!list)return;
  list.innerHTML=TRENDING_SONGS.map(s=>`
    <div onclick="selectEditorSong(${JSON.stringify(s).replace(/"/g,"'")}"
      style="flex-shrink:0;background:#222;border:1.5px solid ${_editorSong?.id===s.id?'var(--red)':'#444'};border-radius:10px;padding:8px 12px;cursor:pointer;min-width:110px;text-align:center;transition:border-color .2s;">
      <div style="font-size:20px;margin-bottom:4px;">${s.emoji}</div>
      <div style="font-size:10px;font-weight:600;color:#ccc;line-height:1.3;">${s.name}</div>
      ${_editorSong?.id===s.id?'<div style="font-size:9px;color:var(--red);margin-top:2px;">✓ Selected</div>':''} 
    </div>`).join('');
  const info=document.getElementById('editorSelectedSong');
  if(info)info.style.display=_editorSong?'flex':'none';
  if(_editorSong){const nm=document.getElementById('editorSongName');if(nm)nm.textContent=_editorSong.name;}
}

function selectEditorSong(song){
  _editorSong=song;
  showToast('Sound: '+song.name+' 🎵');
  openEditorSounds();
}

function clearEditorSong(){
  _editorSong=null;
  const info=document.getElementById('editorSelectedSong');
  if(info)info.style.display='none';
  openEditorSounds();
  showToast('Sound removed');
}

function openEditorTrim(){
  closeAllEditorPanels();
  const panel=document.getElementById('editorTrimPanel');
  if(!panel)return;
  panel.style.display='block';
  const vid=document.getElementById('editorVid');
  const maxDur=Math.floor(vid?.duration||60);
  const startEl=document.getElementById('edTrimStart');
  const durEl=document.getElementById('edTrimDur');
  if(startEl){startEl.max=Math.max(maxDur-1,1);startEl.value=_editorTrimStart;}
  if(durEl){durEl.max=maxDur;durEl.value=_editorTrimDur;}
  updateEdTrim();
}

function updateEdTrim(){
  const s=parseInt(document.getElementById('edTrimStart')?.value||0);
  const d=parseInt(document.getElementById('edTrimDur')?.value||60);
  _editorTrimStart=s;_editorTrimDur=d;
  const sl=document.getElementById('edTrimStartLbl');if(sl)sl.textContent=s+'s';
  const el=document.getElementById('edTrimEndLbl');if(el)el.textContent=(s+d)+'s';
  const dl=document.getElementById('edTrimDurLbl');if(dl)dl.textContent=d+'s';
  const vid=document.getElementById('editorVid');
  if(vid&&vid.duration)vid.currentTime=Math.min(s,vid.duration);
}

function applyEditorTrim(){
  const vid=document.getElementById('editorVid');
  if(vid&&vid.duration)vid.currentTime=Math.min(_editorTrimStart,vid.duration);
  showToast(`✂️ Trim: ${_editorTrimStart}s → ${_editorTrimStart+_editorTrimDur}s`);
  closeAllEditorPanels();
}

function cycleEditorSpeed(btn){
  _editorSpeedIdx=(_editorSpeedIdx+1)%SPEED_OPTIONS.length;
  _editorSpeed=SPEED_OPTIONS[_editorSpeedIdx];
  const vid=document.getElementById('editorVid');
  if(vid)vid.playbackRate=_editorSpeed;
  const lbl=document.getElementById('edSpeedLbl');if(lbl)lbl.textContent=_editorSpeed+'x';
  if(btn)btn.style.borderColor=_editorSpeed!==1?'var(--red)':'#333';
  showToast('Speed: '+_editorSpeed+'x ⚡');
}

function openEditorTimer(){
  closeAllEditorPanels();
  const panel=document.getElementById('editorTimerPanel');
  if(panel)panel.style.display='block';
  clearInterval(_editorTimerInterval);
  const disp=document.getElementById('editorTimerDisplay');
  if(disp){disp.style.display='none';disp.textContent='0';}
}

function setEditorTimer(secs){
  clearInterval(_editorTimerInterval);
  const disp=document.getElementById('editorTimerDisplay');
  if(!disp)return;
  disp.style.display='block';
  disp.style.color='var(--red)';
  let count=secs;
  disp.textContent=count;
  _editorTimerInterval=setInterval(()=>{
    count--;
    if(disp)disp.textContent=count;
    if(count<=3&&count>0)disp.style.color='#ff4444';
    if(count<=0){
      clearInterval(_editorTimerInterval);
      if(disp){disp.textContent='🎬';disp.style.color='#00c864';}
      showToast('Timer done! Record now 🔴');
    }
  },1000);
  showToast('Timer: '+secs+'s ⏱️');
}

function applyShortEdits(){
  const edits={
    trimStart:_editorTrimStart,
    trimDur:_editorTrimDur,
    speed:_editorSpeed,
    bgMusic:_editorSong?.name||null,
    bgMusicId:_editorSong?.id||null,
  };
  window._shortEditorEdits=edits;
  if(edits.bgMusic){
    selectedSong=_editorSong;
    const info=document.getElementById('selectedSongInfo');
    const nameEl=document.getElementById('selectedSongName');
    if(info)info.style.display='flex';
    if(nameEl)nameEl.textContent=edits.bgMusic;
  }
  showToast('Edits applied! ✅');
  closeShortEditor();
}

