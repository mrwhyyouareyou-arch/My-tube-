  const desc=document.getElementById('guidelineDesc')?.value?.trim();
  if(!title||!desc)return showToast('Title and description required!');
  try{
    await db.collection('guidelines').add({category:cat,title,desc,addedBy:cUser.uid,time:Date.now()});
