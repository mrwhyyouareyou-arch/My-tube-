async function doUpload(){
  if(!cUser)return showToast('Login karein!');
  const title=document.getElementById('uploadTitle').value.trim();
  const desc=document.getElementById('uploadDesc').value.trim();
  const tags=document.getElementById('uploadTags').value.trim();
  if(!title)return showToast('Title required!');
  const btn=document.getElementById('uploadBtn');
  btn.disabled=true;btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Uploading...';
  // ══ DAILY UPLOAD LIMIT CHECK ══
  const today = new Date().toDateString();
  const limitKey = `uploadLimit_${cUser.uid}_${today}`;
  let dailyCount = JSON.parse(localStorage.getItem(limitKey) || '{"video":0,"short":0,"post":0}');
  const typeKey = (uploadType==='video'||uploadType==='gaming'||uploadType==='music') ? 'video' :
                  (uploadType==='short') ? 'short' : 'post';
  const limits = {video:2, short:2, post:2};
  if(dailyCount[typeKey] >= limits[typeKey]){
    showToast(`⛔ Aaj ke liye ${typeKey} limit (${limits[typeKey]}) puri ho gayi! Kal dobara try karein.`);
    btn.disabled=false;
    btn.innerHTML='<i class="fas fa-upload"></i> Upload';
    return;
  }

  // ══ ORIGINAL CONTENT CHECK ══
  const confirmed = await new Promise(resolve => {
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;';
    overlay.innerHTML = `
      <div style="background:var(--bg2);border-radius:16px;padding:24px;max-width:340px;width:100%;border:1px solid var(--border);">
        <div style="font-size:28px;text-align:center;margin-bottom:12px;">⚠️</div>
        <h3 style="font-size:16px;font-weight:700;text-align:center;margin-bottom:8px;">Original Content Confirm Karein</h3>
        <p style="font-size:13px;color:var(--text2);text-align:center;margin-bottom:6px;">Is this your original content?<br>کیا یہ آپ کا اپنا اوریجنل مواد ہے؟</p>
        <p style="font-size:11px;color:#ff4444;text-align:center;margin-bottom:18px;line-height:1.5;">⚠️ Reused / copyrighted content upload karne par aapka account permanently terminate ho jayega aur dobara account banana ban hoga.</p>
        <div style="display:flex;gap:10px;">
          <button id="noOriginal" style="flex:1;padding:11px;border:1px solid var(--border);background:transparent;color:var(--text);border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;">No / نہیں</button>
          <button id="yesOriginal" style="flex:1;padding:11px;background:var(--red);color:white;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;">Yes / ہاں</button>
        </div>
      </div>`;
    document.body.appendChild(overlay);
    document.getElementById('yesOriginal').onclick = () => { document.body.removeChild(overlay); resolve(true); };
    document.getElementById('noOriginal').onclick = () => { document.body.removeChild(overlay); resolve(false); };
  });

  if(!confirmed){
    showToast('Upload cancel kar diya gaya.');
    btn.disabled=false;
    btn.innerHTML='<i class="fas fa-upload"></i> Upload';
    return;
  }

  // ══ DAILY COUNT SAVE ══
  dailyCount[typeKey]++;
  localStorage.setItem(limitKey, JSON.stringify(dailyCount));
  try{
    let url='',thumbURL='';
    if(uploadType!=='post'){
      if(!selectedFile){showToast('Select file!');btn.disabled=false;btn.innerHTML='<i class="fas fa-upload"></i> Upload';return;}
      const maxMB=uploadType==='image'?10:150;
      if(selectedFile.size>maxMB*1024*1024){showToast(`Max ${maxMB}MB!`);btn.disabled=false;btn.innerHTML='<i class="fas fa-upload"></i> Upload';return;}
      // ══ DUPLICATE VIDEO HASH CHECK ══
      if(uploadType==='video'||uploadType==='short'||uploadType==='gaming'){
        try{
          showToast('⏳ Duplicate check ho raha hai...');
          const buf = await selectedFile.arrayBuffer();
          const hashBuf = await crypto.subtle.digest('SHA-256', buf);
          const hashArr = Array.from(new Uint8Array(hashBuf));
          const fileHash = hashArr.map(b=>b.toString(16).padStart(2,'0')).join('');
          const hashSnap = await db.collection('videoHashes').where('hash','==',fileHash).get();
          if(!hashSnap.empty){
            showToast('❌ Duplicate content not allowed! Ye video pehle se upload ho chuki hai.');
            btn.disabled=false;
            btn.innerHTML='<i class="fas fa-upload"></i> Upload';
            return;
          }
          window._currentFileHash = fileHash;
        }catch(hashErr){
          console.warn('Hash check failed:', hashErr);
        }
      }
      showProg();
      const ep=(uploadType==='video'||uploadType==='short'||uploadType==='gaming'||uploadType==='music')
        ?`https://api.cloudinary.com/v1_1/${CLOUD}/video/upload`
        :`https://api.cloudinary.com/v1_1/${CLOUD}/image/upload`;
      url=await uploadCloud(selectedFile,ep);
      if(thumbFile)thumbURL=await uploadCloud(thumbFile,`https://api.cloudinary.com/v1_1/${CLOUD}/image/upload`);
    }
    let images=[];
    if(uploadType==='post'&&postImgFiles.length){
      for(const f of postImgFiles){images.push(await uploadCloud(f,`https://api.cloudinary.com/v1_1/${CLOUD}/image/upload`));}
    }
    hideProg();
    // ══ SAVE HASH TO FIRESTORE ══
    if(window._currentFileHash){
      await db.collection('videoHashes').add({
        hash: window._currentFileHash,
        authorId: cUser.uid,
        title: title,
        time: Date.now()
      });
      window._currentFileHash = null;
    }
    // ══ SOCIAL MEDIA REUSED CONTENT SCANNER ══
    const _st = (title+' '+desc+' '+tags).toLowerCase();
    const _badWords = [
      // Social media platforms
      'tiktok','tik tok','#tiktok','@tiktok',
      'instagram','#instagram','#reels','ig reels',
      'youtube','youtu.be','#youtube','#ytshorts',
      'facebook','#facebook','#fbvideo',
      'snapchat','#snapchat',
      'twitter','#twitter','#xvideo',
      'likee','#likee','josh app','#joshapp',
      'moj app','#mojapp','chingari',
      // Repost indicators
      'credit to','credits to','not mine','not my video',
      'not my content','taken from','downloaded from',
      'copied from','source:','via @','repost','re-post',
      'found on','belongs to','owned by','all credit',
      'full credit','original owner','original creator',
      // Urdu/Hindi repost words
      'mera nahi','meri nahi','kisi aur ka','copy kiya',
      'download kiya','wahan se liya','yahan se liya',
      // Watermark hints
      'follow me on','follow us on','link in bio',
      'swipe up','watch on','available on',
      // Common spam
      'میرا نہیں','کسی اور کا','ڈاؤنلوڈ کیا','کاپی کیا',
      'ٹک ٹاک','انسٹاگرام','یوٹیوب'
    ];
    const _found = _badWords.find(w => _st.includes(w));
    if(_found){
      await db.collection('flaggedContent').add({
        authorId: cUser.uid,
        authorName: cUserData?.name || cUser.email,
        title, desc,
        reason: 'Suspicious keyword: "' + _found + '"',
        type: uploadType,
        time: Date.now(),
        status: 'pending'
      });
      showToast('⚠️ Aapka content review ke liye flag ho gaya! Agar reused content hai to account terminate hoga.');
      btn.disabled=false;
      btn.innerHTML='<i class="fas fa-upload"></i> Upload';
      return;
    }
    // Initial rankScore based on recency
    const initialScore=calcScore({time:Date.now(),likes:0,views:0,comments:0,type:uploadType,category:tags.split(',')[0]?.trim()||uploadType});
    await db.collection('posts').add({
      title,desc,url,thumbURL,images,type:uploadType,
      category:document.getElementById('uploadCategory')?.value||tags.split(',')[0]?.trim()||uploadType,
      tags:tags.split(',').map(t=>t.trim()).filter(Boolean),
      authorId:cUser.uid,
      authorName:cUserData?.name||cUser.email,
      authorHandle:cUserData?.channelHandle||cUserData?.handle||(''.concat('@',((cUserData?.name||cUser.email).toLowerCase().replace(/[^a-z0-9]/g,'').substring(0,20)))),
      authorPhoto:cUserData?.photoURL||'',
      likes:0,likedBy:[],views:0,comments:0,reactions:{},
      rankScore:initialScore,time:Date.now(),
      duration:window._vidDuration||'',
      bgMusic:selectedSong?selectedSong.name:'',
      bgColor:window._postBg||'',
      affiliate:getAffiliateData()||null,
      privacy:_uploadPrivacy||'public',
      searchTerms:extractSearchTerms({title,desc,tags:tags.split(',').map(t=>t.trim()),category:document.getElementById('uploadCategory')?.value||uploadType,type:uploadType}),
      ...getProductDataForUpload()
    });
    showToast('✅ Uploaded successfully!');
    resetUploadForm();btn.disabled=false;btn.innerHTML='<i class="fas fa-upload"></i> Upload';
    setTimeout(()=>showScreen('home'),1000);
  }catch(e){
    console.error(e);
    if(e.message!=='Product description required'){
      showToast('Upload failed: '+e.message);
    }
    btn.disabled=false;btn.innerHTML='<i class="fas fa-upload"></i> Upload';hideProg();
  }
}

async function uploadCloud(file,ep){
  const fd=new FormData();fd.append('file',file);fd.append('upload_preset',PRESET);
  let prog=0;
  const progEl=document.getElementById('progFill');
  const iv=setInterval(()=>{prog=Math.min(prog+3,88);if(progEl)progEl.style.width=prog+'%';},250);
  try{
    const res=await fetch(ep,{method:'POST',body:fd});
    clearInterval(iv);
    if(progEl)progEl.style.width='100%';
    if(!res.ok){const er=await res.json();throw new Error(er.error?.message||'Upload failed');}
    const data=await res.json();return data.secure_url;
  }catch(e){
    clearInterval(iv);
    if(progEl)progEl.style.width='0%';
    throw e;
  }
}

