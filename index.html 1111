async function sfPostComment(){
  if(!cUser||!sfCurrentId)return;
  const input=document.getElementById('sfCommInput');
  if(!input)return;
  let text=(input.value||'').trim();
  if(!text){input.focus();return;}
  input.value='';
  input.blur();
  const replyData = _sfReplyTo;
  clearSfReply();
  // If text starts with @name (auto-filled), keep it as-is for display
  // but store clean message separately
  const cleanText = text;
  try{
    const commentData={
      text:cleanText,
      authorId:cUser.uid,authorName:cUserData?.name||cUser.email,
      authorPhoto:cUserData?.photoURL||'',time:Date.now(),
      likes:0,likedBy:[],
      replyTo:replyData?replyData.name:null,
      parentId:replyData?replyData.commentId:null
    };
    if(replyData && replyData.commentId){
      await db.collection('posts').doc(sfCurrentId).collection('comments').doc(replyData.commentId).collection('replies').add(commentData);
      await db.collection('posts').doc(sfCurrentId).collection('comments').doc(replyData.commentId).update({replyCount:firebase.firestore.FieldValue.increment(1)});
      const parentSnap=await db.collection('posts').doc(sfCurrentId).collection('comments').doc(replyData.commentId).get();
      if(parentSnap.exists){
        const parentAuthorId=parentSnap.data().authorId;
        if(parentAuthorId&&parentAuthorId!==cUser.uid) sendNotif(parentAuthorId,'reply',`${cUserData?.name||'Someone'} replied: "${cleanText.substring(0,40)}"`,sfCurrentId,'short');
      }
    } else {
      await db.collection('posts').doc(sfCurrentId).collection('comments').add(commentData);
      await db.collection('posts').doc(sfCurrentId).update({comments:firebase.firestore.FieldValue.increment(1)});
      const sfPost=sfPosts[sfCurrentIdx];
      if(sfPost) sendNotif(sfPost.authorId,'comment',`${cUserData?.name||'Someone'} commented: "${cleanText.substring(0,40)}"`,sfCurrentId,'short');
    }
    sfLoadComments(sfCurrentId);
    showToast('Comment posted ✅');
  }catch(e){showToast('Error posting comment');}
}

