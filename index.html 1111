// UNIQUE VIEW COUNT — per user per video (Firestore-based)
// ══════════════════════════════════════════════════════
async function trackUniqueView(postId){
  if(!cUser||!postId)return;
  try{
    // Owner apni khud ki video ka view count nahi badhata
    if(currentPostData&&currentPostData.authorId===cUser.uid)return;
    // Unique view: har user ke liye sirf ek baar - 24 hour cooldown bhi
    const viewKey=cUser.uid+'_'+postId;
    const viewRef=db.collection('views').doc(viewKey);
    const exists=await viewRef.get();
    if(!exists.exists){
      await viewRef.set({uid:cUser.uid,postId,time:Date.now()});
      await db.collection('posts').doc(postId).update({
        views:firebase.firestore.FieldValue.increment(1),
        rankScore:firebase.firestore.FieldValue.increment(2)
      }).catch(()=>{});
    }
    // Even if doc exists, don't increment again - true unique view per user
  }catch(e){}
}

// ══════════════════════════════════════════════════════
// DASHBOARD — Load videos/shorts/posts separately
// ══════════════════════════════════════════════════════
async function loadMyContentSections(){
  if(!cUser)return;
  const [vEl,sEl,pEl]=['myVideosList','myShortsList','myPostsList'].map(id=>document.getElementById(id));
  [vEl,sEl,pEl].forEach(el=>{if(el)el.innerHTML='<div class="loader"><div class="spinner"></div></div>';});
  try{
    let snap;
    try{
      snap=await db.collection('posts').where('authorId','==',cUser.uid).orderBy('time','desc').get();
    }catch(e){
      // Fallback if index not ready
      snap=await db.collection('posts').where('authorId','==',cUser.uid).get();
    }
    const all=snap.docs.map(d=>({id:d.id,...d.data()})).sort((a,b)=>(b.time||0)-(a.time||0));
    const videos=all.filter(p=>p.type==='video'||p.type==='gaming'||p.type==='music');
    const shorts=all.filter(p=>p.type==='short');
    const posts=all.filter(p=>p.type==='post'||p.type==='image');

    function renderItem(p){
      const priv=p.privacy||'public';
      const privIcon=priv==='private'?'🔒':priv==='unlisted'?'🔗':'🌐';
      return `<div style="display:flex;gap:10px;padding:10px;background:var(--card);border:1px solid var(--border);border-radius:12px;margin-bottom:8px;cursor:pointer;" onclick="openPost('${p.id}')">
        <div style="width:80px;height:52px;border-radius:8px;overflow:hidden;background:var(--bg3);flex-shrink:0;position:relative;">
          ${p.thumbURL?`<img src="${p.thumbURL}" style="width:100%;height:100%;object-fit:cover;">`:`<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;"><i class="fas fa-${p.type==='short'?'film':'video'}" style="color:var(--text3);font-size:18px;"></i></div>`}
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:13px;font-weight:600;line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${p.title||'Untitled'}</div>
          <div style="font-size:11px;color:var(--text3);margin-top:3px;">👁 ${p.views||0} &nbsp; ❤️ ${p.likes||0} &nbsp; 💬 ${p.comments||0}</div>
          <div style="font-size:10px;color:var(--text3);margin-top:2px;">CTR: ${p.views>0?Math.min(100,Math.round(((p.likes||0)/(p.views||1))*100)):0}% &nbsp; ${privIcon} ${priv}</div>
        </div>
        <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;">
          <button onclick="togglePostPrivacy('${p.id}','${priv}',this);event.stopPropagation();" style="background:none;border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:3px 7px;font-size:10px;cursor:pointer;">${privIcon}</button>
          <button onclick="ctxDeleteContent('${p.id}');event.stopPropagation();" style="background:none;border:none;color:#ff4444;cursor:pointer;font-size:13px;"><i class="fas fa-trash"></i></button>
        </div>
      </div>`;
    }

    if(vEl)vEl.innerHTML=videos.length?videos.map(renderItem).join(''):'<div class="empty-state"><i class="fas fa-video"></i><p>No videos yet</p></div>';
    if(sEl)sEl.innerHTML=shorts.length?shorts.map(renderItem).join(''):'<div class="empty-state"><i class="fas fa-film"></i><p>No shorts yet</p></div>';
    if(pEl)pEl.innerHTML=posts.length?posts.map(renderItem).join(''):'<div class="empty-state"><i class="fas fa-pen"></i><p>No posts yet</p></div>';
  }catch(e){
    console.error('loadMyContentSections:',e);
    [vEl,sEl,pEl].forEach(el=>{if(el)el.innerHTML='<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>Error loading content</p></div>';});
  }
}

async function togglePostPrivacy(postId,current,btn){
  const order=['public','unlisted','private'];
  const icons={'public':'🌐','unlisted':'🔗','private':'🔒'};
  const next=order[(order.indexOf(current)+1)%order.length];
  try{
    await db.collection('posts').doc(postId).update({privacy:next});
    if(btn)btn.textContent=icons[next];
    showToast('Visibility: '+next+' '+icons[next]);
  }catch(e){showToast('Error updating');}
}

async function ctxDeleteContent(postId){
  if(!confirm('Delete this content?'))return;
  try{
    await db.collection('posts').doc(postId).delete();
    showToast('Deleted ✅');
    loadMyContentSections();
  }catch(e){showToast('Error: '+e.message);}
}

