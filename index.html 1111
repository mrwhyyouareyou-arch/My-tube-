// Product image slots state
let _prodImgUrls=[null,null,null];

function previewProdImg(url){} // legacy stub

async function handleProdImgSelect(input){
  const file=input.files[0];
  if(!file)return;
  const slot=parseInt(input.getAttribute('data-slot')||'0');
  const slotEl=document.getElementById('prodSlot'+slot);
  if(!slotEl)return;
  // Show local preview immediately
  const localUrl=URL.createObjectURL(file);
  slotEl.innerHTML=`<img src="${localUrl}"><div class="slot-del" onclick="clearProdSlot(${slot},event)"><i class="fas fa-times"></i></div>`;
  slotEl.classList.add('filled');
  showToast('Image upload ho rahi hai...');
  try{
    // Upload to Cloudinary
    const fd=new FormData();
    fd.append('file',file);
    fd.append('upload_preset',PRESET);
    const res=await fetch(`https://api.cloudinary.com/v1_1/${CLOUD}/image/upload`,{method:'POST',body:fd});
    const data=await res.json();
    if(!data.secure_url)throw new Error('Upload failed');
    _prodImgUrls[slot]=data.secure_url;
    // Update preview with final URL
    slotEl.innerHTML=`<img src="${data.secure_url}"><div class="slot-del" onclick="clearProdSlot(${slot},event)"><i class="fas fa-times"></i></div>`;
    showToast('Photo add ho gayi ✅');
  }catch(e){
    _prodImgUrls[slot]=null;
    slotEl.innerHTML='<i class="fas fa-plus"></i>';
    slotEl.classList.remove('filled');
    showToast('Image upload fail: '+e.message);
  }
  input.value='';
}

function clearProdSlot(slot,e){
  if(e)e.stopPropagation();
  _prodImgUrls[slot]=null;
  const slotEl=document.getElementById('prodSlot'+slot);
  if(slotEl){slotEl.innerHTML='<i class="fas fa-plus"></i>';slotEl.classList.remove('filled');}
}

function getProductDataForUpload(){
