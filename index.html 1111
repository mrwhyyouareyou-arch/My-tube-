      ctx.fillStyle=color;
      ctx.beginPath();ctx.ellipse(0,0,size,size*0.5,0,0,Math.PI*2);ctx.fill();
      ctx.beginPath();ctx.moveTo(-size,0);ctx.lineTo(-size-size*0.7,-size*0.5);ctx.lineTo(-size-size*0.7,size*0.5);ctx.closePath();ctx.fill();
      ctx.fillStyle='rgba(0,0,0,0.4)';ctx.beginPath();ctx.arc(size*0.4,-size*0.1,size*0.1,0,Math.PI*2);ctx.fill();
      ctx.restore();
    }
    let rafId=null;
    function animate(){
      ctx.clearRect(0,0,canvas.width,canvas.height);
      fishes.forEach(f=>{
        f.wave+=0.03;f.y+=Math.sin(f.wave)*0.4;f.x+=f.speed*f.dir;
        if(f.x>canvas.width+100){f.x=-100;f.y=60+Math.random()*(canvas.height-120);}
        if(f.x<-100){f.x=canvas.width+100;f.y=60+Math.random()*(canvas.height-120);}
        drawFish(f.x,f.y,f.size,f.color,f.dir);
      });
      rafId=requestAnimationFrame(animate);
    }
    animate();
    window.addEventListener('resize',resize);
  }
  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',setup);}
  else{setTimeout(setup,200);}
})();
</script>
</body>
</html>

