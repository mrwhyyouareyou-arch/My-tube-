function loadUserPrefs(){
  const saved=localStorage.getItem('mt_prefs');
  if(saved){try{userPrefs=JSON.parse(saved);}catch(e){}}
}

function updateUserPrefs(post){
  if(!post)return;
  const cat=post.category||post.type;
  if(cat){
    if(!userPrefs.topCats)userPrefs.topCats=[];
    if(!userPrefs.topCats.includes(cat))userPrefs.topCats.unshift(cat);
    userPrefs.topCats=userPrefs.topCats.slice(0,10);
  }
  if(post.authorId){
    if(!userPrefs.seenAuthors)userPrefs.seenAuthors={};
    userPrefs.seenAuthors[post.authorId]=(userPrefs.seenAuthors[post.authorId]||0)+1;
  }
  localStorage.setItem('mt_prefs',JSON.stringify(userPrefs));
}

