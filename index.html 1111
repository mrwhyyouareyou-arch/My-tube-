// SMART SEARCH — Algorithm connected
// ══════════════════════════════════════════════════════
let searchTimeout;
function searchFocus(){document.getElementById('searchBarEl').classList.add('focused');showSearchSuggestions();}
function searchBlur(){setTimeout(()=>{document.getElementById('searchBarEl').classList.remove('focused');},200);}

function showSearchSuggestions(){
  const sug=document.getElementById('searchSuggestions');
  if(!sug)return;
  const trending=['Cricket','Gaming','Music','Funny','News','Pakistan','Shorts','Food'];
  const recent=searchHistory.slice(0,4);
  let html='';
  if(recent.length){html+=`<div style="font-size:11px;color:var(--text3);margin-bottom:6px;">Recent</div>`+recent.map(h=>`<span class="suggestion-chip" onclick="doSearch('${h}')"><i class="fas fa-history"></i>${h}</span>`).join('')+'<div style="margin-top:10px;font-size:11px;color:var(--text3);">Trending</div>';}
  html+=trending.map(t=>`<span class="suggestion-chip" onclick="doSearch('${t}')"><i class="fas fa-fire"></i>${t}</span>`).join('');
  sug.innerHTML=html;
}

function onSearchInput(v){
  clearTimeout(searchTimeout);
  if(v.trim())searchTimeout=setTimeout(()=>doSearch(v),500);
  else showSearchSuggestions();
}

async function doSearch(q){
  const query=q||document.getElementById('searchInput').value.trim();
  if(!query)return;
  if(document.getElementById('searchInput'))document.getElementById('searchInput').value=query;
  showScreen('search');
  if(!searchHistory.includes(query)){searchHistory.unshift(query);searchHistory=searchHistory.slice(0,8);}
  const results=document.getElementById('searchResults');
  results.innerHTML='<div class="loader"><div class="spinner"></div></div>';
  try{
    const snap=await db.collection('posts').orderBy('time','desc').limit(200).get();
    const ql=query.toLowerCase().replace(/^#/,'');
    let posts=snap.docs.map(d=>({id:d.id,...d.data()}))
      .filter(p=>{
        // Skip private posts (not yours)
        if((p.privacy==='private')&&p.authorId!==cUser?.uid)return false;
        const inTitle=(p.title||'').toLowerCase().includes(ql);
        const inDesc=(p.desc||'').toLowerCase().includes(ql);
        const inCat=(p.category||'').toLowerCase().includes(ql);
        const inAuthor=(p.authorName||'').toLowerCase().includes(ql);
        const inTags=(p.tags||[]).some(t=>t.toLowerCase().replace(/^#/,'').includes(ql));
        // Check precomputed searchTerms (hashtags, keywords)
        const inSearchTerms=(p.searchTerms||[]).some(t=>(t||'').toLowerCase().includes(ql));
        // Check hashtags embedded in title
        const hashTagsInTitle=[...(p.title||'').matchAll(/#(\w+)/g)].map(m=>m[1].toLowerCase());
        const inHashTags=hashTagsInTitle.some(h=>h.includes(ql));
        return inTitle||inDesc||inCat||inAuthor||inTags||inSearchTerms||inHashTags;
      });
    // Sort by relevance + algorithm score
    posts=posts.map(p=>{
      let relevance=0;
      const titleLow=(p.title||'').toLowerCase();
      if(titleLow.startsWith(ql))relevance+=30;
      else if(titleLow.includes(ql))relevance+=20;
      if((p.category||'').toLowerCase().includes(ql))relevance+=15;
      if((p.tags||[]).some(t=>t.toLowerCase().replace(/^#/,'').includes(ql)))relevance+=12;
      if((p.searchTerms||[]).some(t=>(t||'').toLowerCase().includes(ql)))relevance+=10;
      return {...p,_searchScore:(p.rankScore||0)+relevance};
    }).sort((a,b)=>b._searchScore-a._searchScore);
    if(!posts.length){results.innerHTML=`<div class="empty-state"><i class="fas fa-search"></i><p>No results for "${query}"</p></div>`;return;}
    results.innerHTML=posts.map(p=>buildCard(p)).join('');
  }catch(e){results.innerHTML='<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>Search error</p></div>';}
}

