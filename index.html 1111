// Live fetch product image when sheet opens
async function tryFetchProductImg(url){
  if(!url)return;
  try{
    const proxy=`https://api.allorigins.win/get?url=${encodeURIComponent(url)}`;
    const res=await fetch(proxy,{signal:AbortSignal.timeout(6000)});
    const data=await res.json();
    const html=data.contents||'';
    // Try OG image
    const ogMatch=html.match(/<meta[^>]*property=["']og:image["'][^>]*content=["']([^"']+)["']/i)
      ||html.match(/<meta[^>]*content=["']([^"']+)["'][^>]*property=["']og:image["']/i);
    const img=ogMatch?ogMatch[1]:'';
    // Try title
    const titleMatch=html.match(/<meta[^>]*property=["']og:title["'][^>]*content=["']([^"']+)["']/i)
      ||html.match(/<title[^>]*>([^<]+)<\/title>/i);
    const title=titleMatch?decodeHTMLEntities(titleMatch[1].replace(/\s*[\|–-]\s*(Daraz|Amazon|OLX).*$/i,'').trim()):'';
    // Try price
    const price=extractPrice(html)||'';
    const imgEl=document.getElementById('psImg');
