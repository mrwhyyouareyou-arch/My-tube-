async function ensureChannelExists(){
  if(!cUser)return;
  try{
    const doc=await db.collection('users').doc(cUser.uid).get();
    if(!doc.exists)return;
    const u=doc.data();
    if(u.hasChannel&&u.channelName)return; // Already has channel
    // Auto create channel from user name
    const name=u.name||cUser.displayName||cUser.email.split('@')[0];
    const handle='@'+name.toLowerCase().replace(/[^a-z0-9]/g,'').substring(0,20);
    await db.collection('channels').doc(cUser.uid).set({
      name,handle,about:'',
      ownerEmail:cUser.email,ownerUid:cUser.uid,
      ownerPhoto:u.photoURL||'',
      subscribers:0,videos:0,
      createdAt:firebase.firestore.FieldValue.serverTimestamp()
    },{merge:true});
    await db.collection('users').doc(cUser.uid).update({
      channelName:name,channelHandle:handle,hasChannel:true
    });
    if(cUserData){cUserData.channelName=name;cUserData.channelHandle=handle;cUserData.hasChannel=true;}
  }catch(e){console.log('Channel auto-create:',e.message);}
}

async function loadUserData(){
  if(!cUser)return;
  try{
    const doc=await db.collection('users').doc(cUser.uid).get();
    cUserData=doc.exists?doc.data():{name:cUser.displayName||'User',handle:'@user',about:'',photoURL:cUser.photoURL||'',subscribers:0};
    // Update lastSeen
    db.collection('users').doc(cUser.uid).update({lastSeen:Date.now()}).catch(()=>{});
    updateProfileUI();
    updateEmailChannelUI();
  }catch(e){console.error(e);}
}

