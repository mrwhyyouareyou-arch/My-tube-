let _scStream=null,_scRecorder=null,_scChunks=[],_scRecording=false;
let _scMaxTime=15,_scElapsed=0,_scProgInt=null;
let _scFacing='environment',_scSpeedIdx=2;
const SC_SPEEDS=[0.5,0.75,1,1.25,1.5];
let scTextColor='#ffffff';

function openShortsCamera(){
  const modal=document.getElementById('shortsCameraModal');
  if(modal)modal.style.display='block';
  // Show record mode
  const rm=document.getElementById('scRecordMode');
  const em=document.getElementById('scEditMode');
  if(rm)rm.style.display='flex';
  if(em)em.style.display='none';
  startShortsStream();
  // Load trending sounds
  setTimeout(loadScSounds,500);
}

async function startShortsStream(){
  try{
    if(_scStream){_scStream.getTracks().forEach(t=>t.stop());}
    _scStream=await navigator.mediaDevices.getUserMedia({
      video:{facingMode:_scFacing,width:{ideal:1080},height:{ideal:1920}},
      audio:true
    });
    const prev=document.getElementById('shortsCamPreview');
    if(prev){prev.srcObject=_scStream;prev.play().catch(()=>{});}
  }catch(e){
    showToast('Camera access denied. Allow in browser settings.');
    closeShortsCamera();
  }
}

function closeShortsCamera(){
  stopShortsRecording();
  if(_scStream){_scStream.getTracks().forEach(t=>t.stop());_scStream=null;}
  const modal=document.getElementById('shortsCameraModal');
  if(modal)modal.style.display='none';
  // Reset
  const prog=document.getElementById('scProgress');if(prog)prog.style.width='0%';
  const ov=document.getElementById('scTextOverlays');if(ov)ov.innerHTML='';
  window._scSelectedSound=null;window._scAudioBlob=null;
  closeAllEditPanels();
  const sp=document.getElementById('scSoundQuickPanel');if(sp)sp.style.display='none';
}

function backToRecordMode(){
  const rm=document.getElementById('scRecordMode');
  const em=document.getElementById('scEditMode');
  if(rm)rm.style.display='flex';
  if(em)em.style.display='none';
  const ov=document.getElementById('scTextOverlays');if(ov)ov.innerHTML='';
  closeAllEditPanels();
  startShortsStream();
}

function flipShortsCamera(){
  _scFacing=_scFacing==='environment'?'user':'environment';
  startShortsStream();
}

function setShortsTimer(secs){
  _scMaxTime=secs;
  ['scT15','scT30','scT60'].forEach(id=>{
    const el=document.getElementById(id);
    if(el){el.style.borderColor='transparent';el.style.color='rgba(255,255,255,.6)';}
  });
  const active=document.getElementById('scT'+secs);
  if(active){active.style.borderColor='white';active.style.color='white';}
  showToast(secs+'s selected');
}

function cycleShortsSpeed(){
  _scSpeedIdx=(_scSpeedIdx+1)%SC_SPEEDS.length;
  const spd=SC_SPEEDS[_scSpeedIdx];
  const lbl=document.getElementById('scSpeedLbl');
  if(lbl)lbl.textContent=spd+'x';
  showToast('Speed: '+spd+'x');
}

function toggleShortsRecording(){
  if(_scRecording)stopShortsRecording();
  else startShortsRecording();
}

function startShortsRecording(){
  if(!_scStream)return showToast('Camera not ready');
  _scChunks=[];_scElapsed=0;_scRecording=true;
  const icon=document.getElementById('scRecordIcon');
  if(icon){icon.style.borderRadius='6px';icon.style.width='30px';icon.style.height='30px';}
  const timeEl=document.getElementById('scRecTime');
  if(timeEl)timeEl.style.display='block';
  let mimeType='';
  if(MediaRecorder.isTypeSupported('video/mp4;codecs=avc1'))mimeType='video/mp4;codecs=avc1';
  else if(MediaRecorder.isTypeSupported('video/webm;codecs=vp8,opus'))mimeType='video/webm;codecs=vp8,opus';
  else if(MediaRecorder.isTypeSupported('video/webm'))mimeType='video/webm';
  try{_scRecorder=mimeType?new MediaRecorder(_scStream,{mimeType}):new MediaRecorder(_scStream);}
  catch(e){_scRecorder=new MediaRecorder(_scStream);}
  _scRecorder.ondataavailable=e=>{if(e.data&&e.data.size>0)_scChunks.push(e.data);};
  _scRecorder.onstop=()=>finalizeShortsRecording();
  _scRecorder.start(100);
  const prog=document.getElementById('scProgress');
  _scProgInt=setInterval(()=>{
    _scElapsed+=0.1;
    const pct=(_scElapsed/_scMaxTime)*100;
    if(prog)prog.style.width=Math.min(pct,100)+'%';
    const m=Math.floor(_scElapsed/60),s=Math.floor(_scElapsed%60);
    if(timeEl)timeEl.textContent=m+':'+(s<10?'0'+s:s);
    if(_scElapsed>=_scMaxTime)stopShortsRecording();
  },100);
}

function stopShortsRecording(){
  if(!_scRecording)return;
  _scRecording=false;
  clearInterval(_scProgInt);
  if(_scRecorder&&_scRecorder.state!=='inactive')_scRecorder.stop();
  const icon=document.getElementById('scRecordIcon');
  if(icon){icon.style.borderRadius='50%';icon.style.width='38px';icon.style.height='38px';}
}

function finalizeShortsRecording(){
  const mimeType=_scRecorder?.mimeType||'video/webm';
  const ext=mimeType.includes('mp4')?'mp4':'webm';
  const blob=new Blob(_scChunks,{type:mimeType});
  window._recordedShortFile=new File([blob],'short_'+Date.now()+'.'+ext,{type:mimeType});
  if(_scStream){_scStream.getTracks().forEach(t=>t.stop());_scStream=null;}
  const url=URL.createObjectURL(blob);
  const recPrev=document.getElementById('shortsRecPreview');
  if(recPrev){recPrev.src=url;recPrev.play().catch(()=>{});}
  // Switch to edit mode
  const rm=document.getElementById('scRecordMode');
  const em=document.getElementById('scEditMode');
  if(rm)rm.style.display='none';
  if(em)em.style.display='flex';
  // Load edit sounds
  loadScEditSounds();
  showToast('Done! Edit and tap Upload →');
}

function handleGalleryShort(input){
