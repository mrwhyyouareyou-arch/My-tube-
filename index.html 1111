  _liking[id]=true;setTimeout(()=>delete _liking[id],1500);
  try{
    const ref=db.collection('posts').doc(id);
    const doc=await ref.get();if(!doc.exists)return;const p=doc.data();
    const liked=(p.likedBy||[]).includes(cUser.uid);
    if(liked){
      await ref.update({likes:firebase.firestore.FieldValue.increment(-1),likedBy:firebase.firestore.FieldValue.arrayRemove(cUser.uid)});
      btn.innerHTML=`<i class="fas fa-heart"></i> ${Math.max(0,(p.likes||1)-1)}`;
      btn.classList.remove('liked');
    }else{
      await ref.update({
        likes:firebase.firestore.FieldValue.increment(1),
        likedBy:firebase.firestore.FieldValue.arrayUnion(cUser.uid),
        rankScore:firebase.firestore.FieldValue.increment(12)
      });
      btn.innerHTML=`<i class="fas fa-heart"></i> ${(p.likes||0)+1}`;
      btn.classList.add('liked');
      sendNotif(p.authorId,'like',`${cUserData?.name||'Someone'} liked your post "${p.title||''}"`,id);
    }
  }catch(e){showToast('Error');}
}

