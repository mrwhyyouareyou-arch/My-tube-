// HASHTAG SEARCH — make titles & tags searchable for FYP
// ══════════════════════════════════════════════════════
function extractSearchTerms(post){
  const terms=new Set();
  const title=(post.title||'').toLowerCase();
  const desc=(post.desc||'').toLowerCase();
  const tags=post.tags||[];
  // Add each word from title
  title.split(/\s+/).filter(w=>w.length>2).forEach(w=>terms.add(w));
  // Add hashtags from title & desc
  [...title.matchAll(/#(\w+)/g),...desc.matchAll(/#(\w+)/g)].forEach(m=>terms.add(m[1]));
  // Add tags
  tags.forEach(t=>terms.add(t.toLowerCase().replace(/^#/,'')));
  // Add category
  if(post.category)terms.add(post.category);
  if(post.type)terms.add(post.type);
  return [...terms].slice(0,20);
}

