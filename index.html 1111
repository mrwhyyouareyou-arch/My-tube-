// Comment context menu state
let _commCtxData = {};
function openCommCtx(postId, commentId, authorId, authorName, likeCount, liked){
  _commCtxData = {postId, commentId, authorId, authorName, likeCount, liked};
  document.getElementById('commCtxAuthor').textContent = '@'+authorName;
  document.getElementById('commCtxOverlay').style.display='block';
  document.getElementById('commCtxSheet').classList.add('open');
}
function closeCommCtx(){
  document.getElementById('commCtxOverlay').style.display='none';
  document.getElementById('commCtxSheet').classList.remove('open');
}
async function commCtxAction(action){
  closeCommCtx();
  const {postId,commentId,authorId,authorName} = _commCtxData;
  if(action==='reply'){ setVideoReply(authorName, commentId); }
  else if(action==='like'){ const btn=document.getElementById('clbtn_'+commentId); if(btn) likeComment(postId,commentId,btn); }
  else if(action==='profile'){ if(authorId) openChannelPage(authorId,null); }
  else if(action==='share'){ navigator.clipboard?.writeText('Comment by @'+authorName).then(()=>showToast('Copied!')).catch(()=>showToast('Shared!')); }
  else if(action==='report'){ showToast('Report submitted ✅'); }
  else if(action==='block'){
    if(!cUser) return showToast('Login karein!');
    try{
      await db.collection('users').doc(cUser.uid).update({blocked:firebase.firestore.FieldValue.arrayUnion(authorId)});
      showToast('User blocked 🚫');
      // Hide their comments
      document.querySelectorAll(`[data-author="${authorId}"]`).forEach(el=>el.remove());
    }catch(e){ showToast('Block failed'); }
  }
}

