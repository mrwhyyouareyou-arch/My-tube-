async function reactEmoji(emoji,btn){
  if(!cUser||!currentPostId)return;
  try{
    const ref=db.collection('posts').doc(currentPostId);
    const doc=await ref.get();if(!doc.exists)return;const p=doc.data();
    const r=p.reactions||{};
    const users=r[emoji+'_u']||[];
    const reacted=users.includes(cUser.uid);
    const update={};
    if(reacted){
      update[`reactions.${emoji}`]=firebase.firestore.FieldValue.increment(-1);
      update[`reactions.${emoji}_u`]=firebase.firestore.FieldValue.arrayRemove(cUser.uid);
      update.rankScore=firebase.firestore.FieldValue.increment(-3);
      btn.classList.remove('reacted');
    }else{
      update[`reactions.${emoji}`]=firebase.firestore.FieldValue.increment(1);
      update[`reactions.${emoji}_u`]=firebase.firestore.FieldValue.arrayUnion(cUser.uid);
      update.rankScore=firebase.firestore.FieldValue.increment(3);
      btn.classList.add('reacted');
    }
    await ref.update(update);
    const nd=await ref.get();loadReactions(nd.data());
  }catch(e){}
}

async function toggleSubscribe(){
  if(!cUser){showToast('Login karein pehle!');return;}
  if(!currentPostData){return;}
  const aId=currentPostData.authorId;
  if(!aId||aId===cUser.uid){showToast('Apne aap ko subscribe nahi kar sakte');return;}
  const btn=document.getElementById('playerSubBtn');
  if(btn){btn.disabled=true;btn.style.opacity='0.6';}
  const sid=`${cUser.uid}_${aId}`;
  const ref=db.collection('subscriptions').doc(sid);
  try{
    const doc=await ref.get();
    if(doc.exists){
      await ref.delete();
      await db.collection('users').doc(aId).update({subscribers:firebase.firestore.FieldValue.increment(-1)}).catch(()=>{});
      if(btn){btn.textContent='Subscribe';btn.classList.remove('subscribed');}
      showToast('Unsubscribed');
    }else{
      await ref.set({from:cUser.uid,to:aId,time:Date.now()});
      await db.collection('users').doc(aId).update({subscribers:firebase.firestore.FieldValue.increment(1)}).catch(()=>{});
      if(btn){btn.textContent='Subscribed ✓';btn.classList.add('subscribed');}
      showToast('Subscribed! ✅');
      sendNotif(aId,'sub',`${cUserData?.name||'Someone'} subscribed to your channel!`,null);
    }
    // Update subscriber count display
    db.collection('users').doc(aId).get().then(ud=>{
      if(ud.exists){
        const subsEl=document.getElementById('playerChSubs');
        if(subsEl)subsEl.textContent=(ud.data().subscribers||0)+' subscribers';
      }
    }).catch(()=>{});
  }catch(e){
    console.error('Subscribe error:',e);
    showToast('Error: '+e.message);
  }finally{
    if(btn){btn.disabled=false;btn.style.opacity='1';}
  }
}

