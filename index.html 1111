function openUploadDirect(type){
  showScreen('upload');
  setTimeout(()=>{
    let card=null;
    document.querySelectorAll('.type-card').forEach(c=>{
      const t=c.querySelector('span')?.textContent?.toLowerCase()||'';
      if(type==='video'&&(t.includes('video')||t.includes('gaming')||t.includes('music')))card=card||c;
      else if(type==='post'&&t.includes('post'))card=c;
      else if(type==='short'&&t.includes('short'))card=c;
    });
    if(card)selectType(type,card);
  },200);
}

