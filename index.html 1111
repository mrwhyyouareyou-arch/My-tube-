const MONET_REQS={videos:10,subscribers:1000,watchHours:2000,shortsViews:5000000};
const CPM_PKR=85; // ₨85 per 1000 views (Pakistan rate)
let _selectedThanksAmt=100;
let _selectedPayoutMethod='jazzcash';
let _selectedMembershipTier='pro';

async function loadMonetizationTab(){
  if(!cUser)return;
  try{
    const snap=await db.collection('posts').where('authorId','==',cUser.uid).get();
    let videos=0,shorts=0,totalViews=0,shortsTotalViews=0,totalWatchSecs=0;
    snap.forEach(d=>{
      const p=d.data();
      if(p.type==='video'||p.type==='gaming'||p.type==='music'){videos++;totalViews+=p.views||0;totalWatchSecs+=p.watchTime||0;}
      if(p.type==='short'){shorts++;shortsTotalViews+=p.views||0;}
    });
    const ud=await db.collection('users').doc(cUser.uid).get();
    const subs=ud.exists?(ud.data().subscribers||0):0;
    const watchHours=Math.round(totalWatchSecs/3600);

    // Requirements: 1K subs + 2K watch hours (like YouTube YPP)
    const reqs=[
      {label:`${MONET_REQS.subscribers.toLocaleString()} Subscribers`,cur:subs,req:MONET_REQS.subscribers,unit:''},
      {label:`${MONET_REQS.watchHours.toLocaleString()} Watch Hours`,cur:watchHours,req:MONET_REQS.watchHours,unit:'hrs'},
      {label:`${MONET_REQS.videos} Videos Uploaded`,cur:videos,req:MONET_REQS.videos,unit:''},
      {label:`5M Shorts Views (for Shorts bonus)`,cur:shortsTotalViews,req:MONET_REQS.shortsViews,unit:'',optional:true}
    ];
    const mainReqs=reqs.filter(r=>!r.optional);
    const allDone=mainReqs.every(r=>r.cur>=r.req);
    const reqList=document.getElementById('monetReqList');
    if(reqList){
      reqList.innerHTML=reqs.map(r=>{
        const done=r.cur>=r.req;
        const pct=Math.min(100,Math.round((r.cur/r.req)*100));
        const curFmt=r.cur>=1000000?(Math.round(r.cur/100000)/10)+'M':r.cur>=1000?Math.round(r.cur/100)/10+'K':r.cur;
        const reqFmt=r.req>=1000000?(Math.round(r.req/100000)/10)+'M':r.req>=1000?Math.round(r.req/100)/10+'K':r.req;
        return `<div style="margin-bottom:8px;">
          <div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px;">
            <span style="color:${done?'#00c864':'var(--text2)'};">${done?'✅':'🔒'} ${r.label}${r.optional?' <span style=\"font-size:9px;color:var(--text3);\">BONUS</span>':''}</span>
            <span style="color:var(--text3);">${curFmt}/${reqFmt}</span>
          </div>
          <div style="height:4px;background:var(--border);border-radius:2px;overflow:hidden;">
            <div style="height:100%;width:${pct}%;background:${done?'#00c864':r.optional?'#ff9600':'var(--red)'};border-radius:2px;transition:width .5s;"></div>
          </div>
        </div>`;
      }).join('');
    }
    const badge=document.getElementById('monetEligBadge');
    if(badge)badge.style.display=allDone?'flex':'none';

    // Earnings calc
    const monthViews=snap.docs.filter(d=>{
      const t=d.data().time||0;
      return Date.now()-t<30*24*3600*1000;
    }).reduce((a,d)=>a+(d.data().views||0),0);
    const monthEarn=Math.round(monthViews/1000*CPM_PKR);
    const totalEarn=Math.round(totalViews/1000*CPM_PKR);

    const mEl=document.getElementById('monetMonthEarn');
    const tEl=document.getElementById('monetTotalEarn');
    if(mEl)mEl.textContent='₨'+monthEarn.toLocaleString();
    if(tEl)tEl.textContent='₨'+totalEarn.toLocaleString();

    // Super Thanks from Firestore
    loadSuperThanksList();

    // Load saved payout info
    if(ud.exists){
      const u=ud.data();
      const pn=document.getElementById('payoutNumber');
      const pa=document.getElementById('payoutName');
      const ml=document.getElementById('merchLink');
      const md=document.getElementById('merchDesc');
      if(pn&&u.payoutNumber)pn.value=u.payoutNumber;
      if(pa&&u.payoutName)pa.value=u.payoutName;
      if(ml&&u.merchLink)ml.value=u.merchLink;
      if(md&&u.merchDesc)md.value=u.merchDesc;
      if(u.payoutMethod){
        _selectedPayoutMethod=u.payoutMethod;
        document.querySelectorAll('#payJazz,#payEasy,#payBank').forEach(b=>{if(b)b.classList.remove('active');});
        const payMethodMap={jazzcash:'payJazz',easypaisa:'payEasy',paytm:'payPaytm',paypal:'payPaypal',bank:'payBank'};
