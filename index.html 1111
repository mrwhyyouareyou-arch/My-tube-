async function postCommentFromSheet(){
  if(!cUser||!currentPostId)return;
  const input=document.getElementById('commInputSheet')||document.getElementById('commInput');
  const text=input.value.trim();if(!text)return;
  input.value='';
  const replyData = _videoReplyTo;
  clearVideoReply();
  try{
    const commentData = {
      text, authorId:cUser.uid, authorName:cUserData?.name||cUser.email,
      authorPhoto:cUserData?.photoURL||'', time:Date.now(),
      likes:0, likedBy:[],
      replyTo: replyData ? replyData.name : null,
      parentId: replyData ? replyData.commentId : null
    };
    if(replyData && replyData.commentId){
      await db.collection('posts').doc(currentPostId).collection('comments').doc(replyData.commentId).collection('replies').add(commentData);
      await db.collection('posts').doc(currentPostId).collection('comments').doc(replyData.commentId).update({
        replyCount: firebase.firestore.FieldValue.increment(1)
      });
      const parentSnap = await db.collection('posts').doc(currentPostId).collection('comments').doc(replyData.commentId).get();
      if(parentSnap.exists){
        const parentAuthorId = parentSnap.data().authorId;
        if(parentAuthorId && parentAuthorId !== cUser.uid){
          sendNotif(parentAuthorId,'reply',`${cUserData?.name||'Someone'} replied: "${text.substring(0,40)}"`,currentPostId,'video');
        }
      }
      const repliesDiv = document.getElementById('replies_'+replyData.commentId);
      if(repliesDiv && repliesDiv.style.display !== 'none'){
        loadReplies(currentPostId, replyData.commentId, repliesDiv);
      }
    } else {
      await db.collection('posts').doc(currentPostId).collection('comments').add(commentData);
      await db.collection('posts').doc(currentPostId).update({
        comments:firebase.firestore.FieldValue.increment(1),
        rankScore:firebase.firestore.FieldValue.increment(5)
      });
      sendNotif(currentPostData?.authorId,'comment',`${cUserData?.name||'Someone'} commented: "${text.substring(0,40)}"`,currentPostId,'video');
    }
    loadComments(currentPostId);
    updateCommPreview(currentPostId);
    showToast('Comment posted ✅');
  }catch(e){showToast('Error posting comment');}
}

