const BANNED_WORDS=['spam','fake','cheat','hack','nude','xxx','porn','sex','vulgar'];

function moderateContent(text){
  if(!text)return true;
  const lower=text.toLowerCase();
  return !BANNED_WORDS.some(w=>lower.includes(w));
}

async function submitReport(postId,reason,reportedUserId){
  if(!cUser)return showToast('Login karein to report karein');
  try{
    await db.collection('reports').add({
      postId,reason,
      reportedBy:cUser.uid,
      reportedUser:reportedUserId||'',
      time:Date.now(),
      status:'pending'
    });
    showToast('Report submitted. We will review within 24hrs ✅');
    // Auto-flag post if 5+ reports
    const rSnap=await db.collection('reports').where('postId','==',postId).where('status','==','pending').get();
    if(rSnap.size>=5){
      await db.collection('posts').doc(postId).update({flagged:true,flagReason:'Multiple user reports'});
      showToast('Content flagged for review');
    }
  }catch(e){showToast('Error submitting report');}
}

