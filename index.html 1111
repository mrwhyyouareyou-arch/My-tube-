function renderFeed(posts){
  const feed=document.getElementById('homeFeed');
  if(!posts||!posts.length){feed.innerHTML='<div class="empty-state"><i class="fas fa-video-slash"></i><p>No content yet!</p></div>';return;}
  const shorts=posts.filter(p=>p.type==='short');
  const postCards=posts.filter(p=>p.type==='post');
  const videos=posts.filter(p=>p.type!=='short'&&p.type!=='post');
  let html='';
  let shortsInserted=0;
  let postIdx=0;
  videos.forEach((p,i)=>{
    html+=buildCard(p);
    // Every 10 videos inject a shorts strip
    if((i+1)%10===0 && shorts.length>shortsInserted){
      const batch=shorts.slice(shortsInserted,shortsInserted+6);
      html+=buildInlineShortsRow(batch);
      shortsInserted+=batch.length;
    }
    // Every 5 videos inject a community post
    if((i+1)%5===0 && postIdx<postCards.length){
      html+=buildPostCard(postCards[postIdx]);
      postIdx++;
    }
  });
  // Remaining shorts
  if(shortsInserted<shorts.length){
    html+=buildInlineShortsRow(shorts.slice(shortsInserted,shortsInserted+8));
  }
  // Remaining posts at end
  while(postIdx<postCards.length){
    html+=buildPostCard(postCards[postIdx]);postIdx++;
  }
  if(!html)html=posts.map(p=>buildCard(p)).join('');
  feed.innerHTML=html;
}

