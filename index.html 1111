function addToHistory(post){
  if(!post||!post.id)return;
  let history=JSON.parse(localStorage.getItem('mt_history')||'[]');
  history=history.filter(h=>h.id!==post.id);
  history.unshift({id:post.id,title:post.title,thumbURL:post.thumbURL,url:post.url,type:post.type,authorName:post.authorName,time:Date.now()});
  history=history.slice(0,50);
  localStorage.setItem('mt_history',JSON.stringify(history));
}

