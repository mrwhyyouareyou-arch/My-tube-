        const pppl=document.getElementById('playerProdPlatform');if(pppl)pppl.querySelector('span').textContent=p.productPlatform||'Online Store';
      }else{
        ppCard.style.display='none';
      }
    }
  }catch(e){console.error(e);showToast('Error loading');}
}

