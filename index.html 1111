function openShortFS(idx){
  sfCurrentIdx=idx;
  const fs=document.getElementById('shortFS');
  fs.classList.add('open');
  // Build all slides
  const wrap=document.getElementById('sfWrap');
  wrap.innerHTML='';
  sfPosts.forEach((p,i)=>{
    const slide=document.createElement('div');
    slide.className='sf-slide';
    slide.dataset.idx=i;
    const vid=document.createElement('video');
    vid.playsinline=true;
    vid.setAttribute('playsinline','');
    vid.dataset.src=p.url||'';
    vid.onclick=function(e){handleSfTap(e);};
    slide.appendChild(vid);
    wrap.appendChild(slide);
  });
  // Scroll snap observer
  const observer=new IntersectionObserver(entries=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        const i=parseInt(entry.target.dataset.idx);
        // Pause all others
        wrap.querySelectorAll('video').forEach((v,vi)=>{if(vi!==i){v.pause();}});
        // Play this one
        const vid=entry.target.querySelector('video');
        if(vid&&!vid.src&&vid.dataset.src){vid.src=vid.dataset.src;}
        if(vid)vid.play().catch(()=>{});
        if(i!==sfCurrentIdx)playShortAt(i);
      }
    });
  },{root:wrap,threshold:0.6});
  wrap.querySelectorAll('.sf-slide').forEach(s=>observer.observe(s));
  // Scroll to current idx
  setTimeout(()=>{
    const slides=wrap.querySelectorAll('.sf-slide');
    if(slides[idx])slides[idx].scrollIntoView({behavior:'instant'});
    playShortAt(idx);
  },80);
}

function playShortAt(idx){
  if(idx<0||idx>=sfPosts.length)return;
  sfCurrentIdx=idx;
  sfCurrentId=sfPosts[idx].id;
  const p=sfPosts[idx];
  // Load video in slide
  const wrap=document.getElementById('sfWrap');
  const slides=wrap.querySelectorAll('.sf-slide');
  const slide=slides[idx];
  if(slide){
    let vid=slide.querySelector('video');
    if(!vid){vid=document.createElement('video');vid.playsinline=true;vid.setAttribute('playsinline','');vid.onclick=function(e){handleSfTap(e);};slide.appendChild(vid);}
    if(!vid.src&&p.url){vid.src=p.url;}
    vid.onended=function(){if(sfCurrentIdx<sfPosts.length-1){const next=slides[sfCurrentIdx+1];if(next)next.scrollIntoView({behavior:'smooth'});}else{vid.currentTime=0;vid.play().catch(()=>{});}};
    vid.play().catch(()=>{});
    // Real-time progress bar
    const pf=document.getElementById('sfProgFill');
    if(pf){pf.style.width='0%';}
    vid.ontimeupdate=function(){if(vid.duration&&pf){pf.style.width=((vid.currentTime/vid.duration)*100)+'%';}};
  }
  document.getElementById('sfTtl').textContent=p.title||'';
  document.getElementById('sfCh').textContent=p.authorName||'';
  // Avatars
