async function loadDashboard(){
  if(!cUser)return;
  document.getElementById('dashWelcome').textContent='Welcome, '+(cUserData?.name||'Creator')+'!';
  const stAv=document.getElementById('studioAvatar');
  if(stAv){if(cUserData?.photoURL)stAv.innerHTML=`<img src="${cUserData.photoURL}" style="width:100%;height:100%;object-fit:cover;">`;else stAv.textContent=(cUserData?.name||'U')[0].toUpperCase();}
  const stCh=document.getElementById('studioChannelName');
  if(stCh)stCh.textContent=cUserData?.channelName||cUserData?.name||'My Channel';
  try{
    const snap=await db.collection('posts').where('authorId','==',cUser.uid).get();
    let likes=0,views=0,vids=0,comments=0,maxLikes=0,bestTitle='';
    const myPosts=[];
    let watchTimeSecs=0;
    const now=Date.now();
    const periodMs=_dashPeriodDays>0?_dashPeriodDays*24*3600*1000:Infinity;
    snap.forEach(d=>{
      const p={id:d.id,...d.data()};
      myPosts.push(p);
      const inPeriod=_dashPeriodDays===0||(now-(p.time||0))<periodMs;
      if(inPeriod){
        likes+=p.likes||0;
        views+=p.views||0;
        comments+=p.comments||0;
        watchTimeSecs+=p.watchTime||0;
        vids++;
      }
      if((p.likes||0)>maxLikes){maxLikes=p.likes||0;bestTitle=p.title||'N/A';}
    });
    myPosts.sort((a,b)=>b.time-a.time);
    const ud=await db.collection('users').doc(cUser.uid).get();
    const subs=ud.exists?(ud.data().subscribers||0):0;

    // Update counts
    document.getElementById('dSubs').textContent=subs>=1000?(subs/1000).toFixed(1)+'K':subs;
    // Subs goal bar
    const subsBar=document.getElementById('subsGoalBar');
    if(subsBar)subsBar.style.width=Math.min(100,Math.round(subs/1000*100))+'%';
    // Shorts views
    let shortsTotalViews=0;
    snap.forEach(d=>{const p=d.data();if(p.type==='short')shortsTotalViews+=p.views||0;});
    const svEl=document.getElementById('dShortsViews');
    if(svEl)svEl.textContent=shortsTotalViews>=1000000?(shortsTotalViews/1000000).toFixed(2)+'M':shortsTotalViews>=1000?Math.round(shortsTotalViews/1000)+'K':shortsTotalViews;
    const sBar=document.getElementById('shortsGoalBar');
    if(sBar)sBar.style.width=Math.min(100,Math.round(shortsTotalViews/5000000*100))+'%';
    const shortsApplyBtn=document.getElementById('shortsApplyBtn');
    if(shortsApplyBtn)shortsApplyBtn.style.display=shortsTotalViews>=5000000?'block':'none';
    document.getElementById('dViews').textContent=views>=1000?Math.round(views/100)/10+'K':views;
    const watchMins=Math.round(watchTimeSecs/60);
    const wtEl=document.getElementById('dWatchTime');
    const watchHrs=watchMins/60;
    if(wtEl)wtEl.textContent=watchHrs>=1?watchHrs.toFixed(1)+'h':watchMins+'m';
    const wtBar=document.getElementById('watchTimeBar');
    if(wtBar)wtBar.style.width=Math.min(100,Math.round(watchHrs/2000*100))+'%';
    const revEl=document.getElementById('dRevenue');if(revEl)revEl.textContent='₨'+(Math.round(views*0.5/1000*100)/100).toFixed(2);
    const impEl=document.getElementById('dImpressions');if(impEl)impEl.textContent=views>=1000?Math.round((views+likes*3)/100)/10+'K':views+likes*3;
    const vcountEl=document.getElementById('dVideoCount');if(vcountEl)vcountEl.textContent=myPosts.length;

    // Trend arrows — compare first half vs second half of period posts
    const half=Math.floor(myPosts.length/2);
    const recentViews=myPosts.slice(0,half).reduce((a,p)=>a+(p.views||0),0);
    const olderViews=myPosts.slice(half).reduce((a,p)=>a+(p.views||0),0);
    const viewsUp=recentViews>=olderViews;
    const viewsDiff=olderViews>0?Math.round(Math.abs(recentViews-olderViews)/olderViews*100):0;
    const trendEl=document.getElementById('dViewsTrend');
    if(trendEl)trendEl.innerHTML=`<span style="color:${viewsUp?'#00c864':'#ff4444'};font-weight:700;">${viewsUp?'↑':'↓'} ${viewsDiff}%</span> <span style="color:var(--text3);">vs prev period</span>`;
    const subTrendEl=document.getElementById('dSubsTrend');
    if(subTrendEl)subTrendEl.innerHTML=`<span style="color:${subs>0?'#00c864':'var(--text3)'};font-weight:700;">${subs>0?'↑':''} ${subs} total</span>`;
    const wtTrendEl=document.getElementById('dWatchTrend');
    if(wtTrendEl)wtTrendEl.innerHTML=`<span style="color:var(--text2);">${watchMins} min total</span>`;

    // Profile stats
    document.getElementById('profVideos') && (document.getElementById('profVideos').textContent=myPosts.length);
    document.getElementById('profSubs') && (document.getElementById('profSubs').textContent=subs);
    document.getElementById('profLikes') && (document.getElementById('profLikes').textContent=myPosts.reduce((a,p)=>a+(p.likes||0),0));

    // Analytics
    const totalViews=myPosts.reduce((a,p)=>a+(p.views||0),0);
    const totalLikes=myPosts.reduce((a,p)=>a+(p.likes||0),0);
    const ctr=myPosts.length>0?Math.min(100,Math.round((totalLikes/Math.max(totalViews,1))*100)):0;
    const avgV=myPosts.length>0?Math.round(totalViews/myPosts.length):0;
    const eng=myPosts.length>0?Math.min(100,Math.round(((totalLikes+comments)/Math.max(totalViews,1))*100)):0;
    const totalScore=myPosts.reduce((a,p)=>a+(p.rankScore||0),0);
    const growth=subs>0?Math.round((totalLikes/Math.max(subs,1))*100):0;
    document.getElementById('aCTR').textContent=ctr+'%';
    document.getElementById('aAvgViews').textContent=avgV;
    document.getElementById('aEngagement').textContent=eng+'%';
    document.getElementById('aScore').textContent=totalScore;
    document.getElementById('aBest').textContent=bestTitle.substring(0,8)||'-';
    document.getElementById('aGrowth').textContent=growth+'%';
    // CTR bar
    const ctrBar=document.getElementById('dashCTRBar');if(ctrBar)ctrBar.style.width=ctr+'%';
    document.getElementById('dashTotalViews') && (document.getElementById('dashTotalViews').textContent='Total: '+totalViews);

    // SVG Line Chart — views per post
    const last7=myPosts.slice(0,7).reverse();
    const svgEl=document.getElementById('dashLineChart');
    const vlEl=document.getElementById('dashViewsLabels');
    if(svgEl&&last7.length){
      const W=svgEl.getBoundingClientRect().width||300;
      const H=90;
      const maxV=Math.max(...last7.map(p=>p.views||0),1);
      const pts=last7.map((p,i)=>{
        const x=last7.length>1?i*(W/(last7.length-1)):W/2;
        const y=H-Math.max(8,Math.round(((p.views||0)/maxV)*(H-10)));
        return {x,y,views:p.views||0,title:p.title||'',id:p.id};
      });
      const pathD=pts.map((p,i)=>(i===0?`M ${p.x},${p.y}`:`L ${p.x},${p.y}`)).join(' ');
      // Area fill
      const areaD=pathD+` L ${pts[pts.length-1].x},${H} L ${pts[0].x},${H} Z`;
      svgEl.innerHTML=`
        <defs>
          <linearGradient id="lgr" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--red)" stop-opacity="0.35"/>
            <stop offset="100%" stop-color="var(--red)" stop-opacity="0.03"/>
          </linearGradient>
        </defs>
        <path d="${areaD}" fill="url(#lgr)" />
        <path d="${pathD}" fill="none" stroke="var(--red)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        ${pts.map(p=>`<circle cx="${p.x}" cy="${p.y}" r="5" fill="var(--red)" stroke="var(--bg)" stroke-width="2" style="cursor:pointer;" onclick="openPost('${p.id}')"><title>${p.title}: ${p.views} views</title></circle>`).join('')}
        ${pts.map(p=>`<text x="${p.x}" y="${p.y-10}" text-anchor="middle" font-size="9" fill="var(--text2)">${p.views>=1000?Math.round(p.views/100)/10+'K':p.views}</text>`).join('')}
      `;
      if(vlEl)vlEl.innerHTML=last7.map(p=>`<div style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:center;">${(p.title||'').substring(0,6)||'—'}</div>`).join('');
    }

    // Impressions mini chart
    const icEl=document.getElementById('dashImpressionsChart');
    if(icEl&&myPosts.length){
      const l7=myPosts.slice(0,7);
      const maxI=Math.max(...l7.map(p=>(p.views||0)+(p.likes||0)*5),1);
      icEl.innerHTML=l7.map((p,i)=>{
        const val=(p.views||0)+(p.likes||0)*5;
        const pct=Math.max(8,Math.round((val/maxI)*100));
        return `<div style="flex:1;background:linear-gradient(to top,#0096ff,#00c8ff);height:${pct}%;border-radius:3px 3px 0 0;min-height:4px;opacity:${0.5+i*0.07};"></div>`;
      }).join('');
    }

    // Latest video performance
    const lpEl=document.getElementById('latestVideoPerfEl');
    if(lpEl&&myPosts.length){
      const latest=myPosts[0];
      const th=latest.thumbURL||(latest.url?latest.url.replace('/upload/','/upload/so_1,w_120/').replace(/\.(mp4|mov|webm)$/,'.jpg'):'');
      const typical_views=Math.max(1,Math.round(totalViews/Math.max(myPosts.length,1)));
      const isAbove=(latest.views||0)>=typical_views;
      const perfPct=typical_views>0?Math.min(200,Math.round(((latest.views||0)/typical_views)*100)):0;
      lpEl.innerHTML=`
        <div style="display:flex;gap:10px;margin-bottom:12px;">
          <div style="width:80px;height:50px;border-radius:7px;overflow:hidden;background:var(--bg3);flex-shrink:0;">${th?`<img src="${th}" style="width:100%;height:100%;object-fit:cover;">`:'<div style="height:100%;display:flex;align-items:center;justify-content:center;"><i class="fas fa-play" style="color:var(--text3);"></i></div>'}</div>
          <div style="flex:1;">
            <div style="font-size:12px;font-weight:700;">${latest.title||'Untitled'}</div>
            <div style="font-size:10px;color:var(--text2);margin-top:2px;">${getTimeAgo(latest.time)}</div>
            <div style="font-size:10px;font-weight:600;margin-top:4px;color:${isAbove?'#00c864':'#ff4444'};">${isAbove?'↑ Above':'↓ Below'} average (${perfPct}%)</div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;">
          ${[['👁️','Views',latest.views||0],['❤️','Likes',latest.likes||0],['💬','Comments',latest.comments||0]].map(([icon,lbl,val])=>`
            <div style="text-align:center;padding:8px;background:var(--bg3);border-radius:8px;">
              <div style="font-size:16px;font-weight:800;">${val}</div>
              <div style="font-size:10px;color:var(--text3);">${icon} ${lbl}</div>
            </div>`).join('')}
        </div>
        <!-- Performance bar -->
        <div style="margin-top:10px;">
          <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--text3);margin-bottom:4px;"><span>Performance vs channel avg</span><span>${perfPct}%</span></div>
          <div style="height:6px;background:var(--bg3);border-radius:3px;overflow:hidden;">
            <div style="height:100%;width:${Math.min(100,perfPct)}%;background:${isAbove?'#00c864':'var(--red)'};border-radius:3px;transition:width .5s;"></div>
          </div>
        </div>`;
    }

    // Subscriber milestones
    const stEl=document.getElementById('dashSubsTrend');
    if(stEl){
      const milestones=[10,50,100,500,1000,5000,10000,100000];
      const next=milestones.find(m=>m>subs)||null;
      const prev=milestones.filter(m=>m<=subs).pop()||0;
      if(next){
        const pct=Math.min(100,Math.round(((subs-prev)/Math.max(next-prev,1))*100));
        stEl.innerHTML=`
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
            <div style="font-size:22px;font-weight:800;">${subs}</div>
            <div style="font-size:11px;color:var(--text2);">subscribers<br>next goal: <b style="color:var(--text);">${next}</b></div>
          </div>
          <div style="background:var(--bg3);border-radius:6px;height:8px;overflow:hidden;margin-bottom:4px;">
            <div style="background:linear-gradient(90deg,var(--red),#ff6644);height:100%;width:${pct}%;border-radius:6px;transition:width .5s;"></div>
          </div>
          <div style="font-size:11px;color:var(--text3);">${subs}/${next} (${pct}%)</div>`;
      }else{
        stEl.innerHTML=`<div style="color:#ffd700;font-size:14px;font-weight:700;">🏆 Legend! ${subs}+ subs</div>`;
      }
    }

    // My content list
    const cl=document.getElementById('myContentList');
    if(cl){
      if(!myPosts.length){cl.innerHTML='<div class="empty-state"><i class="fas fa-upload"></i><p>No content yet!</p></div>';}
      else{cl.innerHTML=myPosts.map(p=>{
        const th=p.thumbURL||(p.url?p.url.replace('/upload/','/upload/so_1,w_200/').replace(/\.(mp4|mov|webm)$/,'.jpg'):'');
        const avgForThis=myPosts.length>0?totalViews/myPosts.length:0;
        const isGood=(p.views||0)>=avgForThis;
        return `<div class="my-vid-item">
          <div class="my-vid-thumb">${th?`<img src="${th}">`:'<i class="fas fa-video" style="color:var(--text3);font-size:18px;"></i>'}</div>
          <div class="my-vid-info">
