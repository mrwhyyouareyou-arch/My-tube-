/* CHANNEL PAGE */
.channel-page{position:fixed;inset:0;z-index:200;background:var(--bg);display:none;flex-direction:column;overflow-y:auto;}
.channel-page.open{display:flex;}
.channel-cover{height:130px;background:linear-gradient(135deg,#1a0000,#4a0000,#2a0000);position:relative;flex-shrink:0;}
.channel-back{position:absolute;top:12px;left:12px;background:rgba(0,0,0,.5);border:none;color:white;border-radius:50%;width:36px;height:36px;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.channel-info{padding:0 14px;display:flex;flex-direction:column;align-items:center;text-align:center;margin-top:-36px;padding-bottom:16px;}
.channel-pic{width:78px;height:78px;border-radius:50%;background:var(--red);border:3px solid var(--bg);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:800;color:white;overflow:hidden;margin-bottom:10px;}
.channel-pic img{width:100%;height:100%;object-fit:cover;}
.channel-name{font-size:20px;font-weight:800;}
.channel-handle-el{font-size:13px;color:var(--text2);margin-top:2px;}
.channel-sub-count{font-size:13px;color:var(--text2);margin-top:4px;}
.channel-sub-wrap{display:flex;gap:8px;margin-top:14px;}
.channel-sub-btn{padding:9px 24px;background:var(--text);color:var(--bg);border:none;border-radius:20px;font-size:14px;font-weight:700;cursor:pointer;}
.channel-sub-btn.subscribed{background:var(--bg3);color:var(--text);border:1px solid var(--border);}
.channel-tabs{display:flex;border-bottom:2px solid var(--border);padding:0 14px;}
.channel-tab{flex:1;padding:10px;background:none;border:none;border-bottom:2px solid transparent;color:var(--text2);cursor:pointer;font-size:13px;font-weight:500;margin-bottom:-2px;}
.channel-tab.active{color:var(--red);border-bottom-color:var(--red);}
.channel-content{padding:12px 14px;}

/* VIDEO CONTEXT MENU */
.ctx-menu-overlay{position:fixed;inset:0;z-index:350;background:rgba(0,0,0,.4);display:none;}
.ctx-menu-overlay.open{display:block;}
.ctx-menu{position:fixed;bottom:0;left:0;right:0;z-index:351;background:var(--bg2);border-radius:20px 20px 0 0;padding:16px 0 20px;transform:translateY(100%);transition:transform .3s ease;}
.ctx-menu.open{transform:translateY(0);}
.ctx-menu-title{padding:0 16px 12px;font-size:13px;font-weight:700;color:var(--text2);border-bottom:1px solid var(--border);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.ctx-item{display:flex;align-items:center;gap:14px;padding:13px 18px;cursor:pointer;transition:background .15s;}
.ctx-item:active{background:var(--bg3);}
.ctx-item i{font-size:18px;width:22px;text-align:center;color:var(--text2);}
.ctx-item span{font-size:14px;color:var(--text);}
.ctx-item.danger i,.ctx-item.danger span{color:#ff4444;}

/* REPORT MODAL */
.report-modal{position:fixed;inset:0;z-index:400;background:rgba(0,0,0,.6);display:none;align-items:flex-end;}
.report-modal.open{display:flex;}
.report-sheet{width:100%;background:var(--bg2);border-radius:20px 20px 0 0;padding:20px 16px;}
.report-option{display:flex;align-items:center;gap:12px;padding:12px 0;cursor:pointer;border-bottom:1px solid var(--border);}
.report-option input[type="radio"]{accent-color:var(--red);width:18px;height:18px;}
.report-option label{font-size:14px;cursor:pointer;}

/* SIDE MENU */
.side-menu-overlay{position:fixed;inset:0;z-index:400;background:rgba(0,0,0,.5);display:none;}
.side-menu-overlay.open{display:block;}
.side-menu{position:fixed;left:0;top:0;bottom:0;z-index:401;width:75%;max-width:280px;background:var(--bg2);transform:translateX(-100%);transition:transform .3s ease;overflow-y:auto;display:flex;flex-direction:column;}
.side-menu.open{transform:translateX(0);}
.side-menu-header{padding:20px 16px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.side-menu-header svg{flex-shrink:0;}
.side-menu-header span{font-size:18px;font-weight:800;}
.side-menu-header span b{color:var(--red);}
.side-item{display:flex;align-items:center;gap:14px;padding:13px 16px;cursor:pointer;transition:background .2s;border-radius:0;color:var(--text);}
.side-item:active,.side-item:hover{background:var(--bg3);}
.side-item i{font-size:18px;width:24px;text-align:center;color:var(--text2);}
.side-item span{font-size:14px;font-weight:500;}
.side-section-title{font-size:11px;font-weight:700;color:var(--text3);padding:12px 16px 4px;text-transform:uppercase;letter-spacing:.5px;}
.side-divider{height:1px;background:var(--border);margin:8px 0;}
.side-footer{padding:16px;margin-top:auto;}
.side-footer p{font-size:11px;color:var(--text3);line-height:1.6;}



/* STUDIO TABS */
.studio-tab{flex-shrink:0;padding:10px 14px;background:none;border:none;border-bottom:2px solid transparent;color:var(--text2);cursor:pointer;font-size:12px;font-weight:500;white-space:nowrap;transition:all .2s;display:flex;align-items:center;gap:5px;margin-bottom:-2px;}
.studio-tab.active{color:var(--red);border-bottom-color:var(--red);}
.studio-tab i{font-size:13px;}

/* TRIM PANEL */
.trim-panel{position:fixed;bottom:0;left:0;right:0;z-index:250;background:var(--bg2);border-radius:20px 20px 0 0;padding:20px 16px;transform:translateY(100%);transition:transform .3s ease;}
.trim-panel.open{transform:translateY(0);}
.trim-handle{width:34px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 16px;}
.trim-title{font-size:16px;font-weight:700;margin-bottom:14px;}
.trim-range-wrap{margin-bottom:16px;}
.trim-range-label{font-size:12px;color:var(--text2);margin-bottom:6px;display:flex;justify-content:space-between;}
.trim-range{width:100%;-webkit-appearance:none;height:4px;border-radius:2px;background:var(--border);outline:none;}
.trim-range::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--red);cursor:pointer;}
.trim-preview{background:var(--bg3);border-radius:10px;padding:12px;margin-bottom:14px;display:flex;align-items:center;gap:10px;}
.trim-preview i{color:var(--red);font-size:20px;}

/* Music selector scroll */
#trendingSongsList::-webkit-scrollbar{display:none;}
#trendingSongsList{-webkit-overflow-scrolling:touch;}
/* Shorts scroll on home feed */
.shorts-inline::-webkit-scrollbar{display:none;}
/* Video player bottom sheet feel */
.player-screen{-webkit-overflow-scrolling:touch;}
/* Post subscribe button */
.post-act.liked i.fa-user-check{color:var(--red);}
/* Smooth chip scroll */
.chips-wrap{-webkit-overflow-scrolling:touch;}

/* Double tap heart animation */
.heart-anim{position:fixed;pointer-events:none;z-index:9999;font-size:80px;animation:heartPop .8s ease forwards;}
@keyframes heartPop{0%{transform:scale(0) translate(-50%,-50%);opacity:1}50%{transform:scale(1.4) translate(-50%,-50%);opacity:1}100%{transform:scale(1.2) translate(-50%,-50%);opacity:0}}

.toast{position:fixed;bottom:76px;left:50%;transform:translateX(-50%);background:#333;color:white;padding:9px 18px;border-radius:20px;font-size:13px;font-weight:500;z-index:999;opacity:0;transition:opacity .3s;white-space:nowrap;pointer-events:none;}
.toast.show{opacity:1;}
