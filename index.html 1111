async function loadNotifs(){
  if(!cUser)return;
  const list=document.getElementById('notifList');
  list.innerHTML='<div class="loader"><div class="spinner"></div></div>';
  try{
    const snap=await db.collection('notifications').where('to','==',cUser.uid).limit(40).get();
    const docs=snap.docs.sort((a,b)=>b.data().time-a.data().time);
    if(!docs.length){list.innerHTML='<div class="empty-state"><i class="fas fa-bell-slash"></i><p>No notifications yet</p></div>';setNotifBadge(0);return;}
    const unread=docs.filter(d=>!d.data().read).length;
    setNotifBadge(unread);
    list.innerHTML=docs.map(d=>{
      const n=d.data();
      const emoMap={like:'❤️',comment:'💬',sub:'🔔',system:'📢',reply:'↩️'};
      const icClass={like:'like',comment:'comment',sub:'sub',system:'system',reply:'comment'}[n.type]||'system';
      const avHtml=n.fromPhoto?`<img src="${n.fromPhoto}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`:(emoMap[n.type]||'📢');
      const clickable=n.postId?`onclick="handleNotifClick('${n.postId}','${n.postType||''}')"  style="cursor:pointer;"`:'' ;
      return `<div class="notif-item ${n.read?'':'unread'}" ${clickable}>
        <div class="notif-ic ${icClass}" style="overflow:hidden;">${avHtml}</div>
        <div class="notif-body">
          <div class="notif-text">${n.text}</div>
          <div class="notif-time">${getTimeAgo(n.time)}</div>
          ${n.postId?`<div style="font-size:10px;color:var(--red);margin-top:2px;"><i class="fas fa-external-link-alt"></i> Tap to open</div>`:''}
        </div></div>`;
    }).join('');
    docs.forEach(d=>{if(!d.data().read)db.collection('notifications').doc(d.id).update({read:true}).catch(()=>{});});
    setNotifBadge(0);
  }catch(e){list.innerHTML='<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>Could not load notifications</p></div>';}
}

