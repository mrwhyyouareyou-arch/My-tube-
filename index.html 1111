function addTextOverlay(){
  const input=document.getElementById('scTextInput');
  const size=document.getElementById('scTextSize')?.value||'22px';
  const text=input?.value?.trim();
  if(!text)return showToast('Enter text first');
  const container=document.getElementById('scTextOverlays');
  if(!container)return;
  const el=document.createElement('div');
  el.style.cssText='position:absolute;top:35%;left:50%;transform:translate(-50%,-50%);color:'+scTextColor+';font-size:'+size+';font-weight:800;text-shadow:0 2px 8px rgba(0,0,0,.9);pointer-events:all;cursor:move;user-select:none;text-align:center;padding:6px 10px;';
  el.textContent=text;
  let sx,sy,ox,oy,drag=false;
  el.addEventListener('touchstart',e=>{
    drag=true;sx=e.touches[0].clientX;sy=e.touches[0].clientY;
    const r=el.getBoundingClientRect();ox=r.left+r.width/2;oy=r.top+r.height/2;
    e.preventDefault();
  },{passive:false});
  el.addEventListener('touchmove',e=>{
    if(!drag)return;
    ox+=e.touches[0].clientX-sx;oy+=e.touches[0].clientY-sy;
    sx=e.touches[0].clientX;sy=e.touches[0].clientY;
    el.style.left=ox+'px';el.style.top=oy+'px';el.style.transform='translate(-50%,-50%)';
    e.preventDefault();
  },{passive:false});
  el.addEventListener('dblclick',()=>el.remove());
  container.appendChild(el);
  if(input)input.value='';
  closeAllEditPanels();
  showToast('Text added! Drag to move. Double-tap to remove.');
}

