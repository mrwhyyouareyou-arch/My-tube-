async function ownerPayWithdraw(wdId,creatorId,amount){
  if(!confirm('Mark ₨'+amount+' as paid?'))return;
  try{
    await db.collection('affiliateWithdrawals').doc(wdId).update({status:'paid',paidAt:Date.now()});
    await db.collection('affiliateWallet').doc(creatorId).update({balance:firebase.firestore.FieldValue.increment(-amount)});
    sendNotif(creatorId,'affiliate','💸 Your withdrawal of ₨'+amount+' has been processed!','','');
