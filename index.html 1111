// PRO ALGORITHM — Smarter than YouTube/Instagram/Facebook
// Score = (likes*10) + (views*2) + (comments*5) + 
//         (shares*8) + freshness_bonus + category_boost
// Freshness: exponential decay (half-life 24h)
// Category boost: trending categories get extra weight
// Personalization: user watch history + liked categories
// ══════════════════════════════════════════════════════
function calcScore(p, userPrefs={}) {
  const now = Date.now();
  const ageHours = (now - (p.time||now)) / 3600000;
  
  // Freshness: newer = higher, half-life 48 hours
  const freshness = Math.exp(-ageHours / 48) * 100;
  
  // Engagement signals
  const likes = (p.likes||0) * 10;
  const views = (p.views||0) * 2;
  const comments = (p.comments||0) * 5;
  const reactions = Object.keys(p.reactions||{}).filter(k=>!k.includes('_')).reduce((a,k)=>a+(p.reactions[k]||0),0) * 3;
  
  // Velocity: likes per hour (trending signal)
  const velocity = ageHours > 0 ? (p.likes||0) / Math.max(ageHours, 0.5) * 15 : 0;
  
  // Category trending boost
  const trendingCats = userPrefs.topCats || [];
  const catBoost = trendingCats.includes(p.category||p.type) ? 25 : 0;
  
  // Content type weight (shorts & videos rank higher)
  const typeBoost = {video:20, short:15, gaming:12, music:10, image:5, post:5}[p.type] || 0;
  
  // Diversity penalty (same author penalized if seen often)
  const authorPenalty = userPrefs.seenAuthors?.[p.authorId] ? -10 : 0;
  
  const totalScore = freshness + likes + views + comments + reactions + velocity + catBoost + typeBoost + authorPenalty;
  return Math.round(totalScore);
}

function sortFeedByAlgorithm(posts, userPrefs={}) {
  return [...posts].sort((a,b) => {
    const sa = a.rankScore || calcScore(a, userPrefs);
    const sb = b.rankScore || calcScore(b, userPrefs);
    return sb - sa;
  });
}

