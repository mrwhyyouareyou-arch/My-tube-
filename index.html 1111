let _cpCurrentTab = 'videos';

async function loadChannelVideos(authorId,typeFilter='videos'){
  const el=document.getElementById('cpContent');
  el.innerHTML='<div class="loader"><div class="spinner"></div></div>';
  _cpCurrentTab = typeFilter;
  // show/hide sort bar
  const sortBar = document.getElementById('cpSortBar');
  if(sortBar) sortBar.style.display = (typeFilter==='about'||typeFilter==='posts') ? 'none' : 'flex';
  try{
    let snap;
    try{ snap=await db.collection('posts').where('authorId','==',authorId).orderBy('time','desc').limit(50).get(); }
    catch(e){ snap=await db.collection('posts').where('authorId','==',authorId).limit(50).get(); }
    let posts=snap.docs.map(d=>({id:d.id,...d.data()}));
    if(typeFilter==='shorts') posts=posts.filter(p=>p.type==='short');
    else if(typeFilter==='posts') posts=posts.filter(p=>p.type==='post');
    else if(typeFilter==='popular') posts=posts.sort((a,b)=>(b.views||0)-(a.views||0));
    else posts=posts.filter(p=>p.type!=='post'&&p.type!=='short');
    // Sort
    if(typeFilter!=='popular'){
      if(_cpCurrentSort==='oldest') posts=posts.sort((a,b)=>(a.time||0)-(b.time||0));
      else if(_cpCurrentSort==='popular') posts=posts.sort((a,b)=>(b.views||0)-(a.views||0));
      else posts=posts.sort((a,b)=>(b.time||0)-(a.time||0));
    }
    if(!posts.length){el.innerHTML='<div class="empty-state"><i class="fas fa-video-slash"></i><p>No content yet</p></div>';return;}
    const isShorts = typeFilter==='shorts';
    if(isShorts){
      el.innerHTML='<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;">'+posts.map(p=>{
        const th=p.thumbURL||(p.url?p.url.replace('/upload/','/upload/so_1,w_200/').replace(/\.(mp4|mov|webm)$/,'.jpg'):'');
        return `<div onclick="openPost('${p.id}')" style="cursor:pointer;aspect-ratio:9/16;border-radius:6px;overflow:hidden;background:var(--bg3);position:relative;">
          ${th?`<img src="${th}" style="width:100%;height:100%;object-fit:cover;">`:'<div style="height:100%;display:flex;align-items:center;justify-content:center;"><i class="fas fa-film" style="color:var(--text3);font-size:16px;"></i></div>'}
          <div style="position:absolute;bottom:0;left:0;right:0;padding:4px;background:linear-gradient(transparent,rgba(0,0,0,.8));"><div style="font-size:9px;color:white;font-weight:600;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${p.title||''}</div></div>
        </div>`;
      }).join('')+'</div>';
    } else {
      el.innerHTML='<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">'+posts.map(p=>{
        const th=p.thumbURL||(p.url?p.url.replace('/upload/','/upload/so_1,w_300/').replace(/\.(mp4|mov|webm)$/,'.jpg'):'');
        const views=p.views>=1000?(p.views/1000).toFixed(1)+'K':(p.views||0);
        return `<div onclick="openPost('${p.id}')" style="cursor:pointer;">
          <div style="aspect-ratio:16/9;border-radius:8px;overflow:hidden;background:var(--bg3);margin-bottom:5px;position:relative;">
            ${th?`<img src="${th}" style="width:100%;height:100%;object-fit:cover;">`:'<div style="height:100%;display:flex;align-items:center;justify-content:center;"><i class="fas fa-play-circle" style="color:var(--text3);font-size:22px;"></i></div>'}
            ${p.duration?`<div style="position:absolute;bottom:4px;right:4px;background:rgba(0,0,0,.85);color:white;font-size:9px;font-weight:600;padding:1px 4px;border-radius:3px;">${p.duration}</div>`:''}
          </div>
          <div style="font-size:11px;font-weight:600;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.4;">${p.title||'Untitled'}</div>
          <div style="font-size:10px;color:var(--text2);margin-top:2px;">👁️${views} • ${getTimeAgo(p.time)}</div>
        </div>`;
      }).join('')+'</div>';
    }
  }catch(e2){
    try{
      const s2=await db.collection('posts').where('authorId','==',authorId).limit(20).get();
      const posts2=s2.docs.map(d=>({id:d.id,...d.data()})).sort((a,b)=>b.time-a.time);
      el.innerHTML=posts2.length?'<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">'+posts2.map(p=>`<div onclick="openPost('${p.id}')" style="cursor:pointer;"><div style="aspect-ratio:16/9;border-radius:8px;background:var(--bg3);margin-bottom:5px;overflow:hidden;"></div><div style="font-size:11px;font-weight:600;">${p.title||'Untitled'}</div></div>`).join('')+'</div>':'<div class="empty-state"><i class="fas fa-video-slash"></i><p>No content</p></div>';
    }catch(e3){el.innerHTML='<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>Error loading</p></div>';}
  }
}

