    </div>`;
  ov.onclick=()=>{sheet.remove();ov.remove();};
  document.body.appendChild(sheet);
  // Load comments
  pdLoadComments(p.id);
  // Track view
  trackUniqueView(p.id);
}

async function pdLike(postId,btn){
  if(!cUser)return showToast('Login karein!');
  try{
    const ref=db.collection('posts').doc(postId);
    const doc=await ref.get();if(!doc.exists)return;const p=doc.data();
    const liked=(p.likedBy||[]).includes(cUser.uid);
    if(liked){
      await ref.update({likes:firebase.firestore.FieldValue.increment(-1),likedBy:firebase.firestore.FieldValue.arrayRemove(cUser.uid)});
      if(btn){btn.style.color='var(--text2)';}
      showToast('Like removed');
    }else{
      await ref.update({likes:firebase.firestore.FieldValue.increment(1),likedBy:firebase.firestore.FieldValue.arrayUnion(cUser.uid),rankScore:firebase.firestore.FieldValue.increment(10)});
      if(btn){btn.style.color='var(--red)';}
      showToast('Liked! ❤️');
      sendNotif(p.authorId,'like',`${cUserData?.name||'Someone'} liked your post "${p.title||''}"`,postId,'post');
    }
  }catch(e){showToast('Error');}
}

async function pdPostComment(postId){
  if(!cUser)return showToast('Login karein!');
  const input=document.getElementById('pdCommInput');
  const text=input?.value?.trim();if(!text)return;
  const replyData = input._replyTo || null;
  input.value='';
  input._replyTo=null;
  input.placeholder='Write a comment...';
  input.style.borderColor='var(--border)';
  try{
    const commentData={
      text,authorId:cUser.uid,authorName:cUserData?.name||cUser.email,
      authorPhoto:cUserData?.photoURL||'',time:Date.now(),
      likes:0,likedBy:[],
      replyTo:replyData?replyData.name:null,
      parentId:replyData?replyData.commentId:null
    };
    if(replyData && replyData.commentId){
      await db.collection('posts').doc(postId).collection('comments').doc(replyData.commentId).collection('replies').add(commentData);
      await db.collection('posts').doc(postId).collection('comments').doc(replyData.commentId).update({replyCount:firebase.firestore.FieldValue.increment(1)});
      const parentSnap=await db.collection('posts').doc(postId).collection('comments').doc(replyData.commentId).get();
      if(parentSnap.exists){
        const parentAuthorId=parentSnap.data().authorId;
        if(parentAuthorId&&parentAuthorId!==cUser.uid) sendNotif(parentAuthorId,'reply',`${cUserData?.name||'Someone'} replied: "${text.substring(0,40)}"`,postId,'video');
      }
    } else {
      await db.collection('posts').doc(postId).collection('comments').add(commentData);
      await db.collection('posts').doc(postId).update({comments:firebase.firestore.FieldValue.increment(1)});
      sendNotif(currentPostData?.authorId||'','comment',`${cUserData?.name||'Someone'} commented: "${text.substring(0,40)}"`,postId,'video');
    }
    showToast('Comment posted ✅');
    pdLoadComments(postId);
  }catch(e){showToast('Error posting');}
}

