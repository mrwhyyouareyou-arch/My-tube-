// Touch swipe for shorts
(function(){
  let ts=0,ty=0;
  const el=document.getElementById('shortFS')||document.body;
  document.addEventListener('touchstart',e=>{if(!document.getElementById('shortFS').classList.contains('open'))return;ts=e.touches[0].clientY;ty=e.touches[0].clientX;},{passive:true});
  document.addEventListener('touchend',e=>{
    if(!document.getElementById('shortFS').classList.contains('open'))return;
    const dy=ts-e.changedTouches[0].clientY;
    const dx=ty-e.changedTouches[0].clientX;
    if(Math.abs(dy)>Math.abs(dx)&&Math.abs(dy)>50){
      if(dy>0)nextShort();else prevShort();
    }
  },{passive:true});
})();

