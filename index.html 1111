async function ownerReviewMonet(appId,uid,email,name,action){
  try{
    await db.collection('monetizationApps').doc(appId).update({status:action==='approve'?'approved':'rejected',reviewedAt:Date.now(),reviewedBy:cUser.uid});
    if(action==='approve'&&uid){
      await db.collection('users').doc(uid).update({monetizationApproved:true,monetizationApprovedAt:Date.now()});
      // Send notification to creator
      await db.collection('notifications').add({to:uid,from:cUser.uid,fromName:'Stream x Team',type:'system',text:`🎉 Mubarak ho! Aapki monetization application approve ho gayi. Ab aap earn kar sakte hain!`,postId:null,read:false,time:Date.now()});
    }else if(action==='reject'&&uid){
      await db.collection('notifications').add({to:uid,from:cUser.uid,fromName:'Stream x Team',type:'system',text:`Aapki monetization application abhi approve nahi hui. Requirements poori karein aur dobara apply karein.`,postId:null,read:false,time:Date.now()});
    }
    showToast(action==='approve'?`✅ ${name} approved! Notification bhi bhej diya`:`❌ ${name} reject kar diya`);
    loadOwnerMonetization();
  }catch(e){showToast('Error: '+e.message);}
}

async function ownerRevokeMonet(appId,name){
