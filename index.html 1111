let _storiesData=[];
let _svCurrentUser=null;
let _svCurrentStoryIdx=0;
let _svTimer=null;
const STORY_DURATION=5000; // 5 sec per story

async function loadStories(){
  const row=document.getElementById('storiesRow');
  if(!row)return;
  try{
    const now=Date.now();
    const cutoff=now-(24*60*60*1000); // 24 hours
    const snap=await db.collection('stories').where('time','>',cutoff).orderBy('time','desc').limit(100).get();
    // Group by user
    const byUser={};
    snap.docs.forEach(d=>{
      const s={id:d.id,...d.data()};
      if(!byUser[s.authorId])byUser[s.authorId]={authorId:s.authorId,authorName:s.authorName,authorPhoto:s.authorPhoto,stories:[]};
      byUser[s.authorId].stories.push(s);
    });
    _storiesData=Object.values(byUser);
    // Render
    const addBtn=row.querySelector('.story-item');
    row.innerHTML='';
    if(addBtn)row.appendChild(addBtn);
    const seenKey='sx_seen_stories';
    const seen=JSON.parse(localStorage.getItem(seenKey)||'[]');
    _storiesData.forEach((u,i)=>{
      const isSeen=seen.includes(u.authorId);
      const avHtml=u.authorPhoto?`<img src="${u.authorPhoto}">`:(u.authorName||'U')[0].toUpperCase();
      const el=document.createElement('div');
      el.className='story-item';
      el.innerHTML=`<div class="story-ring${isSeen?' seen':''}"><div class="story-av">${avHtml}</div></div><div class="story-name">${u.authorName||'User'}</div>`;
      el.onclick=()=>openStoryViewer(i);
      row.appendChild(el);
    });
  }catch(e){console.warn('Stories load err:',e);}
}

function openStoryViewer(userIdx){
  _svCurrentUser=userIdx;
  _svCurrentStoryIdx=0;
  document.getElementById('storyViewer').classList.add('open');
  renderStorySlide();
  // Mark seen
  const seenKey='sx_seen_stories';
  const seen=JSON.parse(localStorage.getItem(seenKey)||'[]');
  const uid=_storiesData[_svCurrentUser]?.authorId;
  if(uid&&!seen.includes(uid)){seen.push(uid);localStorage.setItem(seenKey,JSON.stringify(seen.slice(-200)));}
  // Update ring
  loadStories();
}

let _svPaused=false;
let _svPauseStart=0;
let _svRemainingTime=0;

function svPause(){
  if(_svPaused)return;
  _svPaused=true;
  _svPauseStart=Date.now();
  clearTimeout(_svTimer);
  // Freeze progress bar
  const fill=document.getElementById('svFill_'+_svCurrentStoryIdx);
  if(fill){
    const computed=getComputedStyle(fill).width;
    const parent=fill.parentElement;
    const pct=parent?((parseFloat(computed)/parent.offsetWidth)*100).toFixed(2)+'%':'0%';
    fill.style.transition='none';
    fill.style.width=pct;
  }
  // Pause video if any
  const vid=document.getElementById('svMedia')?.querySelector('video');
  if(vid)vid.pause();
  // Show pause indicator
  const viewer=document.getElementById('storyViewer');
  if(viewer&&!viewer.querySelector('.sv-pause-icon')){
    const icon=document.createElement('div');
    icon.className='sv-pause-icon';
    icon.style.cssText='position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,.5);border-radius:50%;width:50px;height:50px;display:flex;align-items:center;justify-content:center;z-index:20;pointer-events:none;';
    icon.innerHTML='<i class="fas fa-pause" style="color:white;font-size:20px;"></i>';
    viewer.appendChild(icon);
  }
}

function svResume(){
  if(!_svPaused)return;
  _svPaused=false;
  // Remove pause icon
  document.querySelector('.sv-pause-icon')?.remove();
  // Resume video
  const vid=document.getElementById('svMedia')?.querySelector('video');
  if(vid)vid.play().catch(()=>{});
  // Calculate remaining time
  const elapsed=Date.now()-_svPauseStart;
  const remaining=Math.max(500,(_svRemainingTime||STORY_DURATION)-elapsed);
  _svRemainingTime=remaining;
  // Resume progress bar
  const fill=document.getElementById('svFill_'+_svCurrentStoryIdx);
  if(fill){
    const parent=fill.parentElement;
    const currentPct=parent?(parseFloat(fill.style.width)/parent.offsetWidth*100):0;
    const remainingPct=100-currentPct;
    const timePerPct=remaining/remainingPct;
    fill.style.transition=`width ${remaining}ms linear`;
    fill.style.width='100%';
  }
  _svTimer=setTimeout(()=>svNext(),remaining);
}

function renderStorySlide(){
  _svPaused=false;
  _svRemainingTime=STORY_DURATION;
  document.querySelector('.sv-pause-icon')?.remove();
  const u=_storiesData[_svCurrentUser];
  if(!u)return closeStoryViewer();
  const s=u.stories[_svCurrentStoryIdx];
  if(!s)return closeStoryViewer();
  const avEl=document.getElementById('svAvatar');
  const avHtml=u.authorPhoto?`<img src="${u.authorPhoto}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`:(u.authorName||'U')[0].toUpperCase();
  if(avEl)avEl.innerHTML=avHtml;
  const nameEl=document.getElementById('svName');if(nameEl)nameEl.textContent=u.authorName||'User';
  const timeEl=document.getElementById('svTime');if(timeEl)timeEl.textContent=getTimeAgo(s.time);
  const prog=document.getElementById('svProgress');
  if(prog){
    prog.innerHTML=u.stories.map((_,i)=>`<div class="sv-bar"><div class="sv-bar-fill" id="svFill_${i}" style="width:${i<_svCurrentStoryIdx?'100%':'0%'}"></div></div>`).join('');
    requestAnimationFrame(()=>{
      const fill=document.getElementById('svFill_'+_svCurrentStoryIdx);
      if(fill){
        fill.style.transition=`width ${STORY_DURATION}ms linear`;
        fill.style.width='100%';
      }
    });
  }
  const media=document.getElementById('svMedia');
  const navLeft=`<div class="sv-nav left" onpointerdown="svPause()" onpointerup="svPrev()" ontouchstart="svPause()" ontouchend="svPrev()"></div>`;
  const navRight=`<div class="sv-nav right" onpointerdown="svPause()" onpointerup="svNext()" ontouchstart="svPause()" ontouchend="svNext()"></div>`;
  if(s.type==='video'){
    media.innerHTML=`${navLeft}<video src="${s.url}" autoplay playsinline style="width:100%;height:100%;object-fit:contain;" onended="svNext()"></video>${navRight}`;
  }else{
    media.innerHTML=`${navLeft}<img src="${s.url}" style="width:100%;height:100%;object-fit:contain;" onpointerdown="svPause()" onpointerup="svResume()">${navRight}`;
  }
  // Hold to pause on the whole viewer (except footer)
  const viewer=document.getElementById('storyViewer');
  viewer.onpointerdown=function(e){
    if(e.target.closest('.sv-footer')||e.target.closest('.sv-header'))return;
    svPause();
  };
  viewer.onpointerup=function(e){
    if(e.target.closest('.sv-footer')||e.target.closest('.sv-header'))return;
    if(_svPaused)svResume();
  };
  clearTimeout(_svTimer);
  _svTimer=setTimeout(()=>svNext(),STORY_DURATION);
}

// Reply input - pause when typing, resume when done
document.addEventListener('DOMContentLoaded',()=>{
  const replyInp=document.getElementById('svReplyInp');
  if(replyInp){
    replyInp.addEventListener('focus',()=>svPause());
    replyInp.addEventListener('blur',()=>{
      // Resume only if input is empty (if text, user still thinking)
      setTimeout(()=>{if(!replyInp.value.trim())svResume();},300);
    });
  }
});



function svNext(){
  clearTimeout(_svTimer);
  const u=_storiesData[_svCurrentUser];
  if(!u)return closeStoryViewer();
  if(_svCurrentStoryIdx<u.stories.length-1){
    _svCurrentStoryIdx++;
    renderStorySlide();
  }else if(_svCurrentUser<_storiesData.length-1){
    _svCurrentUser++;
    _svCurrentStoryIdx=0;
    renderStorySlide();
  }else{
    closeStoryViewer();
  }
}

function svPrev(){
  clearTimeout(_svTimer);
  if(_svCurrentStoryIdx>0){
    _svCurrentStoryIdx--;
    renderStorySlide();
  }else if(_svCurrentUser>0){
    _svCurrentUser--;
    _svCurrentStoryIdx=0;
    renderStorySlide();
  }
}

function closeStoryViewer(){
  clearTimeout(_svTimer);
  document.getElementById('storyViewer').classList.remove('open');
  const media=document.getElementById('svMedia');
  if(media){const v=media.querySelector('video');if(v){v.pause();v.src='';}}
}

