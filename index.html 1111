async function likeComment(postId, commentId, btn){
  if(!cUser) return showToast('Login karein!');
  try{
    const ref = db.collection('posts').doc(postId).collection('comments').doc(commentId);
    const doc = await ref.get(); if(!doc.exists) return;
    const c = doc.data();
    const liked = (c.likedBy||[]).includes(cUser.uid);
    const countEl = document.getElementById('clcount_'+commentId);
    if(liked){
      await ref.update({likes:firebase.firestore.FieldValue.increment(-1), likedBy:firebase.firestore.FieldValue.arrayRemove(cUser.uid)});
      btn.classList.remove('liked');
      if(countEl) countEl.textContent = Math.max(0,(c.likes||1)-1);
    } else {
      await ref.update({likes:firebase.firestore.FieldValue.increment(1), likedBy:firebase.firestore.FieldValue.arrayUnion(cUser.uid)});
      btn.classList.add('liked');
      if(countEl) countEl.textContent = (c.likes||0)+1;
      // Notify comment author
      if(c.authorId && c.authorId !== cUser.uid){
        sendNotif(c.authorId,'like',`${cUserData?.name||'Someone'} liked your comment: "${(c.text||'').substring(0,40)}"`, postId, 'video');
      }
    }
  }catch(e){ showToast('Error'); }
}

