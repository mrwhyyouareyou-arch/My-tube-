async function confirmDeleteAccount(){
  const val=document.getElementById('deleteConfirmInput').value.trim();
  if(val!=='DELETE')return showToast('Type DELETE to confirm');
  if(!cUser)return showToast('Not logged in');
  if(!confirm('Last warning: ALL your data will be deleted forever. Continue?'))return;
  try{
    showToast('Deleting your account...');
    // Delete all user posts
    const posts=await db.collection('posts').where('authorId','==',cUser.uid).get();
    const batch=db.batch();
    posts.forEach(d=>batch.delete(d.ref));
    // Delete subscriptions
    const subs=await db.collection('subscriptions').where('from','==',cUser.uid).get();
    subs.forEach(d=>batch.delete(d.ref));
    const subs2=await db.collection('subscriptions').where('to','==',cUser.uid).get();
    subs2.forEach(d=>batch.delete(d.ref));
    // Delete user doc
    batch.delete(db.collection('users').doc(cUser.uid));
    batch.delete(db.collection('channels').doc(cUser.uid));
    await batch.commit();
    // Delete Firebase Auth user
    await cUser.delete();
    closeDeleteAccountSheet();
    showToast('Account deleted. Goodbye! 👋');
    setTimeout(()=>location.reload(),2000);
  }catch(e){
    if(e.code==='auth/requires-recent-login'){
      showToast('Please logout and login again to delete account');
    }else{
      showToast('Error: '+e.message);
    }
  }
}

