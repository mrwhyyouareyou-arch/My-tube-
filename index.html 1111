function updateOgTags(postId, p){
  try{
    const title = (p.title||'Stream X Video') + ' — Stream X 🇵🇰';
    const desc = p.desc
      ? p.desc.substring(0,160)
      : `${p.authorName||'Creator'} ka video — ${p.title||''}. Stream X pe dekho, Pakistan ka apna platform!`;

    // thumbURL preferred (proper image for OG preview)
    let img = p.thumbURL || '';
    if(!img && p.url){
      // Cloudinary video → generate thumbnail image URL
      img = p.url
        .replace('/upload/', '/upload/so_1,w_1200,h_630,c_fill/')
        .replace(/\.(mp4|mov|webm|avi|mkv)$/i, '.jpg');
    }
    if(!img) img = 'https://streamx.pk/og-banner.png';

    // Always share app URL (NOT Cloudinary) so WhatsApp/Facebook scrape OUR page
    // Worker URL — WhatsApp/Facebook scrape karte hain isko, OG image milti hai
    const appUrl = `${WORKER_URL}/?post=${postId}`;
    const browserUrl = `${location.origin}${location.pathname}?post=${postId}`;

    document.title = title;
    const set = (id, attr, val) => { const el=document.getElementById(id); if(el) el.setAttribute(attr, val); };
    set('ogTitle','content', title);
    set('ogDesc','content', desc);
    set('ogImage','content', img);
    set('ogImageSecure','content', img);
    set('ogUrl','content', appUrl);
    set('ogType','content', p.type==='short'?'video.other':'video.movie');
    set('twTitle','content', title);
    set('twDesc','content', desc);
    set('twImage','content', img);
    try{ history.replaceState(null,'', browserUrl); }catch(e){}
  }catch(e){}
}

function resetOgTags(){
  document.title = 'Stream X — Pakistan ka apna platform 🇵🇰';
