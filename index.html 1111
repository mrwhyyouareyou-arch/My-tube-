// Mark sale — called from owner dashboard when confirming a sale
async function ownerMarkSale(clickId,postId,creatorId,saleAmount,payMethod,payNumber){
  if(!cUser)return;
  const commission=Math.floor(saleAmount*0.7);
  const platformCut=saleAmount-commission;
  try{
    // Update click as converted
    await db.collection('affiliateClicks').doc(clickId).update({converted:true,saleAmount,commission,time:Date.now()});
    // Add to creator wallet
    await db.collection('affiliateWallet').doc(creatorId).set({
      balance:firebase.firestore.FieldValue.increment(commission),
      totalEarned:firebase.firestore.FieldValue.increment(commission),
      totalSales:firebase.firestore.FieldValue.increment(1),
    },{merge:true});
    // Log transaction
    await db.collection('affiliateTransactions').add({
      creatorId,postId,clickId,saleAmount,commission,platformCut,
      payMethod,payNumber,status:'pending',time:Date.now()
    });
    // Notify creator
    sendNotif(creatorId,'affiliate',`🎉 Your product sold! Commission: ₨${commission} added to your wallet.`,postId,'post');
    showToast('Sale marked! ₨'+commission+' added to creator wallet.');
    loadOwnerAffiliate();
  }catch(e){showToast('Error: '+e.message);}
}

