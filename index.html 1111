<style>
/* ═══ 50 THEMES ═══ */
:root{
  --bg:#0f0f0f;--bg2:#181818;--bg3:#222;--card:#1a1a1a;
  --red:#ff0000;--red2:#cc0000;--text:#fff;--text2:#aaa;--text3:#555;
  --border:#2a2a2a;--radius:12px;--font:'Outfit',sans-serif;
  --accent:#ff0000;--accent2:#ff4444;
}
/* LIGHT */
[data-theme="light"]{--bg:#f9f9f9;--bg2:#fff;--bg3:#f0f0f0;--card:#fff;--text:#0f0f0f;--text2:#606060;--text3:#999;--border:#e0e0e0;}
/* OCEAN BLUE */
[data-theme="ocean"]{--bg:#0a1628;--bg2:#0d1f3c;--bg3:#162a4f;--card:#0d1f3c;--text:#e8f4ff;--text2:#8ab4d4;--text3:#4a7fa5;--border:#1e3a5f;--accent:#0096ff;--red:#0096ff;--red2:#0077cc;}
/* FOREST GREEN */
[data-theme="forest"]{--bg:#0a1a0f;--bg2:#0d2214;--bg3:#143020;--card:#0d2214;--text:#e8ffe8;--text2:#7ab87a;--text3:#3a7a3a;--border:#1e3a1e;--accent:#00c864;--red:#00c864;--red2:#009a4f;}
/* PURPLE DREAM */
[data-theme="purple"]{--bg:#0f0a1e;--bg2:#150f2e;--bg3:#1e1440;--card:#150f2e;--text:#f0e8ff;--text2:#b09acc;--text3:#7055a0;--border:#2a1e50;--accent:#9b59b6;--red:#9b59b6;--red2:#7d3c98;}
/* SUNSET ORANGE */
[data-theme="sunset"]{--bg:#1a0a00;--bg2:#2a1200;--bg3:#3a1a00;--card:#2a1200;--text:#fff5e8;--text2:#cc8855;--text3:#885522;--border:#4a2200;--accent:#ff6600;--red:#ff6600;--red2:#cc4400;}
/* ROSE GOLD */
[data-theme="rose"]{--bg:#1a0a10;--bg2:#2a1018;--bg3:#3a1522;--card:#2a1018;--text:#ffe8f0;--text2:#cc8899;--text3:#885566;--border:#4a1a28;--accent:#e91e8c;--red:#e91e8c;--red2:#c0166e;}
/* MIDNIGHT */
[data-theme="midnight"]{--bg:#000010;--bg2:#000520;--bg3:#000a30;--card:#000520;--text:#e8eeff;--text2:#6670aa;--text3:#334488;--border:#001040;--accent:#4455ff;--red:#4455ff;--red2:#2233cc;}
/* GOLDEN */
[data-theme="golden"]{--bg:#1a1200;--bg2:#2a1e00;--bg3:#3a2a00;--card:#2a1e00;--text:#fff8e0;--text2:#ccaa44;--text3:#886622;--border:#4a3500;--accent:#ffd700;--red:#ffd700;--red2:#ccaa00;}
/* ICE */
[data-theme="ice"]{--bg:#f0f8ff;--bg2:#e8f4ff;--bg3:#ddeeff;--card:#fff;--text:#0a2040;--text2:#406080;--text3:#608090;--border:#c0d8ee;--accent:#00aaff;--red:#00aaff;--red2:#0088cc;}
/* CHERRY */
[data-theme="cherry"]{--bg:#1a0010;--bg2:#2a0018;--bg3:#3a0022;--card:#2a0018;--text:#ffe8f5;--text2:#cc5588;--text3:#882244;--border:#4a0030;--accent:#ff1a6e;--red:#ff1a6e;--red2:#cc0055;}
/* AMOLED */
[data-theme="amoled"]{--bg:#000;--bg2:#000;--bg3:#111;--card:#0a0a0a;--text:#fff;--text2:#888;--text3:#444;--border:#1a1a1a;--accent:#ff0000;--red:#ff0000;}
/* COFFEE */
[data-theme="coffee"]{--bg:#1a1008;--bg2:#2a1a0e;--bg3:#3a2416;--card:#2a1a0e;--text:#fff5e8;--text2:#c4955a;--text3:#8a6030;--border:#4a3020;--accent:#c4955a;--red:#c4955a;--red2:#a07040;}
/* MINT */
[data-theme="mint"]{--bg:#f0fff8;--bg2:#e8fff5;--bg3:#d0ffee;--card:#fff;--text:#003322;--text2:#337755;--text3:#66aa88;--border:#b0eecc;--accent:#00c896;--red:#00c896;--red2:#00a07a;}
/* GALAXY */
[data-theme="galaxy"]{--bg:#080320;--bg2:#100538;--bg3:#180850;--card:#100538;--text:#f0e8ff;--text2:#9988cc;--text3:#554488;--border:#200a60;--accent:#aa44ff;--red:#aa44ff;--red2:#8822dd;}
/* NEON */
[data-theme="neon"]{--bg:#000;--bg2:#030a00;--bg3:#051200;--card:#030a00;--text:#ccff44;--text2:#88cc00;--text3:#448800;--border:#0a2000;--accent:#ccff00;--red:#ccff00;--red2:#aadd00;}

*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;transition:background .3s,color .3s;overflow-x:hidden;}
button,input,textarea{font-family:var(--font);}

/* ═══ STORIES ═══ */
.stories-row{display:flex;gap:10px;overflow-x:auto;padding:10px 12px 6px;scrollbar-width:none;border-bottom:1px solid var(--border);}
.stories-row::-webkit-scrollbar{display:none;}
.story-item{display:flex;flex-direction:column;align-items:center;gap:4px;flex-shrink:0;cursor:pointer;}
.story-ring{width:56px;height:56px;border-radius:50%;padding:2.5px;background:linear-gradient(135deg,var(--red),#ff6600,#ffd700);position:relative;}
.story-ring.seen{background:var(--border);}
.story-ring.add-story{background:var(--bg3);border:2px dashed var(--border);}
.story-av{width:100%;height:100%;border-radius:50%;background:var(--bg2);border:2.5px solid var(--bg);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;overflow:hidden;color:white;}
.story-av img{width:100%;height:100%;object-fit:cover;}
.story-plus{position:absolute;bottom:-2px;right:-2px;width:18px;height:18px;background:var(--red);border-radius:50%;border:2px solid var(--bg);display:flex;align-items:center;justify-content:center;font-size:10px;color:white;font-weight:700;}
.story-name{font-size:10px;color:var(--text2);text-align:center;max-width:58px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

/* Story fullscreen viewer */
.story-viewer{position:fixed;inset:0;z-index:999;background:#000;display:none;flex-direction:column;}
.story-viewer.open{display:flex;}
.sv-progress{display:flex;gap:3px;padding:10px 10px 6px;position:absolute;top:0;left:0;right:0;z-index:10;}
.sv-bar{flex:1;height:2.5px;background:rgba(255,255,255,.3);border-radius:2px;overflow:hidden;}
.sv-bar-fill{height:100%;background:white;width:0%;transition:width linear;}
.sv-header{position:absolute;top:20px;left:0;right:0;z-index:10;display:flex;align-items:center;gap:10px;padding:0 12px;}
.sv-av{width:32px;height:32px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:white;overflow:hidden;flex-shrink:0;}
.sv-av img{width:100%;height:100%;object-fit:cover;}
.sv-name{font-size:13px;font-weight:700;color:white;flex:1;}
.sv-time{font-size:10px;color:rgba(255,255,255,.6);}
.sv-close{background:none;border:none;color:white;font-size:20px;cursor:pointer;padding:4px;}
.sv-media{flex:1;display:flex;align-items:center;justify-content:center;position:relative;}
.sv-media img{width:100%;height:100%;object-fit:contain;}
.sv-media video{width:100%;height:100%;object-fit:contain;}
.sv-nav{position:absolute;top:0;bottom:0;width:40%;cursor:pointer;}
.sv-nav.left{left:0;}
.sv-nav.right{right:0;}
.sv-footer{position:absolute;bottom:0;left:0;right:0;padding:12px 14px 28px;z-index:10;background:linear-gradient(transparent,rgba(0,0,0,.7));}
.sv-reply-row{display:flex;gap:8px;align-items:center;}
.sv-reply-inp{flex:1;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);border-radius:22px;padding:9px 14px;color:white;font-size:13px;outline:none;}
.sv-reply-inp::placeholder{color:rgba(255,255,255,.5);}
.sv-emoji-row{display:flex;gap:8px;margin-bottom:8px;}
.sv-emoji-btn{background:rgba(255,255,255,.12);border:none;border-radius:20px;padding:5px 10px;font-size:16px;cursor:pointer;transition:transform .15s;}
.sv-emoji-btn:active{transform:scale(.88);}
.sv-send-btn{width:36px;height:36px;background:var(--red);border:none;border-radius:50%;color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}

/* ═══ PRODUCT CARD OVERLAY (YouTube Shopping style) ═══ */
.prod-overlay-btn{position:absolute;bottom:54px;left:8px;z-index:15;background:rgba(0,0,0,.75);backdrop-filter:blur(4px);border:1px solid rgba(255,255,255,.15);border-radius:10px;padding:6px 10px;display:flex;align-items:center;gap:7px;cursor:pointer;max-width:200px;transition:all .2s;}
.prod-overlay-btn:active{transform:scale(.96);}
.prod-overlay-thumb{width:32px;height:32px;border-radius:6px;object-fit:cover;flex-shrink:0;background:var(--bg3);}
.prod-overlay-info{flex:1;min-width:0;}
.prod-overlay-name{font-size:10px;font-weight:700;color:white;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
/* Product image slots */
.prod-img-slot{width:72px;height:72px;border-radius:10px;background:var(--bg3);border:2px dashed var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;flex-shrink:0;transition:border-color .2s;}
.prod-img-slot:active{opacity:.8;}
.prod-img-slot i{color:var(--text3);font-size:20px;}
.prod-img-slot img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0;}
.prod-img-slot .slot-del{position:absolute;top:2px;right:2px;width:18px;height:18px;background:rgba(255,0,0,.85);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;color:white;cursor:pointer;z-index:2;}
.prod-img-slot.filled{border-color:#0096ff;border-style:solid;}
.prod-overlay-price{font-size:11px;font-weight:800;color:#00e676;}
.prod-overlay-badge{font-size:8px;color:rgba(255,255,255,.6);display:flex;align-items:center;gap:3px;}

/* Product bottom sheet */
.prod-sheet{position:fixed;bottom:0;left:0;right:0;z-index:800;background:var(--bg2);border-radius:20px 20px 0 0;padding:0 0 28px;transform:translateY(100%);transition:transform .32s cubic-bezier(.4,0,.2,1);max-height:85vh;overflow-y:auto;}
.prod-sheet.open{transform:translateY(0);}
.prod-sheet-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:10px auto 0;}
.prod-sheet-header{padding:12px 16px 0;display:flex;align-items:flex-start;gap:12px;}
.prod-sheet-img{width:80px;height:80px;border-radius:12px;object-fit:cover;flex-shrink:0;background:var(--bg3);}
.prod-sheet-info{flex:1;}
.prod-sheet-title{font-size:15px;font-weight:800;line-height:1.4;margin-bottom:4px;}
.prod-sheet-price{font-size:20px;font-weight:800;color:#00e676;margin-bottom:4px;}
.prod-sheet-platform{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:4px;}
.prod-sheet-desc{padding:10px 16px;font-size:12px;color:var(--text2);line-height:1.6;}
.prod-buy-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:calc(100% - 32px);margin:4px 16px 0;padding:13px;background:linear-gradient(135deg,#00e676,#00c064);border:none;border-radius:13px;font-size:15px;font-weight:800;color:#000;cursor:pointer;text-decoration:none;}
.prod-buy-btn:active{opacity:.85;}
.prod-sheet-overlay{position:fixed;inset:0;z-index:799;background:rgba(0,0,0,.4);display:none;}
.prod-sheet-overlay.open{display:block;}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

/* ═══ HEADER ═══ */
.header{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg);border-bottom:1px solid var(--border);}
.logo-wrap{display:flex;align-items:center;gap:6px;flex-shrink:0;cursor:pointer;}
.logo-icon{width:30px;height:21px;flex-shrink:0;}
.logo-text{font-size:16px;font-weight:800;color:var(--text);letter-spacing:-0.5px;}
.logo-text span{color:var(--red);}
.logo-text .streams{color:var(--red);}
.logo-text .max{color:var(--text);font-size:14px;}
.search-bar{flex:1;display:flex;align-items:center;background:var(--bg3);border:1px solid var(--border);border-radius:22px;overflow:hidden;transition:border-color .2s;}
.search-bar.focused{border-color:var(--red);}
.search-bar input{flex:1;padding:8px 12px;background:none;border:none;outline:none;color:var(--text);font-size:13px;}
.search-bar input::placeholder{color:var(--text3);}
.search-bar button{padding:8px 12px;background:none;border:none;color:var(--text2);cursor:pointer;font-size:14px;}
.header-actions{display:flex;gap:4px;align-items:center;}
.icon-btn{width:34px;height:34px;background:none;border:none;color:var(--text);cursor:pointer;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;position:relative;transition:background .2s;}
.icon-btn:active{background:var(--bg3);}
.notif-dot{position:absolute;top:-2px;right:-4px;min-width:16px;height:16px;background:#1a73e8;border-radius:8px;border:2px solid var(--bg);font-size:9px;font-weight:700;color:white;display:flex;align-items:center;justify-content:center;padding:0 3px;}
.avatar-btn{width:32px;height:32px;border-radius:50%;background:var(--red);border:2px solid var(--border);cursor:pointer;color:white;font-weight:700;font-size:13px;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;transition:border-color .2s;}
.avatar-btn:active{border-color:var(--red);}
.avatar-btn img{width:100%;height:100%;object-fit:cover;}

/* ═══ BOTTOM NAV ═══ */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;z-index:100;display:flex;background:var(--bg);border-top:1px solid var(--border);padding:4px 0 8px;}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;background:none;border:none;color:var(--text3);cursor:pointer;font-size:9px;padding:4px 0;transition:color .2s;}
.nav-item i{font-size:18px;}
.nav-item.active{color:var(--red);}
.nav-item.active i{transform:scale(1.1);}
.nav-plus{width:42px;height:42px;background:var(--red);border-radius:14px;display:flex;align-items:center;justify-content:center;margin-top:-6px;box-shadow:0 4px 12px rgba(255,0,0,.4);}

/* ═══ MAIN ═══ */
.main{padding-top:58px;padding-bottom:68px;min-height:100vh;}
.screen{display:none;}.screen.active{display:block;}
.spinner{width:28px;height:28px;border:3px solid var(--border);border-top-color:var(--red);border-radius:50%;animation:spin .7s linear infinite;margin:0 auto;}
@keyframes spin{to{transform:rotate(360deg);}}
.loader{display:flex;justify-content:center;padding:28px;}
.empty-state{text-align:center;padding:40px 20px;color:var(--text3);}
.empty-state i{font-size:44px;margin-bottom:12px;display:block;opacity:.35;}
.empty-state p{font-size:14px;}

/* ═══ AUTH ═══ */
.auth-screen{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;background:var(--bg);}
.auth-brand{text-align:center;margin-bottom:32px;}
.auth-brand svg{margin-bottom:8px;}
.auth-brand h1{font-size:28px;font-weight:800;margin-bottom:4px;}
.auth-brand h1 span{color:var(--red);}
.auth-brand h1 .streams{color:var(--red);}
.auth-brand h1 .max{color:var(--text);}
.auth-brand p{color:var(--text2);font-size:13px;}
.auth-card{width:100%;max-width:360px;background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px 20px;}
.auth-tabs{display:flex;gap:4px;background:var(--bg3);border-radius:10px;padding:4px;margin-bottom:20px;}
.auth-tab{flex:1;padding:8px;background:none;border:none;color:var(--text2);font-size:14px;font-weight:600;border-radius:8px;cursor:pointer;transition:all .2s;}
.auth-tab.active{background:var(--bg2);color:var(--text);}
.inp{width:100%;padding:11px 13px;background:var(--bg3);border:1.5px solid var(--border);border-radius:10px;color:var(--text);font-size:14px;outline:none;margin-bottom:10px;transition:border-color .2s;}
.inp:focus{border-color:var(--red);}
.btn-red{width:100%;padding:12px;background:var(--red);color:white;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;margin-bottom:10px;transition:opacity .2s;}
.btn-red:active{opacity:.8;}
.btn-red:disabled{background:#555;cursor:not-allowed;}
.btn-outline{width:100%;padding:11px;background:none;border:1.5px solid var(--border);color:var(--text);border-radius:10px;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:background .2s;}
.btn-outline:active{background:var(--bg3);}
.auth-err{color:#ff5555;font-size:12px;text-align:center;margin-top:6px;min-height:16px;}

/* ═══ CHIPS ═══ */
.chips-wrap{overflow-x:auto;padding:10px 12px 4px;}
.chips-wrap::-webkit-scrollbar{display:none;}
.chips{display:flex;gap:6px;width:max-content;}
.chip{padding:5px 13px;background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all .2s;}
.chip.active{background:var(--text);color:var(--bg);border-color:var(--text);}

/* ═══ FEED ═══ */
.feed{padding:0;}
/* YouTube-style video card */
.yt-card{margin-bottom:8px;cursor:pointer;animation:fadeUp .35s ease;background:var(--bg);}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.yt-thumb{position:relative;background:var(--bg3);aspect-ratio:16/9;width:100%;}
.yt-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
.yt-thumb-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--bg3);}
.yt-thumb-placeholder i{font-size:36px;color:var(--text3);opacity:.5;}
.yt-badge{position:absolute;top:7px;left:7px;background:var(--red);color:white;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;}
.yt-dur{position:absolute;bottom:5px;right:6px;background:rgba(0,0,0,.88);color:white;font-size:10px;font-weight:600;padding:2px 5px;border-radius:3px;}
.yt-info{display:flex;gap:9px;padding:10px 12px 12px;}
.yt-av{width:34px;height:34px;border-radius:50%;background:var(--red);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-weight:700;color:white;font-size:13px;overflow:hidden;}
.yt-av img{width:100%;height:100%;object-fit:cover;}
.yt-meta{flex:1;min-width:0;}
.yt-title{font-size:14px;font-weight:600;line-height:1.4;color:var(--text);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.yt-sub{font-size:12px;color:var(--text2);margin-top:3px;}
.yt-more{background:none;border:none;color:var(--text3);cursor:pointer;padding:4px;flex-shrink:0;font-size:16px;}

/* Post card */
.post-card{background:var(--card);border:1px solid var(--border);border-radius:14px;margin:0 12px 12px;overflow:hidden;animation:fadeUp .35s ease;cursor:pointer;}
.post-hdr{display:flex;align-items:center;gap:10px;padding:12px 14px 8px;}
.post-av{width:38px;height:38px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:14px;overflow:hidden;flex-shrink:0;}
.post-av img{width:100%;height:100%;object-fit:cover;}
.post-author{font-size:13px;font-weight:600;}
.post-time{font-size:11px;color:var(--text2);}
.post-body{padding:0 14px 10px;font-size:13px;color:var(--text2);line-height:1.6;}
.post-imgs{display:grid;gap:2px;}
.post-imgs.one img{width:100%;max-height:260px;object-fit:cover;}
.post-imgs.two{grid-template-columns:1fr 1fr;}
.post-imgs.two img{height:140px;object-fit:cover;width:100%;}
.post-imgs.three{grid-template-columns:1fr 1fr;}
.post-imgs.three img:first-child{grid-column:1/-1;height:150px;object-fit:cover;width:100%;}
.post-imgs.three img{height:90px;object-fit:cover;width:100%;}
.post-acts{display:flex;border-top:1px solid var(--border);}
.post-act{flex:1;background:none;border:none;color:var(--text2);cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;gap:4px;padding:8px;transition:color .2s;}
.post-act.liked{color:var(--red);}
.post-act i{font-size:15px;}

/* ═══ SHORTS GRID ═══ */
.shorts-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;padding:8px 12px;}
.short-card{position:relative;border-radius:10px;overflow:hidden;aspect-ratio:9/16;background:var(--bg3);cursor:pointer;}
.short-card img{width:100%;height:100%;object-fit:cover;display:block;}
.short-card .placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--bg3);}
.short-overlay{position:absolute;bottom:0;left:0;right:0;padding:8px;background:linear-gradient(transparent,rgba(0,0,0,.85));}
.short-ttl{font-size:11px;font-weight:600;color:white;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.short-stats{font-size:10px;color:rgba(255,255,255,.75);margin-top:2px;}

/* ═══ FULLSCREEN SHORT — YouTube Shorts Style ═══ */
.sf{position:fixed;inset:0;z-index:999;background:#000;display:none;flex-direction:column;}
.sf.open{display:flex;}

/* SCROLL SNAP CONTAINER */
.sf-wrap{flex:1;overflow-y:scroll;scroll-snap-type:y mandatory;-webkit-overflow-scrolling:touch;position:relative;}
.sf-wrap::-webkit-scrollbar{display:none;}

/* Each short = one full-screen slide */
.sf-slide{height:100vh;width:100%;scroll-snap-align:start;scroll-snap-stop:always;position:relative;overflow:hidden;flex-shrink:0;background:#000;}
.sf-slide video{width:100%;height:100%;object-fit:cover;position:absolute;inset:0;}

/* TOP TABS */
.sf-top-bar{position:fixed;top:0;left:0;right:0;z-index:1001;display:flex;align-items:center;justify-content:center;padding:10px 0 6px;background:linear-gradient(rgba(0,0,0,.5),transparent);pointer-events:none;}
.sf-top-bar *{pointer-events:auto;}
.sf-tab-btn{background:none;border:none;color:rgba(255,255,255,.6);font-size:13px;font-weight:600;padding:4px 12px;cursor:pointer;position:relative;}
.sf-tab-btn.sf-tab-active{color:#fff;font-weight:700;}
.sf-tab-btn.sf-tab-active::after{content:'';position:absolute;bottom:-2px;left:50%;transform:translateX(-50%);width:20px;height:2px;background:#fff;border-radius:2px;}
.sf-tab-sep{color:rgba(255,255,255,.3);font-size:13px;}

/* RIGHT ACTION BAR — YouTube Shorts style */
.sf-acts{position:fixed;right:8px;bottom:100px;display:flex;flex-direction:column;gap:6px;align-items:center;z-index:1001;}
.sf-act{display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;color:white;cursor:pointer;padding:4px;}
.sf-act-circle{width:46px;height:46px;border-radius:50%;background:rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);margin-bottom:1px;transition:transform .15s,background .2s;}
.sf-act:active .sf-act-circle{transform:scale(.88);}
.sf-act-circle.liked{background:rgba(255,50,50,.4);}
.sf-act-circle.disliked{background:rgba(80,180,255,.35);}
.sf-act-circle i{font-size:21px;filter:drop-shadow(0 1px 3px rgba(0,0,0,.5));}
.sf-act span{font-size:11px;font-weight:600;text-shadow:0 1px 3px rgba(0,0,0,.8);}

/* BOTTOM INFO */
.sf-info{position:fixed;bottom:18px;left:12px;right:72px;z-index:1001;pointer-events:none;}
.sf-info *{pointer-events:auto;}
.sf-ch{font-size:14px;font-weight:700;color:white;margin-bottom:2px;text-shadow:0 1px 4px rgba(0,0,0,.8);}
.sf-ttl2{font-size:12px;color:rgba(255,255,255,.9);text-shadow:0 1px 3px rgba(0,0,0,.8);}

/* PROGRESS BAR */
.sf-progress{position:fixed;bottom:0;left:0;right:0;height:3px;background:rgba(255,255,255,.2);z-index:1002;}
.sf-prog-fill{height:100%;background:#ff0000;width:0%;transition:none;}

/* CHANNEL ROW (fixed top, below tabs) */
.sf-channel-row{position:fixed;top:50px;left:0;right:0;z-index:1001;display:flex;align-items:center;gap:10px;padding:6px 12px;pointer-events:none;}
.sf-channel-row *{pointer-events:auto;}

/* PAUSE OVERLAY */
.sf-pause-ov{position:fixed;inset:0;display:none;align-items:center;justify-content:center;pointer-events:none;z-index:1000;}
.sf-pause-ov.show{display:flex;}

/* ═══ UPLOAD ═══ */
.upload-screen{padding:16px 14px;}
.upload-screen h2{font-size:18px;font-weight:700;margin-bottom:16px;}
.type-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:16px;}
.type-card{background:var(--card);border:2px solid var(--border);border-radius:13px;padding:14px 8px;text-align:center;cursor:pointer;transition:all .2s;}
.type-card.selected{border-color:var(--red);background:rgba(255,0,0,.06);}
.type-card:active{transform:scale(.97);}
.type-card i{font-size:22px;margin-bottom:6px;display:block;color:var(--red);}
.type-card span{font-size:11px;font-weight:600;color:var(--text2);}
.upload-form{display:none;}.upload-form.show{display:block;}
.file-drop{border:2px dashed var(--border);border-radius:13px;padding:26px;text-align:center;cursor:pointer;margin-bottom:12px;transition:border-color .2s;}
.file-drop:active,.file-drop.dragover{border-color:var(--red);}
.file-drop i{font-size:28px;color:var(--text2);margin-bottom:8px;}
.file-drop p{color:var(--text2);font-size:13px;}
.file-drop input{display:none;}
.upload-prev-img,.upload-prev-vid{width:100%;border-radius:9px;margin-bottom:12px;display:none;max-height:170px;object-fit:cover;}
.prog-bar{width:100%;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden;margin-bottom:12px;display:none;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--red),#ff6644);border-radius:3px;width:0%;transition:width .3s;}
.thumb-box{border:2px dashed var(--border);border-radius:10px;padding:12px;text-align:center;cursor:pointer;margin-bottom:12px;}
.thumb-box input{display:none;}
.thumb-box i{font-size:20px;color:var(--text2);margin-bottom:4px;}
.thumb-box p{font-size:11px;color:var(--text2);}
.thumb-prev{width:100%;border-radius:8px;max-height:90px;object-fit:cover;display:none;margin-top:8px;}
.post-img-grid{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;}
.post-img-item{position:relative;width:76px;height:76px;border-radius:8px;overflow:hidden;}
.post-img-item img{width:100%;height:100%;object-fit:cover;}
.post-img-rm{position:absolute;top:2px;right:2px;background:rgba(0,0,0,.75);border:none;color:white;border-radius:50%;width:18px;height:18px;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.add-img-btn{width:76px;height:76px;border:2px dashed var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text3);font-size:20px;}
.add-img-btn input{display:none;}
/* Privacy buttons */
.privacy-btn{flex:1;padding:9px 6px;background:var(--bg3);border:1.5px solid var(--border);color:var(--text2);border-radius:9px;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;transition:all .2s;}
.privacy-btn.active{background:rgba(255,0,0,.1);border-color:var(--red);color:var(--text);}
/* Heart animation multi-color */
.heart-anim{position:fixed;pointer-events:none;z-index:9999;font-size:28px;animation:heartFly .9s ease-out forwards;}
@keyframes heartFly{0%{opacity:1;transform:scale(0.5) translateY(0);}50%{opacity:1;transform:scale(1.4) translateY(-40px);}100%{opacity:0;transform:scale(1) translateY(-90px);}}

/* ═══ DASHBOARD ═══ */
.dash-screen{padding:16px 14px;}
.dash-hdr h2{font-size:20px;font-weight:800;}
.dash-hdr p{color:var(--text2);font-size:12px;margin-bottom:16px;}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:14px;}
.stat-ico{width:34px;height:34px;border-radius:9px;background:rgba(255,0,0,.1);display:flex;align-items:center;justify-content:center;color:var(--red);font-size:15px;margin-bottom:8px;}
.stat-num{font-size:22px;font-weight:800;}
.stat-lbl{color:var(--text2);font-size:11px;margin-top:2px;}
/* CTR */
.analytics-wrap{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:14px;margin-bottom:16px;}
.analytics-title{font-size:14px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:6px;}
.analytics-title i{color:var(--red);}
.an-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
.an-card{text-align:center;padding:10px 6px;background:var(--bg3);border-radius:10px;}
.an-num{font-size:16px;font-weight:800;color:var(--red);}
.an-lbl{font-size:9px;color:var(--text2);margin-top:2px;}
/* My content */
.sec-title{font-size:14px;font-weight:700;margin-bottom:10px;}
.my-vid-item{display:flex;gap:10px;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);}
.my-vid-thumb{width:74px;height:46px;border-radius:7px;background:var(--bg3);overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.my-vid-thumb img{width:100%;height:100%;object-fit:cover;}
.my-vid-info{flex:1;min-width:0;}
.my-vid-title{font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.my-vid-stats{font-size:10px;color:var(--text2);margin-top:2px;}
.my-vid-del{background:none;border:none;color:var(--text3);cursor:pointer;font-size:15px;padding:4px;flex-shrink:0;}
.my-vid-del:active{color:var(--red);}
/* Subs list */
.sub-item{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);}
.sub-av{width:38px;height:38px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:13px;overflow:hidden;flex-shrink:0;}
.sub-av img{width:100%;height:100%;object-fit:cover;}

/* ═══ PROFILE ═══ */
.prof-screen{padding-bottom:20px;}
.prof-cover{height:110px;background:linear-gradient(135deg,#1a0000,#4a0000,#1a0000);position:relative;}
.prof-info{padding:0 14px;display:flex;flex-direction:column;align-items:center;text-align:center;margin-top:-36px;margin-bottom:16px;}
.prof-pic-wrap{position:relative;margin-bottom:10px;}
.prof-pic{width:76px;height:76px;border-radius:50%;background:var(--red);border:3px solid var(--bg);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:800;color:white;overflow:hidden;}
.prof-pic img{width:100%;height:100%;object-fit:cover;}
.prof-pic-edit{position:absolute;bottom:0;right:0;width:24px;height:24px;background:var(--red);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid var(--bg);color:white;font-size:10px;}
#profilePicInput{display:none;}
.prof-name{font-size:18px;font-weight:700;}
.prof-handle{color:var(--text2);font-size:12px;margin-top:2px;}
.prof-email{color:var(--text3);font-size:11px;margin-top:1px;}
.prof-stats{display:flex;gap:24px;margin-top:12px;}
.pst{text-align:center;}
.pst-num{font-size:16px;font-weight:700;}
.pst-lbl{font-size:10px;color:var(--text2);}
.prof-acts{display:flex;gap:7px;margin-top:12px;width:100%;}
.btn-sm{flex:1;padding:8px;border-radius:9px;border:1px solid var(--border);background:var(--bg3);color:var(--text);font-size:12px;font-weight:500;cursor:pointer;transition:background .2s;}
.btn-sm:active{background:var(--border);}
.prof-section{padding:0 14px;margin-bottom:14px;}
.prof-sec-title{font-size:13px;font-weight:700;margin-bottom:10px;padding-bottom:7px;border-bottom:1px solid var(--border);}

/* ═══ CHANNEL SETUP ═══ */
.channel-setup-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;margin:0 14px 14px;}
.channel-setup-card h3{font-size:14px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:7px;}
.channel-setup-card h3 i{color:var(--red);}
/* Email channel selection */
.email-channel-wrap{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:12px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:border-color .2s;}
.email-channel-wrap:active,.email-channel-wrap.selected{border-color:var(--red);background:rgba(255,0,0,.05);}
.email-channel-av{width:42px;height:42px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:16px;overflow:hidden;flex-shrink:0;}
.email-channel-av img{width:100%;height:100%;object-fit:cover;}
.email-channel-info{flex:1;}
.email-channel-name{font-size:14px;font-weight:600;}
.email-channel-email{font-size:11px;color:var(--text2);}
.email-check{color:var(--red);font-size:18px;display:none;}
.email-channel-wrap.selected .email-check{display:block;}

/* ═══ THEMES SCREEN ═══ */
.themes-screen{padding:16px 14px;}
.themes-screen h2{font-size:18px;font-weight:700;margin-bottom:4px;}
.themes-screen p{color:var(--text2);font-size:12px;margin-bottom:16px;}
.themes-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.theme-card{border-radius:13px;overflow:hidden;cursor:pointer;border:2px solid var(--border);transition:all .2s;position:relative;}
.theme-card.active{border-color:var(--red);}
.theme-preview{height:80px;display:flex;flex-direction:column;padding:8px;}
.theme-top{display:flex;align-items:center;gap:6px;margin-bottom:6px;}
.theme-dot{width:20px;height:14px;border-radius:3px;}
.theme-line{flex:1;height:8px;border-radius:4px;opacity:.6;}
.theme-cards{display:grid;grid-template-columns:1fr 1fr;gap:4px;flex:1;}
.theme-mini{border-radius:4px;height:100%;}
.theme-label{padding:7px 10px;font-size:12px;font-weight:600;}
.theme-check{position:absolute;top:6px;right:6px;background:var(--red);color:white;border-radius:50%;width:20px;height:20px;display:none;align-items:center;justify-content:center;font-size:11px;}
.theme-card.active .theme-check{display:flex;}

/* ═══ WALLPAPER / GALLERY ═══ */
.gallery-screen{padding:16px 14px;}
.gallery-screen h2{font-size:18px;font-weight:700;margin-bottom:4px;}
.gallery-screen p{color:var(--text2);font-size:12px;margin-bottom:14px;}
.gallery-tabs{display:flex;gap:6px;margin-bottom:14px;overflow-x:auto;}
.gallery-tabs::-webkit-scrollbar{display:none;}
.gtab{padding:6px 14px;border-radius:20px;border:1px solid var(--border);background:var(--bg3);color:var(--text2);font-size:12px;cursor:pointer;white-space:nowrap;}
.gtab.active{background:var(--red);color:white;border-color:var(--red);}
.gallery-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:3px;}
.gallery-item{aspect-ratio:9/16;border-radius:8px;overflow:hidden;cursor:pointer;position:relative;background:var(--bg3);}
.gallery-item img{width:100%;height:100%;object-fit:cover;display:block;}
.gallery-item video{width:100%;height:100%;object-fit:cover;display:block;}
.gallery-item-info{position:absolute;bottom:0;left:0;right:0;padding:6px;background:linear-gradient(transparent,rgba(0,0,0,.7));}
.gallery-item-title{font-size:9px;color:white;font-weight:500;}
.gallery-add-btn{width:100%;padding:12px;background:var(--red);color:white;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;margin-top:14px;}
/* Gallery modal */
.gallery-modal{position:fixed;inset:0;z-index:500;background:#000;display:none;flex-direction:column;}
.gallery-modal.open{display:flex;}
.gm-header{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;background:#000;}
.gm-close{background:none;border:none;color:white;font-size:20px;cursor:pointer;}
.gm-title{font-size:15px;font-weight:600;color:white;}
.gm-content{flex:1;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.gm-content img,.gm-content video{max-width:100%;max-height:100%;object-fit:contain;}
.gm-footer{padding:12px 14px;background:rgba(0,0,0,.8);}
.gm-item-title{font-size:14px;font-weight:600;color:white;margin-bottom:4px;}
.gm-item-date{font-size:11px;color:#888;}
.gm-actions{display:flex;gap:10px;margin-top:10px;}
.gm-action{flex:1;padding:9px;border-radius:9px;border:1px solid #333;background:none;color:white;font-size:12px;cursor:pointer;}
.gm-del{border-color:var(--red);color:var(--red);}

/* ═══ VIDEO PLAYER ═══ */
.player-screen{position:fixed;inset:0;z-index:200;background:var(--bg);display:none;flex-direction:column;overflow:hidden;}
.player-screen.open{display:flex;}
/* ── YT-style: video pinned top, content scrolls below ── */
.player-screen .player-back{position:absolute;top:10px;left:10px;z-index:210;}
.player-vid-wrap{flex-shrink:0;width:100%;background:#000;position:relative;z-index:5;}
.player-back{position:fixed;top:10px;left:10px;z-index:210;width:34px;height:34px;background:rgba(0,0,0,.6);border:none;color:white;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;}
.player-vid-wrap{background:#000;width:100%;flex-shrink:0;min-height:200px;max-height:56.25vw;position:relative;z-index:5;}
.player-vid-wrap video{width:100%;height:auto;max-height:56.25vw;object-fit:contain;display:block;}
.player-vid-wrap img{width:100%;height:100%;object-fit:contain;}
/* Short ratio */
.player-vid-wrap.short-ratio{aspect-ratio:9/16;max-height:60vh;}
.player-vid-wrap.short-ratio video{max-height:60vh;height:100%;object-fit:cover;}
/* Scroll body — takes remaining height, scrolls independently */
.player-scroll-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;}
/* Sticky input bar at bottom of player */
.player-info{padding:12px 14px 0;}
.player-title{font-size:15px;font-weight:700;line-height:1.4;}
.player-meta{font-size:11px;color:var(--text2);margin-top:4px;}
.player-acts{display:flex;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin:10px 0;}
.pl-act{flex:1;padding:10px 4px;background:none;border:none;color:var(--text2);cursor:pointer;font-size:11px;font-weight:500;display:flex;flex-direction:column;align-items:center;gap:3px;transition:color .2s;}
.pl-act i{font-size:18px;}
.pl-act.liked{color:var(--red);}
.emoji-row{display:flex;gap:7px;padding:0 14px 10px;flex-wrap:wrap;}
.emoji-btn{background:var(--bg3);border:1.5px solid var(--border);border-radius:20px;padding:5px 10px;font-size:14px;cursor:pointer;display:flex;align-items:center;gap:4px;transition:all .2s;}
.emoji-btn span{font-size:11px;color:var(--text2);}
.emoji-btn.reacted{border-color:var(--red);background:rgba(255,0,0,.07);}
.ch-row{display:flex;align-items:center;gap:10px;padding:0 14px 12px;}
.ch-row-info{flex:1;}
.ch-row-name{font-size:13px;font-weight:700;}
.ch-row-subs{font-size:11px;color:var(--text2);}
.sub-btn{padding:7px 16px;background:var(--text);color:var(--bg);border:none;border-radius:20px;font-size:12px;font-weight:700;cursor:pointer;transition:opacity .2s;}
.sub-btn:active{opacity:.7;}
.sub-btn.subscribed{background:var(--bg3);color:var(--text);border:1px solid var(--border);}

/* ═══ COMMENTS ═══ */
.comm-sec{padding:0 14px;}
.comm-title{font-size:14px;font-weight:700;margin-bottom:12px;}
.comm-input-row{display:flex;gap:8px;align-items:center;margin-bottom:14px;}
.comm-av{width:30px;height:30px;border-radius:50%;background:var(--red);flex-shrink:0;display:flex;align-items:center;justify-content:center;color:white;font-size:11px;font-weight:700;overflow:hidden;}
.comm-av img{width:100%;height:100%;object-fit:cover;}
.comm-input{flex:1;padding:9px 13px;background:var(--bg3);border:1.5px solid var(--border);border-radius:20px;color:var(--text);font-size:13px;outline:none;transition:border-color .2s;}
.comm-input:focus{border-color:var(--red);}
.comm-send{width:34px;height:34px;background:var(--red);border:none;border-radius:50%;color:white;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;}
.comm-item{display:flex;gap:8px;margin-bottom:12px;animation:fadeUp .3s ease;}
.comm-body{flex:1;}
.comm-author{font-size:12px;font-weight:600;}
.comm-text{font-size:12px;color:var(--text2);margin-top:2px;line-height:1.5;}
.comm-time{font-size:10px;color:var(--text3);margin-top:3px;}
/* Sticky comment input bar */
.comm-sticky-bar{position:fixed;bottom:0;left:0;right:0;background:var(--bg);border-top:1px solid var(--border);padding:8px 14px 12px;z-index:210;display:none;gap:8px;align-items:center;}
.comm-sticky-bar.visible{display:flex;}
/* Comment like button - blue not red */
.comm-like-btn{background:none;border:none;color:var(--text3);font-size:11px;cursor:pointer;display:flex;align-items:center;gap:3px;padding:2px 6px;border-radius:10px;transition:all .15s;}
.comm-like-btn.liked{color:#1a73e8;background:rgba(26,115,232,.1);}
.comm-like-btn i{font-size:12px;}
/* Comment emoji reactions */
.comm-emoji-row{display:flex;gap:6px;padding:6px 0;overflow-x:auto;scrollbar-width:none;margin-bottom:8px;}
.comm-emoji-btn{background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:4px 10px;font-size:13px;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;transition:all .15s;}
.comm-emoji-btn:active{transform:scale(.93);}
.comm-emoji-btn.reacted{border-color:#1a73e8;background:rgba(26,115,232,.1);}
/* Guidelines bar */
.comm-guidelines{background:rgba(26,115,232,.06);border:1px solid rgba(26,115,232,.15);border-radius:10px;padding:8px 12px;margin-bottom:12px;font-size:11px;color:var(--text2);line-height:1.5;}
.comm-guidelines a{color:#1a73e8;text-decoration:none;}
/* Comment 3-dot menu */
.comm-3dot{background:none;border:none;color:var(--text3);cursor:pointer;padding:4px 6px;border-radius:50%;font-size:14px;margin-left:auto;}
.comm-ctx-sheet{position:fixed;bottom:0;left:0;right:0;z-index:700;background:var(--bg2);border-radius:20px 20px 0 0;padding:12px 0 28px;transform:translateY(100%);transition:transform .3s ease;}
.comm-ctx-sheet.open{transform:translateY(0);}
.comm-ctx-item{display:flex;align-items:center;gap:14px;padding:14px 20px;cursor:pointer;font-size:14px;}
.comm-ctx-item:active{background:var(--bg3);}
.comm-ctx-item.danger{color:#ff4444;}
/* Reply indicator */
.reply-indicator-bar{background:var(--bg3);border-left:3px solid var(--red);padding:6px 10px;border-radius:0 8px 8px 0;margin-bottom:6px;display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text3);}
/* Replies section */
.replies-wrap{margin-left:38px;margin-top:6px;border-left:2px solid var(--border);padding-left:10px;}
.load-replies-btn{background:none;border:none;color:var(--red);font-size:11px;font-weight:600;cursor:pointer;padding:4px 0;display:flex;align-items:center;gap:4px;margin-left:38px;}
/* End screen overlay */
.end-screen-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.88);z-index:20;display:none;flex-direction:column;align-items:center;justify-content:center;padding:16px;}
.end-screen-overlay.show{display:flex;}
.end-screen-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;max-width:400px;}
.end-vid-card{background:var(--bg2);border-radius:10px;overflow:hidden;cursor:pointer;position:relative;}
.end-vid-thumb{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;background:var(--bg3);}
.end-vid-title{font-size:10px;font-weight:600;color:white;padding:6px 8px;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.end-countdown-ring{width:48px;height:48px;position:relative;margin-bottom:10px;}
.end-replay-btn{background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.4);color:white;border-radius:20px;padding:7px 18px;font-size:13px;cursor:pointer;margin-top:10px;}

/* ═══ NOTIFICATIONS ═══ */
.notif-screen{padding:16px 14px;}
.notif-screen h2{font-size:18px;font-weight:700;margin-bottom:14px;}
.notif-item{display:flex;gap:10px;align-items:flex-start;padding:12px 0;border-bottom:1px solid var(--border);}
.notif-item.unread{background:rgba(255,0,0,.04);margin:0 -14px;padding:12px 14px;border-radius:10px;}
.notif-ic{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.notif-ic.like{background:rgba(255,0,0,.15);color:var(--red);}
.notif-ic.comment{background:rgba(0,150,255,.15);color:#0096ff;}
.notif-ic.sub{background:rgba(0,200,100,.15);color:#00c864;}
.notif-ic.system{background:rgba(255,150,0,.15);color:#ff9600;}
.notif-body{flex:1;}
.notif-text{font-size:12px;line-height:1.5;}
.notif-time{font-size:10px;color:var(--text3);margin-top:3px;}

/* ═══ SEARCH ═══ */
.search-screen{padding:10px 14px;}
.search-suggestions{margin-bottom:14px;}
.suggestion-chip{display:inline-flex;align-items:center;gap:6px;padding:6px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:20px;font-size:12px;color:var(--text2);cursor:pointer;margin:4px 4px 0 0;}
.suggestion-chip i{font-size:11px;color:var(--red);}

/* ═══ SUBS ═══ */
.subs-screen{padding:14px;}
.subs-screen h2{font-size:18px;font-weight:700;margin-bottom:14px;}

/* ═══ OWNER ═══ */
.owner-screen{padding:16px 14px;}
.owner-hdr{display:flex;align-items:center;gap:8px;margin-bottom:16px;}
.owner-hdr h2{font-size:20px;font-weight:800;}
.owner-badge{background:var(--red);color:white;font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px;}
.owner-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.ow-stat{background:var(--card);border:1px solid var(--border);border-radius:13px;padding:14px;}
.ow-ico{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;margin-bottom:8px;}
.ow-num{font-size:22px;font-weight:800;}
.ow-lbl{color:var(--text2);font-size:11px;}
.owner-sec-title{font-size:14px;font-weight:700;margin-bottom:12px;padding-bottom:7px;border-bottom:1px solid var(--border);}
.ou-item{display:flex;align-items:center;gap:10px;padding:11px 0;border-bottom:1px solid var(--border);}
.ou-av{width:40px;height:40px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;overflow:hidden;flex-shrink:0;}
.ou-av img{width:100%;height:100%;object-fit:cover;}
.ou-info{flex:1;}
.ou-name{font-size:13px;font-weight:600;}
.ou-meta{font-size:11px;color:var(--text2);margin-top:2px;}
.ou-badge{font-size:10px;padding:2px 7px;border-radius:5px;font-weight:600;}
.badge-active{background:rgba(0,200,100,.15);color:#00c864;}
.badge-ch{background:rgba(255,0,0,.1);color:var(--red);}

/* ═══ LIVE ═══ */
.live-screen{padding:16px 14px;}
.live-screen h2{font-size:18px;font-weight:700;margin-bottom:14px;}
.live-req-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:14px;}
.live-req-card h3{font-size:14px;font-weight:700;margin-bottom:4px;display:flex;align-items:center;gap:7px;}
.live-req-card p{font-size:12px;color:var(--text2);margin-bottom:14px;}
.live-req{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);}
.live-req-ic{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.req-ok{background:rgba(0,200,100,.15);color:#00c864;}
.req-no{background:rgba(255,0,0,.1);color:var(--red);}
.live-req-txt{flex:1;font-size:12px;}
.live-req-prog{font-size:11px;color:var(--text2);}
.live-prog-bar{height:3px;border-radius:2px;background:var(--border);margin-top:4px;overflow:hidden;}
.live-prog-fill{height:100%;background:var(--red);border-radius:2px;}
.live-setup-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;}
.live-setup-card h3{font-size:14px;font-weight:700;margin-bottom:14px;}
.live-ind{display:flex;align-items:center;gap:8px;padding:10px 14px;background:rgba(255,0,0,.1);border-radius:10px;margin-bottom:14px;}
.live-dot{width:10px;height:10px;background:var(--red);border-radius:50%;animation:blink 1.2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.live-badge{background:var(--red);color:white;font-size:11px;font-weight:700;padding:2px 8px;border-radius:4px;}

/* ═══ MODAL ═══ */
.modal-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.75);display:none;align-items:flex-end;}
.modal-overlay.open{display:flex;}
.modal-sheet{width:100%;background:var(--bg2);border-radius:20px 20px 0 0;padding:20px 16px;animation:slideUp .3s ease;max-height:92vh;overflow-y:auto;}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:none}}
.sheet-handle{width:34px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 16px;}
.sheet-title{font-size:16px;font-weight:700;margin-bottom:16px;}

