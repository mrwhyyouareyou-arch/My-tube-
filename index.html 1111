function switchAuthTab(tab,el){
  document.querySelectorAll('.auth-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('loginForm').style.display=tab==='login'?'block':'none';
  document.getElementById('signupForm').style.display=tab==='signup'?'block':'none';
  document.getElementById('authErr').textContent='';
}

async function doLogin(){
  const e=document.getElementById('loginEmail').value.trim();
  const p=document.getElementById('loginPass').value;
  const btn=document.getElementById('loginBtn');
  if(!e||!p)return setAuthErr('Email aur password dono enter karein');
  if(!e.includes('@'))return setAuthErr('Valid email enter karein');
  btn.disabled=true;btn.textContent='Logging in...';
  try{
    await auth.signInWithEmailAndPassword(e,p);
  }catch(err){
    setAuthErr(fErr(err.code));
    btn.disabled=false;btn.textContent='Login';
  }
}

async function doSignup(){
  const n=document.getElementById('signupName').value.trim();
  const e=document.getElementById('signupEmail').value.trim();
  const p=document.getElementById('signupPass').value;
  const btn=document.getElementById('signupBtn');
  if(!n||!e||!p)return setAuthErr('Sab fields fill karein');
  if(!e.includes('@'))return setAuthErr('Valid email enter karein');
  if(p.length<6)return setAuthErr('Password min 6 characters ka hona chahiye');
  btn.disabled=true;btn.textContent='Creating...';
  try{
    const c=await auth.createUserWithEmailAndPassword(e,p);
    await db.collection('users').doc(c.user.uid).set({
      name:n,email:e,
      handle:'@'+n.toLowerCase().replace(/\s+/g,'').replace(/[^a-z0-9]/g,'').substring(0,20),
      about:'',photoURL:'',subscribers:0,createdAt:Date.now(),lastSeen:Date.now()
    });
  }catch(err){
    setAuthErr(fErr(err.code));
    btn.disabled=false;btn.textContent='Create Account';
  }
}

