async function loadRelated(postId, postType, category){
  const list = document.getElementById('relatedList');
  if(!list) return;
  list.innerHTML = '<div style="display:flex;justify-content:center;padding:20px;"><div class="spinner"></div></div>';
  try {
    let snap;
    try { snap = await db.collection('posts').orderBy('rankScore','desc').limit(50).get(); }
    catch(e) { snap = await db.collection('posts').orderBy('time','desc').limit(50).get(); }

    const all = snap.docs.map(d => ({id:d.id,...d.data()})).filter(p => p.id !== postId);
    const shorts = all.filter(p => p.type === 'short' && p.url).slice(0, 8);
    const videos = all.filter(p => p.type !== 'short' && p.type !== 'post')
      .sort((a,b) => {
        const sa = (a.category===category?30:0)+(a.type===postType?10:0)+(a.rankScore||0);
        const sb = (b.category===category?30:0)+(b.type===postType?10:0)+(b.rankScore||0);
        return sb-sa;
      }).slice(0,15);
    const communityPosts = all.filter(p => p.type === 'post').slice(0, 3);

    if(!videos.length && !shorts.length && !communityPosts.length){
      list.innerHTML='<div style="text-align:center;padding:20px;color:var(--text3);font-size:12px;">Koi related content nahi mila</div>';
      return;
    }

    let html = '';

    // SHORTS ROW
    if(shorts.length){
      html += `<div style="margin-bottom:18px;">
        <div style="font-size:12px;font-weight:700;color:var(--text2);margin-bottom:10px;display:flex;align-items:center;gap:6px;">
          <i class="fas fa-film" style="color:var(--red);"></i> Shorts
        </div>
        <div style="display:flex;gap:8px;overflow-x:auto;padding-bottom:6px;scrollbar-width:none;-webkit-overflow-scrolling:touch;">
          ${shorts.map((p,si) => {
            const th = p.thumbURL||(p.url?p.url.replace('/upload/','/upload/so_0,w_200/').replace(/\.(mp4|mov|webm)$/,'.jpg'):'');
            const ttl = (p.title||'').replace(/</g,'&lt;');
            return `<div onclick="openRelatedShort('${p.id}');event.stopPropagation();" style="flex-shrink:0;width:80px;height:140px;border-radius:10px;overflow:hidden;background:var(--bg3);position:relative;cursor:pointer;">
              ${th?`<img src="${th}" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">`:'<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;"><i class="fas fa-film" style="color:var(--text3);font-size:20px;"></i></div>'}
              <div style="position:absolute;bottom:0;left:0;right:0;padding:5px;background:linear-gradient(transparent,rgba(0,0,0,.85));">
                <div style="font-size:9px;font-weight:600;color:white;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${ttl}</div>
              </div>
            </div>`;
          }).join('')}
        </div>
      </div>`;
    }

    // LANDSCAPE VIDEO CARDS
    html += videos.map(p => {
      const th = p.thumbURL||(p.url?p.url.replace('/upload/','/upload/so_1,w_400/').replace(/\.(mp4|mov|webm)$/,'.jpg'):'');
      const views = p.views>=1000000?(p.views/1000000).toFixed(1)+'M':p.views>=1000?(p.views/1000).toFixed(1)+'K':(p.views||0);
      const title = (p.title||'Untitled').replace(/</g,'&lt;');
      const ch = (p.authorName||'Unknown').replace(/</g,'&lt;');
      const dur = p.duration||'';
      return `<div onclick="openPost('${p.id}')" style="display:flex;gap:10px;align-items:flex-start;margin-bottom:14px;cursor:pointer;-webkit-tap-highlight-color:transparent;">
        <div style="position:relative;width:160px;min-width:160px;height:90px;border-radius:8px;overflow:hidden;background:var(--bg3);flex-shrink:0;">
          ${th?`<img src="${th}" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;">`:`<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;"><i class="fas fa-play-circle" style="font-size:26px;color:var(--text3);opacity:.5;"></i></div>`}
          ${dur?`<div style="position:absolute;bottom:4px;right:4px;background:rgba(0,0,0,.85);color:white;font-size:9px;font-weight:600;padding:2px 5px;border-radius:3px;">${dur}</div>`:''}
        </div>
        <div style="flex:1;min-width:0;padding-top:2px;">
          <div style="font-size:12px;font-weight:600;line-height:1.45;color:var(--text);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:5px;">${title}</div>
          <div style="font-size:11px;color:var(--text2);margin-bottom:3px;">${ch}</div>
          <div style="font-size:10px;color:var(--text3);">👁️ ${views} &nbsp;•&nbsp; ${getTimeAgo(p.time)}</div>
        </div>
      </div>`;
    }).join('');

    // COMMUNITY POSTS
    if(communityPosts.length){
      html += `<div style="margin-top:8px;margin-bottom:16px;">
        <div style="font-size:12px;font-weight:700;color:var(--text2);margin-bottom:10px;display:flex;align-items:center;gap:6px;padding:0 2px;">
          <i class="fas fa-users" style="color:var(--red);"></i> Community Posts
