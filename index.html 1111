async function applyForMonetization(){
  if(!cUser)return showToast('Login karein');
  // GEO RESTRICTION — India & Pakistan only
  const allowedCountries=['PK','IN'];
  try{
    const geoRes=await fetch('https://ipapi.co/json/').catch(()=>null);
    if(geoRes){
      const geoData=await geoRes.json().catch(()=>null);
      if(geoData&&geoData.country_code&&!allowedCountries.includes(geoData.country_code)){
        return showToast('⛔ Monetization sirf Pakistan aur India ke creators ke liye available hai');
      }
    }
  }catch(e){/* geo check fail — allow anyway */}
  try{
    // Check eligibility first
    const snap=await db.collection('posts').where('authorId','==',cUser.uid).get();
    let videos=0,totalWatchSecs=0;
    snap.forEach(d=>{const p=d.data();if(p.type==='video'||p.type==='gaming'||p.type==='music'){videos++;totalWatchSecs+=p.watchTime||0;}});
    const ud=await db.collection('users').doc(cUser.uid).get();
    const subs=ud.exists?(ud.data().subscribers||0):0;
    const watchHours=Math.round(totalWatchSecs/3600);
    if(subs<MONET_REQS.subscribers)return showToast(`${MONET_REQS.subscribers} subscribers chahiye! Abhi ${subs} hain 📈`);
    if(watchHours<MONET_REQS.watchHours)return showToast(`${MONET_REQS.watchHours} watch hours chahiye! Abhi ${watchHours} hrs hain ⏱️`);
    if(videos<MONET_REQS.videos)return showToast(`${MONET_REQS.videos} videos upload karo pehle! Abhi ${videos} hain 🎬`);
    const existing=await db.collection('monetizationApps').where('uid','==',cUser.uid).where('status','==','pending').get();
    if(!existing.empty)return showToast('Application already pending hai ⏳');
    await db.collection('monetizationApps').add({
      uid:cUser.uid,
      email:cUser.email,
      name:cUserData?.name||'',
      subscribers:subs,
      watchHours:watchHours,
      videos:videos,
      appliedAt:Date.now(),
      status:'pending'
    });
    showToast('🎉 Application submit ho gaya! 48 hours mein review hoga ✅');
    document.getElementById('monetApplyCard').style.borderColor='#00c864';
  }catch(e){showToast('Error: '+e.message);}
}

