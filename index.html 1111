async function loadOwnerUsers(){
  const ul=document.getElementById('ownerUsersList');
  if(!ul)return;
  ul.innerHTML='<div class="loader"><div class="spinner"></div></div>';
  try{
    const usersSnap=await db.collection('users').get();
    const users=usersSnap.docs.map(d=>({id:d.id,...d.data()})).sort((a,b)=>(b.lastSeen||0)-(a.lastSeen||0));
    renderOwnerUsers(users);
  }catch(e){ul.innerHTML='<div class="empty-state"><i class="fas fa-users"></i><p>Error loading users</p></div>';}
}

function renderOwnerUsers(users){
  const ul=document.getElementById('ownerUsersList');
  if(!ul)return;
  if(!users.length){ul.innerHTML='<div class="empty-state"><i class="fas fa-users"></i><p>No users yet</p></div>';return;}
  ul.innerHTML=users.map(u=>{
    const av=u.photoURL?`<img src="${u.photoURL}" style="width:100%;height:100%;object-fit:cover;">`:(u.name||'U')[0].toUpperCase();
    const ls=u.lastSeen?getTimeAgo(u.lastSeen):'Never';
    const active=u.lastSeen&&(Date.now()-u.lastSeen)<3*24*3600*1000;
    const isOwner=u.email===OWNER_EMAIL;
    return `<div class="ou-item">
      <div class="ou-av" style="overflow:hidden;">${av}</div>
      <div class="ou-info">
        <div class="ou-name">${u.name||'User'}${isOwner?' 👑':''}</div>
        <div class="ou-meta">${u.email||''} • ${ls}</div>
        ${u.channelName?`<div style="font-size:10px;color:var(--red);">📺 ${u.channelName}</div>`:''}
      </div>
      <div style="text-align:right;flex-shrink:0;">
        <span style="display:block;font-size:10px;color:${active?'#00c864':'var(--text3)'};">${active?'🟢 Active':'⚫ Offline'}</span>
        <span style="font-size:10px;color:var(--text3);">${u.subscribers||0} subs</span>
        ${!isOwner?`<button onclick="ownerBanUser('${u.id}','${(u.name||'User').replace(/'/g,'')}',event)" style="background:none;border:1px solid #ff4444;color:#ff4444;border-radius:6px;padding:3px 7px;font-size:9px;cursor:pointer;margin-top:4px;">Ban</button>`:''}
      </div>
    </div>`;
  }).join('');
}

function ownerSearchUsers(query){
  const q=query.toLowerCase().trim();
  if(!q){loadOwnerUsers();return;}
  db.collection('users').get().then(snap=>{
    const all=snap.docs.map(d=>({id:d.id,...d.data()}));
    const filtered=all.filter(u=>(u.name||'').toLowerCase().includes(q)||(u.email||'').toLowerCase().includes(q));
    renderOwnerUsers(filtered);
  });
}

