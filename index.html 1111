    const [uDoc, postsSnap] = await Promise.all([
      db.collection('users').doc(authorId).get(),
      db.collection('posts').where('authorId','==',authorId).get()
    ]);
    if(!uDoc.exists){showToast('Channel not found');closeChannelPage();return;}
    const u=uDoc.data();
    // Cover
    const coverDiv = document.getElementById('cpCoverDiv');
    if(coverDiv && u.coverURL){ coverDiv.style.backgroundImage=`url(${u.coverURL})`; coverDiv.style.backgroundSize='cover'; }
    // Avatar
    const pic=document.getElementById('cpPic');
    if(u.photoURL){pic.innerHTML=`<img src="${u.photoURL}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;}else{pic.textContent=(u.name||'U')[0].toUpperCase();}
    document.getElementById('cpName').textContent=u.channelName||u.name||'Channel';
    document.getElementById('cpHandle').textContent=u.channelHandle||u.handle||'@user';
    document.getElementById('cpAbout').textContent=u.channelAbout||u.about||'';
    // About snippet
    const snip = document.getElementById('cpAboutSnippet');
    if(snip) snip.textContent=u.channelAbout||u.about||'';
    // Stats
    let totalViews = 0;
    postsSnap.forEach(d=>{ totalViews += d.data().views||0; });
    const subsNum = u.subscribers||0;
    const vidsNum = postsSnap.size;
    document.getElementById('cpSubsNum').textContent = subsNum>=1000?(subsNum/1000).toFixed(1)+'K':subsNum;
    document.getElementById('cpVidsNum').textContent = vidsNum;
    document.getElementById('cpViewsNum').textContent = totalViews>=1000000?(totalViews/1000000).toFixed(1)+'M':totalViews>=1000?(totalViews/1000).toFixed(1)+'K':totalViews;
    // Sub button
    const subBtn=document.getElementById('cpSubBtn');
    if(authorId===cUser?.uid){subBtn.style.display='none';}
    else{
      subBtn.style.display='block';
      if(cUser){
        try{
          const subDoc=await db.collection('subscriptions').doc(`${cUser.uid}_${authorId}`).get();
          if(subDoc.exists){subBtn.textContent='Subscribed ✓';subBtn.classList.add('subscribed');}
          else{subBtn.textContent='Subscribe';subBtn.classList.remove('subscribed');}
        }catch(se){ subBtn.textContent='Subscribe'; }
      }
    }
    loadChannelVideos(authorId,'videos');
  }catch(err){showToast('Error loading channel');}
}

