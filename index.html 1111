async function scrapeProductInfo(url){
  const loadEl=document.getElementById('affScrapeLoading');
  const prevEl=document.getElementById('affiliateLinkPreview');
  if(loadEl)loadEl.style.display='block';
  if(prevEl)prevEl.style.display='none';
  try{
    const info=extractProductInfoFromUrl(url);
    // Step 1: Resolve short links first (s.daraz.pk, bit.ly etc)
    let finalUrl=url;
    const isShortLink=url.includes('s.daraz.pk')||url.includes('bit.ly')||url.includes('tinyurl')||url.includes('cutt.ly')||url.length<50;
    if(isShortLink){
      try{
        const resolveRes=await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(url)}`,{signal:AbortSignal.timeout(5000)});
        const resolveData=await resolveRes.json();
        // Get final URL from status
        if(resolveData.status?.url&&resolveData.status.url!==url){
          finalUrl=resolveData.status.url;
        }
      }catch(e){}
    }
    // Step 2: Scrape final URL
    const proxyUrl=`https://api.allorigins.win/get?url=${encodeURIComponent(finalUrl)}`;
    const res=await fetch(proxyUrl,{signal:AbortSignal.timeout(10000)});
    const data=await res.json();
    const html=data.contents||'';
    // Step 3: Update info with resolved URL
    const finalInfo=extractProductInfoFromUrl(finalUrl);
    // Step 4: Parse OG meta tags
    const getOG=(prop)=>{
      const m=html.match(new RegExp(`<meta[^>]*property=["']og:${prop}["'][^>]*content=["']([^"']+)["']`,'i'))
        ||html.match(new RegExp(`<meta[^>]*content=["']([^"']+)["'][^>]*property=["']og:${prop}["']`,'i'));
      return m?decodeHTMLEntities(m[1]):'';
    };
    // Step 5: Also try title tag and Daraz specific selectors
    const titleTagMatch=html.match(/<title[^>]*>([^<]+)<\/title>/i);
    const titleTag=titleTagMatch?decodeHTMLEntities(titleTagMatch[1].replace(/\s*[\|–-]\s*Daraz.*$/i,'').trim()):'';
    const title=getOG('title')||titleTag||finalInfo.title||info.title||'Product';
    const img=getOG('image')||finalInfo.img||info.img||'';
    let price=extractPrice(html)||finalInfo.price||info.price||'';
    const platform=finalInfo.platform||info.platform||'Online Store';
    const desc=getOG('description')||'';
    // Show preview
    if(loadEl)loadEl.style.display='none';
    if(prevEl){
      prevEl.style.display='block';
      document.getElementById('affPrevImg').src=img;
      document.getElementById('affPrevTitle').textContent=title;
      document.getElementById('affPrevPrice').textContent=price;
      document.getElementById('affPrevPlatform').textContent=platform;
    }
    // Store for upload
    window._scrapedProduct={title,img,price,platform,desc,link:url};
  }catch(err){
    if(loadEl)loadEl.style.display='none';
    // Use URL-based fallback
    const info=extractProductInfoFromUrl(url);
    if(prevEl&&info.title){
      prevEl.style.display='block';
      document.getElementById('affPrevImg').src='';
      document.getElementById('affPrevTitle').textContent=info.title;
      document.getElementById('affPrevPrice').textContent=info.price||'';
      document.getElementById('affPrevPlatform').textContent=info.platform||'Online Store';
    }
    window._scrapedProduct={title:info.title||'Product',img:'',price:info.price||'',platform:info.platform||'Store',desc:'',link:url};
  }
}

function decodeHTMLEntities(str){
  if(!str)return '';
  return str.replace(/&amp;/g,'&').replace(/&lt;/g,'<').replace(/&gt;/g,'>').replace(/&quot;/g,'"').replace(/&#39;/g,"'").replace(/&nbsp;/g,' ');
}

function extractProductInfoFromUrl(url){
  try{
    const u=new URL(url);
    const host=u.hostname.replace('www.','');
    let platform='Online Store',title='',price='';
    if(host.includes('daraz'))platform='Daraz.pk';
    else if(host.includes('amazon'))platform='Amazon';
    else if(host.includes('olx'))platform='OLX';
    else if(host.includes('alibaba'))platform='Alibaba';
    else if(host.includes('aliexpress'))platform='AliExpress';
    else if(host.includes('shopify')||host.includes('myshopify'))platform='Shopify Store';
    else platform=host.split('.')[0].charAt(0).toUpperCase()+host.split('.')[0].slice(1);
    // Extract product name from URL path
    const path=u.pathname.replace(/[-_]/g,' ').replace(/\/products?\//i,'').replace(/\//g,' ').trim();
    title=path.slice(0,60)||'Product from '+platform;
    return{platform,title,price,img:''};
  }catch(e){return{platform:'Online Store',title:'',price:'',img:''};}
}

function extractPrice(html){
  // Common price patterns
  const patterns=[
    /["']price["']\s*:\s*["']?([\d,.]+)/i,
    /class=["'][^"']*price[^"']*["'][^>]*>[\s\S]*?([₨$£€Rp]\s*[\d,]+)/i,
    /itemprop=["']price["'][^>]*content=["']([\d.]+)/i,
    /"amount"\s*:\s*([\d.]+)/,
    /"price"\s*:\s*([\d.]+)/,
  ];
  for(const p of patterns){
    const m=html.match(p);
    if(m&&m[1]){
      const num=parseFloat(m[1].replace(/,/g,''));
      if(num>0&&num<1000000)return'₨'+num.toLocaleString();
    }
  }
  return'';
}

