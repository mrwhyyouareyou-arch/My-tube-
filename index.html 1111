// HOME FEED — Pro Algorithm
// ══════════════════════════════════════════════════════
// ══════════════════════════════════════════════════════
// INFINITE SCROLL — YouTube/Facebook style
// ══════════════════════════════════════════════════════
let _feedPage=0, _feedBatchSize=15, _feedLoading=false;
let _feedLastDoc=null, _feedAllLoaded=false, _feedCurrentFilter='all';

async function loadHome(){
  const feed=document.getElementById('homeFeed');
  feed.innerHTML='<div class="loader"><div class="spinner"></div></div>';
  // Reset pagination
  _feedPage=0; _feedLastDoc=null; _feedAllLoaded=false; allPosts=[];
  await loadNextBatch(true);
  setupInfiniteScroll();
}

async function loadNextBatch(isFirst=false){
  if(_feedLoading||_feedAllLoaded)return;
  _feedLoading=true;
  const feed=document.getElementById('homeFeed');
  // Show loader at bottom
  if(!isFirst){
    const loader=document.createElement('div');
    loader.id='feedBottomLoader';
    loader.className='loader';
    loader.innerHTML='<div class="spinner"></div>';
    feed.appendChild(loader);
  }
  try{
    let query;
    if(_feedCurrentFilter==='trending'){
      try{ query=db.collection('posts').orderBy('rankScore','desc').limit(_feedBatchSize*2); }
      catch(e){ query=db.collection('posts').orderBy('time','desc').limit(_feedBatchSize*2); }
    } else {
      query=db.collection('posts').orderBy('time','desc').limit(_feedBatchSize);
    }
    if(_feedLastDoc&&_feedCurrentFilter!=='trending')query=query.startAfter(_feedLastDoc);
    let snap;
    try{snap=await query.get();}
    catch(e){
      let q2=db.collection('posts').limit(_feedBatchSize);
      snap=await q2.get();
    }
    // Remove bottom loader
    const bl=document.getElementById('feedBottomLoader');if(bl)bl.remove();

    if(snap.empty||snap.docs.length<_feedBatchSize){
      _feedAllLoaded=true;
      if(snap.empty&&isFirst){
        feed.innerHTML='<div class="empty-state"><i class="fas fa-video-slash"></i><p>No content yet. Be the first to upload!</p></div>';
        _feedLoading=false;return;
      }
    }
    if(snap.docs.length>0)_feedLastDoc=snap.docs[snap.docs.length-1];

    const newPosts=snap.docs.map(d=>({id:d.id,...d.data()}));
    // Filter: show public posts + own unlisted/private
    const visiblePosts=newPosts.filter(p=>{
      const priv=p.privacy||'public';
      if(priv==='public')return true;
      if(priv==='unlisted')return true; // unlisted visible via link
      if(priv==='private')return p.authorId===cUser?.uid; // only owner sees private
      return true;
    });
    const filtered=(_feedCurrentFilter==='all'||_feedCurrentFilter==='trending')?visiblePosts:visiblePosts.filter(p=>p.type===_feedCurrentFilter||p.category===_feedCurrentFilter);
    const scored=sortFeedByAlgorithm(filtered,userPrefs);
    allPosts=[...allPosts,...scored];

    if(isFirst){
      feed.innerHTML='';
      // Add shorts row first if exists
      const shorts=allPosts.filter(p=>p.type==='short').slice(0,6);
      const nonShorts=allPosts.filter(p=>p.type!=='short');
      if(shorts.length&&nonShorts.length>=3){
        nonShorts.slice(0,3).forEach(p=>appendCard(p,feed));
        feed.insertAdjacentHTML('beforeend',buildInlineShortsRow(shorts));
        nonShorts.slice(3).forEach(p=>appendCard(p,feed));
      }else{
        allPosts.forEach(p=>appendCard(p,feed));
      }
    }else{
      scored.forEach(p=>appendCard(p,feed));
    }
    if(_feedAllLoaded&&allPosts.length>0){
      feed.insertAdjacentHTML('beforeend','<div style="text-align:center;padding:20px;color:var(--text3);font-size:12px;">✅ All caught up!</div>');
    }
  }catch(e){
    const bl=document.getElementById('feedBottomLoader');if(bl)bl.remove();
    console.error('Feed err:',e);
  }
  _feedLoading=false;
}

function appendCard(p,feed){
  const div=document.createElement('div');
  div.innerHTML=buildCard(p);
  if(div.firstChild)feed.appendChild(div.firstChild);
}

function setupInfiniteScroll(){
  // Remove old listener
  window._infiniteScrollHandler&&window.removeEventListener('scroll',window._infiniteScrollHandler);
  const mainEl=document.querySelector('.main')||window;
  mainEl._infiniteScrollHandler&&mainEl.removeEventListener('scroll',mainEl._infiniteScrollHandler);

  const handler=()=>{
    const el=document.querySelector('.main');
    if(!el)return;
    const scrolled=el.scrollTop+el.clientHeight;
    const total=el.scrollHeight;
    if(scrolled>total-300&&!_feedLoading&&!_feedAllLoaded){
      loadNextBatch();
    }
  };
  window._infiniteScrollHandler=handler;
  // Listen on .main element which is the scrollable container
  const mainDiv=document.querySelector('.main');
  if(mainDiv){
    mainDiv.removeEventListener('scroll',handler);
    mainDiv.addEventListener('scroll',handler,{passive:true});
  }
}

