// ══════════════════════════════════════════════════════
// DOUBLE-TAP HEARTS — Multi-color, continuous while holding
// ══════════════════════════════════════════════════════
const HEART_MULTI=['❤️','💜','💛','💚','💙','🧡','🤍','💖','💗'];
let _dtLastTap=0,_dtHoldInt=null;
let _dtTouchX=0,_dtTouchY=0; // live position tracked by touchmove

function setupDoubleTapHearts(){
  const sfEl=document.getElementById('shortFS');
  if(!sfEl)return;

  // Track live finger position
  sfEl.addEventListener('touchmove',function(e){
    if(e.touches[0]){
      _dtTouchX=e.touches[0].clientX;
      _dtTouchY=e.touches[0].clientY;
    }
  },{passive:true});

  sfEl.addEventListener('touchstart',function(e){
    // Ignore buttons
    if(e.target.closest('button,.sf-act,.sf-close,.sf-nav'))return;
    const now=Date.now();
    const diff=now-_dtLastTap;
    _dtLastTap=now;
    // Capture initial position
    _dtTouchX=e.touches[0].clientX;
    _dtTouchY=e.touches[0].clientY;

    if(diff<300&&diff>0){
      // Double tap — spawn hearts and like
      spawnHearts(_dtTouchX,_dtTouchY,3);
      sfLike();
      // Keep spawning while finger is held
      clearInterval(_dtHoldInt);
      _dtHoldInt=setInterval(()=>{
        spawnHearts(_dtTouchX,_dtTouchY,2);
      },140);
    }
  },{passive:true});

  sfEl.addEventListener('touchend',function(){
    if(_dtHoldInt){clearInterval(_dtHoldInt);_dtHoldInt=null;}
  },{passive:true});

  sfEl.addEventListener('touchcancel',function(){
    if(_dtHoldInt){clearInterval(_dtHoldInt);_dtHoldInt=null;}
  },{passive:true});
}

function spawnHearts(x,y,count){
  for(let i=0;i<count;i++){
    const em=HEART_MULTI[Math.floor(Math.random()*HEART_MULTI.length)];
    const el=document.createElement('div');
    el.className='heart-anim';
    el.style.left=(x+(Math.random()-0.5)*80)+'px';
    el.style.top=(y+(Math.random()-0.5)*60)+'px';
    el.style.animationDelay=(i*0.07)+'s';
    el.style.fontSize=(22+Math.random()*18)+'px';
    el.textContent=em;
    document.body.appendChild(el);
    setTimeout(()=>el.remove(),950+i*70);
  }
}

