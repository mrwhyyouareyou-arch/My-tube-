async function loadLatestVideos(){
  const feed = document.getElementById('latestVideosFeed');
  const countEl = document.getElementById('lvResultCount');
  if(!feed) return;
  feed.innerHTML = '<div class="loader"><div class="spinner"></div></div>';
  if(countEl) countEl.innerHTML = '<span style="font-size:11px;color:var(--text3);">Loading...</span>';

  try{
    // Get date range
    const now = Date.now();
    let fromTime = 0;
    const DAY = 86400000;
    if(_lvFilter === 'today')       fromTime = now - DAY;
    else if(_lvFilter === 'week')   fromTime = now - 7*DAY;
    else if(_lvFilter === 'last4weeks') fromTime = now - 28*DAY;
    else if(_lvFilter === 'last4months') fromTime = now - 120*DAY;
    else if(_lvFilter === 'last4years')  fromTime = now - 4*365*DAY;

    // Fetch from Firestore
    let query = db.collection('posts').orderBy('time','desc').limit(200);
    let snap;
    try{ snap = await query.get(); }
    catch(e){ snap = await db.collection('posts').limit(200).get(); }

    let posts = snap.docs.map(d=>({id:d.id,...d.data()})).filter(p=>{
      // Privacy filter
      const priv = p.privacy||'public';
      if(priv==='private' && p.authorId !== cUser?.uid) return false;
      // Time filter
      if(fromTime > 0 && (p.time||0) < fromTime) return false;
      // Only videos/shorts (not text posts)
      if(p.type === 'post') return false;
      return true;
    });

    // Sort
    if(_lvSort === 'views')  posts.sort((a,b)=>(b.views||0)-(a.views||0));
    else if(_lvSort === 'likes') posts.sort((a,b)=>(b.likes||0)-(a.likes||0));
    else posts.sort((a,b)=>(b.time||0)-(a.time||0)); // latest

    if(countEl) countEl.innerHTML = `<span style="font-size:11px;color:var(--text3);">${posts.length} video${posts.length!==1?'s':''} found</span>`;

    if(!posts.length){
      feed.innerHTML = '<div class="empty-state"><i class="fas fa-video-slash"></i><p>Is period mein koi video nahi mili</p></div>';
      return;
    }

    feed.innerHTML = '';
    posts.forEach(p => {
      const div = document.createElement('div');
      div.innerHTML = buildCard(p);
      if(div.firstChild) feed.appendChild(div.firstChild);
    });

    // "All caught up" footer
    feed.insertAdjacentHTML('beforeend','<div style="text-align:center;padding:20px;color:var(--text3);font-size:12px;">✅ Yahi hain latest videos is period mein!</div>');

  }catch(err){
    console.error('loadLatestVideos error:',err);
    feed.innerHTML = '<div class="empty-state"><i class="fas fa-exclamation-circle"></i><p>Error loading. Dobara try karein.</p></div>';
  }
}

