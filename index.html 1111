async function openPost(id){
  currentPostId=id;
  // First check if it's a post type - show post detail sheet
  try{
    const doc=await db.collection('posts').doc(id).get();
    if(!doc.exists){showToast('Content not found');return;}
    const p=doc.data();
    // If it's a text/image post without video, show Facebook-style post detail
    if(p.type==='post'){
      openPostDetail({id,...p});
      return;
    }
  }catch(e){console.warn('openPost type check:',e);}
  // Otherwise open video player
  const sc=document.getElementById('playerScreen');sc.classList.add('open');
  // Scroll content body to top (not the screen itself)
  const scrollBody=document.querySelector('#playerScreen .player-scroll-body');
  if(scrollBody) scrollBody.scrollTop=0;
  // Show sticky comment bar
  const stickyBar=document.getElementById('stickyCommBar');
  if(stickyBar) stickyBar.classList.add('visible');
  // Set my avatar
  if(cUserData?.photoURL){ document.getElementById('myCommAv').innerHTML=`<img src="${cUserData.photoURL}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">`; }
  else if(cUserData?.name){ document.getElementById('myCommAv').textContent=cUserData.name[0].toUpperCase(); }
  document.getElementById('playerTitle').textContent='Loading...';
  document.getElementById('commList').innerHTML='<div class="loader"><div class="spinner"></div></div>';
  try{
    const doc=await db.collection('posts').doc(id).get();
    if(!doc.exists){showToast('Video not found or deleted');return;}
    const p=doc.data();currentPostData={id,...p};
    updateUserPrefs(p);
    addToHistory(p);
    // Update OG/SEO meta tags for sharing
    updateOgTags(id, p);
    const vid=document.getElementById('playerVid');
    const wrap=document.getElementById('playerVidWrap');
    wrap.style.backgroundImage='';wrap.style.display='block';vid.style.display='block';
    // Aspect ratio: short = 9:16, others = 16:9
    if(p.type==='short'){
      wrap.classList.add('short-ratio');
    } else {
      wrap.classList.remove('short-ratio');
    }
    cancelEndScreen();
    // Hook end event for end screen
    vid.onended = ()=>{ showEndScreen(); };
    if(p.type==='image'){
      vid.style.display='none';
      wrap.style.backgroundImage=`url(${p.url})`;
      wrap.style.backgroundSize='contain';wrap.style.backgroundRepeat='no-repeat';
      wrap.style.backgroundPosition='center';wrap.style.backgroundColor='#000';
    }else if(p.type==='post'&&!p.url){
      vid.style.display='none';wrap.style.display='none';
    }else{
      if(p.url){
        vid.src='';
        vid.src=p.url;
        vid.load();
        vid.play().catch(()=>{
          // Show play button if autoplay blocked
          let po=document.getElementById('playOverlay');
          if(po)po.remove();
          po=document.createElement('div');
          po.id='playOverlay';
          po.style.cssText='position:absolute;inset:0;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:5;background:rgba(0,0,0,0.3);';
          po.innerHTML='<div style="width:64px;height:64px;background:rgba(0,0,0,.75);border-radius:50%;display:flex;align-items:center;justify-content:center;"><i class="fas fa-play" style="color:white;font-size:26px;margin-left:4px;"></i></div>';
          po.onclick=()=>{vid.play();po.remove();};
          wrap.appendChild(po);
        });
      }else{
        vid.style.display='none';
        wrap.style.display='flex';
        wrap.style.alignItems='center';
        wrap.style.justifyContent='center';
        wrap.innerHTML='<div style="color:#aaa;text-align:center;"><i class="fas fa-video-slash" style="font-size:36px;margin-bottom:8px;display:block;"></i><div style="font-size:13px;">Video unavailable</div></div>';
      }
    }
    document.getElementById('playerTitle').textContent=p.title||'Untitled';
    // Show @handle + views + time
    const handle=p.channelHandle||p.authorHandle||('@'+(p.authorName||'user').toLowerCase().replace(/[^a-z0-9]/g,''));
    document.getElementById('playerMeta').innerHTML=`
      <span style="color:var(--text2);font-size:12px;">${handle} &nbsp;•&nbsp; ${p.views||0} views &nbsp;•&nbsp; ${getTimeAgo(p.time)}</span>
      ${p.duration?`<span style="background:#000;color:#fff;font-size:10px;font-weight:600;padding:2px 6px;border-radius:3px;margin-left:6px;">${p.duration}</span>`:''}
      <span style="color:var(--red);font-size:11px;cursor:pointer;margin-left:4px;" onclick="showDescSheet()" id="playerMoreBtn">&nbsp;...more</span>
    `;
    const liked=cUser&&(p.likedBy||[]).includes(cUser.uid);
    document.getElementById('likeBtn').classList.toggle('liked',liked);
    document.getElementById('likeCount').textContent=p.likes||0;
    loadReactions(p);
    const ca=document.getElementById('playerChAv');
    if(p.authorPhoto){ca.innerHTML=`<img src="${p.authorPhoto}">`;}else{ca.textContent=(p.authorName||'U')[0].toUpperCase();}
    document.getElementById('playerChName').textContent=p.authorName||'Unknown';
    if(p.authorId){
      db.collection('users').doc(p.authorId).get().then(ud=>{
        if(ud.exists)document.getElementById('playerChSubs').textContent=(ud.data().subscribers||0)+' subscribers';
      });
      db.collection('subscriptions').doc(`${cUser.uid}_${p.authorId}`).get().then(sd=>{
        const sb=document.getElementById('playerSubBtn');
        if(sd.exists){sb.textContent='Subscribed';sb.classList.add('subscribed');}
        else{sb.textContent='Subscribe';sb.classList.remove('subscribed');}
        sb.style.display=p.authorId===cUser.uid?'none':'block';
      });
    }
    // View tracking — unique per user per video via Firestore
    trackUniqueView(id);
    loadComments(id);
    updateCommPreview(id);
    loadRelated(id, p.type, p.category||p.type);
    startWatchTimer(id);
    // Product card in player
    const ppCard=document.getElementById('playerProdCard');
    if(ppCard){
      if(p.productLink){
        ppCard.style.display='flex';
        const ppi=document.getElementById('playerProdImg');if(ppi)ppi.src=p.productImg||'';
        const ppt=document.getElementById('playerProdTitle');if(ppt)ppt.textContent=p.productTitle||'View Product';
