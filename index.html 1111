function previewAffLink(url){
  const prev=document.getElementById('affiliateLinkPreview');
  if(!url){if(prev)prev.style.display='none';return;}
  // Detect platform
  let platform='';
  if(url.includes('daraz'))platform='Daraz';
  else if(url.includes('amazon'))platform='Amazon';
