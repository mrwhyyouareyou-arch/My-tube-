// END SCREEN — 4 video cards + 10s autoplay
// ══════════════════════════════════════════════════════
let _endScreenTimer = null;
let _endScreenCancelled = false;

async function showEndScreen(){
  const overlay = document.getElementById('endScreenOverlay');
  if(!overlay) return;
  overlay.classList.add('show');
  _endScreenCancelled = false;
  const grid = document.getElementById('endScreenGrid');
  if(!grid) return;
  grid.innerHTML = '<div style="grid-column:1/-1;display:flex;justify-content:center;padding:20px;"><div class="spinner"></div></div>';

  try{
    // Algorithm: prefer same category/type as current video, high rankScore
    const p = currentPostData || {};
    let snap;
    try{ snap = await db.collection('posts').orderBy('rankScore','desc').limit(30).get(); }
    catch(e){ snap = await db.collection('posts').orderBy('time','desc').limit(30).get(); }

    let all = snap.docs.map(d=>({id:d.id,...d.data()}))
      .filter(v => v.id !== currentPostId && v.url && v.type !== 'post');

    // Score by relevance
    all = all.map(v=>{
      let score = v.rankScore||0;
      if(v.category && v.category === p.category) score += 50;
      if(v.type === p.type) score += 20;
      if(v.authorId === p.authorId) score += 30;
      return {...v, _score: score};
    }).sort((a,b)=>b._score - a._score).slice(0,4);

    renderEndScreenCards(all, grid);
    startEndScreenCountdown(all[0]);
  }catch(e){
    grid.innerHTML = '<div style="grid-column:1/-1;color:rgba(255,255,255,.5);text-align:center;font-size:12px;">No suggestions available</div>';
    startEndScreenCountdown(null);
  }
}

function renderEndScreenCards(posts, grid){
  grid.innerHTML = posts.map(p => {
    const th = p.thumbURL || '';
    const title = (p.title||'Video').replace(/</g,'&lt;').substring(0,40);
    return `<div class="end-vid-card" onclick="cancelEndScreen();openPost('${p.id}')">
      ${th ? `<img class="end-vid-thumb" src="${th}" loading="lazy">` : `<div class="end-vid-thumb" style="display:flex;align-items:center;justify-content:center;"><i class="fas fa-play-circle" style="font-size:28px;color:var(--text3);"></i></div>`}
      <div class="end-vid-title">${title}</div>
    </div>`;
  }).join('');
}

function startEndScreenCountdown(nextPost){
  let secs = 10;
  const numEl = document.getElementById('endCountdownNum');
  const circleEl = document.getElementById('endCountdownCircle');
  const circumference = 113; // 2*pi*18
  if(_endScreenTimer) clearInterval(_endScreenTimer);
  if(numEl) numEl.textContent = secs;
  _endScreenTimer = setInterval(()=>{
    if(_endScreenCancelled){ clearInterval(_endScreenTimer); return; }
    secs--;
    if(numEl) numEl.textContent = secs;
    if(circleEl){ const offset = circumference - (circumference * (10-secs) / 10); circleEl.style.strokeDashoffset = offset; }
    if(secs <= 0){
      clearInterval(_endScreenTimer);
      if(!_endScreenCancelled && nextPost){
        cancelEndScreen();
        openPost(nextPost.id);
      }
    }
  }, 1000);
}

function cancelEndScreen(){
  _endScreenCancelled = true;
  if(_endScreenTimer) clearInterval(_endScreenTimer);
  const overlay = document.getElementById('endScreenOverlay');
  if(overlay) overlay.classList.remove('show');
}

function replayVideo(){
  cancelEndScreen();
  const vid = document.getElementById('playerVid');
  if(vid){ vid.currentTime = 0; vid.play().catch(()=>{}); }
