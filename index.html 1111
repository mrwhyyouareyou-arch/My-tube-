// Double-tap like system for Shorts
let _sfTapTimer=null,_sfTapCount=0;
const HEART_COLORS=['#ff0000','#ff4d4d','#ff6b6b','#ff1493','#ff69b4','#e91e8c'];

function handleSfTap(e){
  _sfTapCount++;
  if(_sfTapCount===1){
    _sfTapTimer=setTimeout(()=>{
      _sfTapCount=0;
      // Single tap = pause/play
      const wrap=document.getElementById('sfWrap');
      const slides=wrap.querySelectorAll('.sf-slide');
      const v=slides[sfCurrentIdx]?slides[sfCurrentIdx].querySelector('video'):null;
      const ov=document.getElementById('sfPauseOverlay');
      const ic=document.getElementById('sfPauseIcon');
      if(v){
        if(v.paused){v.play();if(ic)ic.className='fas fa-play';}
        else{v.pause();if(ic)ic.className='fas fa-pause';}
        if(ov){
          ov.classList.add('show');
          clearTimeout(window._sfPauseTimer);
          window._sfPauseTimer=setTimeout(()=>{ov.classList.remove('show');},700);
        }
      }
    },250);
  }else if(_sfTapCount>=2){
    clearTimeout(_sfTapTimer);_sfTapCount=0;
    // Double tap = hearts + like
    showDoubleTapHeart(e.clientX,e.clientY);
    if(sfCurrentId&&cUser){
      db.collection('posts').doc(sfCurrentId).get().then(doc=>{
        const p=doc.data();
        const liked=(p.likedBy||[]).includes(cUser.uid);
        if(!liked){
          doc.ref.update({likes:firebase.firestore.FieldValue.increment(1),likedBy:firebase.firestore.FieldValue.arrayUnion(cUser.uid),rankScore:firebase.firestore.FieldValue.increment(10)});
          const cnt=document.getElementById('sfLikeCount');
          if(cnt)cnt.textContent=fmtCount((p.likes||0)+1);
          const lc=document.getElementById('sfLikeCircle');
          if(lc)lc.classList.add('liked');
        }
      }).catch(()=>{});
    }
  }
}

