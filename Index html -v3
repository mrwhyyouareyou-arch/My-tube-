// --- STREAM X RULES & CRITERIA ---
const ELITE_LIVE_SUBS_REQUIRED = 100;
const ELITE_LIVE_VIDEOS_REQUIRED = 40; // 20 Long + 20 Shorts

function checkLiveEligibility(userData) {
    const totalVideos = userData.longVideos + userData.shorts;
    
    if (userData.subscribers >= ELITE_LIVE_SUBS_REQUIRED && totalVideos >= ELITE_LIVE_VIDEOS_REQUIRED) {
        console.log("Stream X: Live Access Granted ✅");
        return true;
    } else {
        const remainingSubs = ELITE_LIVE_SUBS_REQUIRED - userData.subscribers;
        const remainingVideos = ELITE_LIVE_VIDEOS_REQUIRED - totalVideos;
        
        showEliteAlert(`Access Denied: You need ${remainingSubs} more subs and ${remainingVideos} more uploads to go Live.`);
        return false;
    }
}

// --- COPYRIGHT PROTECTION SYSTEM ---
function scanForCopyright(contentData) {
    // Simple logic to detect duplicate external links or banned keywords
    const bannedLinks = ['malware.com', 'scam.site'];
    if (bannedLinks.some(link => contentData.externalLink.includes(link))) {
        triggerCopyrightStrike(currentUser.uid, "Banned External Link Detected");
        return false;
    }
    return true;
}

function triggerCopyrightStrike(userId, reason) {
    db.collection('strikes').add({
        userId: userId,
        reason: reason,
        timestamp: firebase.firestore.FieldValue.serverTimestamp()
    });
    showEliteAlert("Copyright Strike! Your content was flagged by Stream X Algorithm.");
}

// Custom Elite Alert
function showEliteAlert(msg) {
    const alertBox = document.createElement('div');
    alertBox.className = 'elite-blur';
    alertBox.style.cssText = "position:fixed; top:20px; left:20px; right:20px; padding:15px; background:rgba(255,0,0,0.2); border:1px solid var(--red); border-radius:10px; z-index:10000; text-align:center; animation:slideIn 0.3s forwards;";
    alertBox.innerHTML = `<i class="fas fa-exclamation-triangle"></i> <span style="font-size:13px;">${msg}</span>`;
    document.body.appendChild(alertBox);
    setTimeout(() => alertBox.remove(), 4000);
}
