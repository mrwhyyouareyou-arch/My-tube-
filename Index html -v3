function triggerMultiHeart(e, container) {
    const heart = document.createElement('i');
    heart.className = 'fas fa-heart';
    const rect = container.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    heart.style.cssText = `
        position: absolute;
        left: ${x}px;
        top: ${y}px;
        color: var(--red);
        font-size: 35px;
        pointer-events: none;
        text-shadow: 0 0 15px rgba(255,0,0,0.8);
        animation: eliteHeartFly 0.7s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
